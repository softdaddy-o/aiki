---
import { t, getLocaleFromUrl } from '../i18n/utils';
import Search from '../components/Search.astro';

interface Props {
    title?: string;
    description?: string;
}

const lang = getLocaleFromUrl(Astro.url);
const { title, description } = Astro.props;
const siteTitle = title ? `${title} | ${t(lang, 'site.title')}` : t(lang, 'site.title');
const siteDesc = description ?? t(lang, 'site.description');
const otherLang = lang === 'ko' ? 'en' : 'ko';
const otherPath = Astro.url.pathname.replace(`/${lang}/`, `/${otherLang}/`);

const navItems = [
    { key: 'nav.home', href: `/${lang}/` },
    { key: 'nav.news', href: `/${lang}/` },
    { key: 'nav.wiki', href: `/${lang}/wiki/` },
    // { key: 'nav.models', href: `/${lang}/models/` },
    // { key: 'nav.tutorials', href: `/${lang}/tutorials/` },
    // { key: 'nav.about', href: `/${lang}/about/` },
];
---
<!DOCTYPE html>
<html lang={lang}>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{siteTitle}</title>
    <meta name="description" content={siteDesc} />
    <link rel="alternate" hreflang={otherLang} href={otherPath} />
    <link rel="stylesheet" as="style" crossorigin
        href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" />
</head>
<body data-pagefind-body>
    <nav class="site-nav">
        <a href={`/${lang}/`} class="site-logo">AIKI</a>
        <button class="nav-toggle" aria-label="Toggle navigation">
            <span></span><span></span><span></span>
        </button>
        <div class="nav-links">
            {navItems.map(item => (
                <a href={item.href}>{t(lang, item.key)}</a>
            ))}
        </div>
        <Search />
        <a href={otherPath} class="lang-switch">{otherLang.toUpperCase()}</a>
    </nav>
    <main>
        <slot />
    </main>
    <footer class="site-footer">
        <p>AIKI — AI-curated, human-verified.</p>
    </footer>
    <script is:inline>
        document.querySelector('.nav-toggle')?.addEventListener('click', () => {
            document.querySelector('.nav-links')?.classList.toggle('open');
        });
    </script>
</body>
</html>

<style is:global>
    :root {
        --color-bg: #0a0a1a;
        --color-surface: #14142a;
        --color-surface-alt: #1e1e2e;
        --color-surface-elevated: #2a2a3e;
        --color-text: #e0e0e0;
        --color-text-muted: #888;
        --color-news: #4fc3f7;
        --color-wiki: #ce93d8;
        --color-model: #fff176;
        --color-tutorial: #81c784;
        --color-skill: #f48fb1;
        --color-dot: #ef5350;
        --color-pass: #81c784;
        --color-fail: #ef5350;
        --text-xs: 0.75rem;
        --text-sm: 0.8125rem;
        --text-base: 1rem;
        --text-lg: 1.0625rem;
        --text-xl: 1.25rem;
        --text-2xl: 1.5rem;
        --text-3xl: 2rem;
        --text-4xl: 2.5rem;
        --color-border: rgba(255, 255, 255, 0.08);
        --color-border-strong: rgba(255, 255, 255, 0.15);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; color-scheme: dark; }
    ::selection { background: rgba(79, 195, 247, 0.3); color: #fff; }
    :focus-visible { outline: 2px solid var(--color-news); outline-offset: 2px; }
    body {
        font-family: 'Pretendard Variable', Pretendard, -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        font-size: var(--text-base);
        background: var(--color-bg);
        background-image: radial-gradient(ellipse at 50% 0%, rgba(79, 195, 247, 0.05) 0%, transparent 60%);
        color: var(--color-text);
        line-height: 1.6;
    }
    .site-nav {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 16px 24px;
        border-bottom: 1px solid var(--color-border);
        backdrop-filter: blur(12px);
        background: rgba(10, 10, 26, 0.85);
        position: sticky;
        top: 0;
        z-index: 100;
    }
    .site-logo {
        font-size: 22px;
        font-weight: 900;
        color: var(--color-news);
        text-decoration: none;
        letter-spacing: 3px;
        text-shadow: 0 0 20px rgba(79, 195, 247, 0.3);
    }
    .nav-links { display: flex; gap: 16px; flex: 1; }
    .nav-links a {
        color: var(--color-text-muted);
        text-decoration: none;
        font-size: 14px;
        padding: 10px 4px;
        transition: color 0.2s ease;
        position: relative;
    }
    .nav-links a:hover { color: var(--color-text); }
    .nav-links a::after {
        content: '';
        position: absolute;
        bottom: -4px;
        left: 0;
        right: 0;
        height: 2px;
        background: var(--color-news);
        transform: scaleX(0);
        transition: transform 0.2s ease;
    }
    .nav-links a:hover::after { transform: scaleX(1); }
    .nav-toggle {
        display: none;
        flex-direction: column;
        gap: 4px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 4px;
    }
    .nav-toggle span {
        display: block;
        width: 20px;
        height: 2px;
        background: var(--color-text);
        transition: transform 0.2s ease;
    }
    @media (max-width: 768px) {
        .nav-toggle { display: flex; }
        .nav-links {
            display: none;
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            flex-direction: column;
            background: var(--color-surface);
            padding: 16px 24px;
            border-bottom: 1px solid var(--color-border);
            gap: 12px;
        }
        .nav-links.open { display: flex; }
        .nav-links a { font-size: 16px; padding: 8px 0; }
        .site-nav { flex-wrap: wrap; position: relative; }
    }
    .lang-switch {
        color: var(--color-text-muted);
        text-decoration: none;
        font-size: 12px;
        padding: 4px 10px;
        border: 1px solid #444;
        border-radius: 4px;
        transition: color 0.2s ease, border-color 0.2s ease;
    }
    .lang-switch:hover { color: var(--color-text); border-color: var(--color-text-muted); }
    main { max-width: 960px; margin: 0 auto; padding: 32px 20px; }
    .site-footer {
        text-align: center;
        padding: 48px 20px;
        margin-top: 48px;
        color: var(--color-text-muted);
        font-size: 13px;
        border-top: 1px solid var(--color-border);
    }
    .site-footer a { color: var(--color-text-muted); }
</style>
