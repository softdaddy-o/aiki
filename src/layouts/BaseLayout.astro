    .nav-links a[data-section="projects"].active { color: var(--color-aiki-blue); }
    .nav-links a::after {
        content: '';
        position: absolute;
        bottom: 3px;
        left: 14px;
        right: 14px;
        height: 2px;
        background: var(--color-aiki-blue);
        transform: scaleX(0);
        transition: transform 0.2s ease;
