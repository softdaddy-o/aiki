---
import { t, getLocaleFromUrl } from '../i18n/utils';
import Search from '../components/Search.astro';

interface Props {
    title?: string;
    description?: string;
    ogImage?: string;
    ogType?: 'website' | 'article';
    ogImageAlt?: string;
}

const lang = getLocaleFromUrl(Astro.url);
const { title, description, ogImage, ogType = 'website', ogImageAlt } = Astro.props;
const siteTitle = title ? `${title} | ${t(lang, 'site.title')}` : t(lang, 'site.title');
const siteDesc = description ?? t(lang, 'site.description');
const siteUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.href;
const resolvedOgImage = ogImage ?? '/og/site-default.png';
const ogImageUrl = new URL(resolvedOgImage, Astro.site ?? Astro.url).href;
const ogImageExt = resolvedOgImage.split('.').pop()?.toLowerCase();
const ogImageMimeType = ogImageExt === 'png'
    ? 'image/png'
    : ogImageExt === 'webp'
        ? 'image/webp'
        : 'image/jpeg';
const socialImageAlt = ogImageAlt ?? title ?? t(lang, 'site.title');
const otherLang = lang === 'ko' ? 'en' : 'ko';
const otherPath = lang === 'ko' ? '/en/' : '/ko/';
const searchPlaceholder = lang === 'ko' ? '검색...' : 'Search...';
const searchAriaLabel = lang === 'ko' ? '전체 검색' : 'Global search';
const threadsIcon = `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017c.03-3.579.879-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717C4.307 6.504 3.616 8.914 3.589 12c.027 3.086.718 5.496 2.057 7.164 1.43 1.783 3.631 2.698 6.54 2.717 2.623-.02 4.358-.631 5.8-2.045 1.647-1.613 1.618-3.593 1.09-4.798-.31-.71-.873-1.3-1.634-1.75-.192 1.352-.622 2.446-1.284 3.272-.886 1.102-2.14 1.704-3.73 1.79-1.202.065-2.361-.218-3.259-.801-1.063-.689-1.685-1.74-1.752-2.964-.065-1.19.408-2.285 1.33-3.082.88-.76 2.119-1.207 3.583-1.291a13.853 13.853 0 0 1 3.02.142c-.126-.742-.375-1.332-.75-1.757-.513-.586-1.308-.883-2.359-.89h-.029c-.844 0-1.992.232-2.721 1.32L7.734 7.847c.98-1.454 2.568-2.256 4.478-2.256h.044c3.194.02 5.097 1.975 5.287 5.388.108.046.216.094.321.142 1.49.7 2.58 1.761 3.154 3.07.797 1.82.871 4.79-1.548 7.158-1.85 1.81-4.094 2.628-7.277 2.65Zm1.003-11.69c-.242 0-.487.007-.739.021-1.836.103-2.98.946-2.916 2.143.067 1.256 1.452 1.839 2.784 1.767 1.224-.065 2.818-.543 3.086-3.71a10.5 10.5 0 0 0-2.215-.221z"/></svg>`;

const navItems = lang === 'en'
    ? [
        { key: 'nav.home', href: '/en/' },
        { key: 'nav.news', href: '/en/' },
        { key: 'nav.wiki', href: '/en/' },
    ]
    : [
        { key: 'nav.home', href: '/ko/' },
        { key: 'nav.projects', href: '/ko/projects/' },
        { key: 'nav.news', href: '/ko/news/' },
        { key: 'nav.wiki', href: '/ko/wiki/' },
        // { key: 'nav.models', href: `/${lang}/models/` },
        // { key: 'nav.tutorials', href: `/${lang}/tutorials/` },
        // { key: 'nav.about', href: `/${lang}/about/` },
    ];
---
<!DOCTYPE html>
<html lang={lang}>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{siteTitle}</title>
    <meta name="description" content={siteDesc} />
    <link rel="canonical" href={siteUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDesc} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content="AIKI" />
    <meta property="og:locale" content={lang === 'ko' ? 'ko_KR' : 'en_US'} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:type" content={ogImageMimeType} />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={siteDesc} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={socialImageAlt} />
    <link rel="icon" type="image/jpeg" href="/softdaddy-logo.jpg" />
    <link rel="apple-touch-icon" href="/softdaddy-logo.jpg" />
    <link rel="alternate" hreflang={otherLang} href={otherPath} />
    <script is:inline>
        (function() {
            function getCookie(name) {
                var v = document.cookie.match('(^|;)\\s*' + name + '\\s*=\\s*([^;]+)');
                return v ? v.pop() : '';
            }
            if (getCookie('theme') !== 'light') {
                document.documentElement.classList.add('dark');
            }
        })();
    </script>
    <link rel="stylesheet" as="style" crossorigin
        href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet" />
    <script defer src="https://cloud.umami.is/script.js" data-website-id="1e50ef50-5315-4044-b642-804a3fb40355"></script>
</head>
<body data-pagefind-body>
    <nav class="site-nav">
        <a href={`/${lang}/`} class="site-logo" aria-label="Soft Daddy home">
            <img src="/softdaddy-logo.jpg" alt="Soft Daddy" />
        </a>
        <button class="nav-toggle" aria-label="Toggle navigation">
            <span></span><span></span><span></span>
        </button>
        <div class="nav-links">
            {navItems.map(item => (
                <a href={item.href}>{t(lang, item.key)}</a>
            ))}
        </div>
        <Search placeholder={searchPlaceholder} ariaLabel={searchAriaLabel} />
        <span class="nav-divider" aria-hidden="true"></span>
        <a
            href="https://www.threads.net/@softdaddy_o"
            target="_blank"
            rel="noopener noreferrer"
            class="nav-social"
            aria-label="Threads @softdaddy_o"
            title="@softdaddy_o"
        >
            <span class="nav-social-icon" aria-hidden="true">
                <Fragment set:html={threadsIcon} />
            </span>
            <span class="nav-social-label">softdaddy_o</span>
        </a>
        <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
            <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        <a href={otherPath} class="lang-switch">{otherLang.toUpperCase()}</a>
    </nav>
    <main>
        <slot />
    </main>
    <footer class="site-footer">
        <p>AIKI — AI-curated, human-verified.</p>
    </footer>
    <nav class="bottom-nav" aria-label="Mobile navigation">
        <a href={`/${lang}/`} class="bottom-tab" data-path={`/${lang}/`}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <span>홈</span>
        </a>
        <a href={`/${lang}/projects/`} class="bottom-tab" data-path={`/${lang}/projects/`}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
            <span>{t(lang, 'nav.projects')}</span>
        </a>
        <a href={`/${lang}/news/`} class="bottom-tab" data-path={`/${lang}/news/`}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 22h16a2 2 0 002-2V4a2 2 0 00-2-2H8a2 2 0 00-2 2v16a2 2 0 01-2 2zm0 0a2 2 0 01-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8m8-4h-8m5 8h-5"/></svg>
            <span>뉴스</span>
        </a>
        <a href={`/${lang}/wiki/`} class="bottom-tab" data-path={`/${lang}/wiki/`}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
            <span>위키</span>
        </a>
        <button class="bottom-tab" id="mobile-search-toggle" aria-label="검색">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <span>검색</span>
        </button>
    </nav>
    <script is:inline>
        document.querySelector('.nav-toggle')?.addEventListener('click', () => {
            document.querySelector('.nav-links')?.classList.toggle('open');
        });
        // Highlight active bottom tab
        const path = window.location.pathname;
        document.querySelectorAll('.bottom-tab').forEach(tab => {
            const tabPath = tab.getAttribute('data-path');
            if (tabPath && (path === tabPath || (tabPath !== `/${document.documentElement.lang}/` && path.startsWith(tabPath)))) {
                tab.classList.add('active');
            }
        });
        // Mobile search toggle — focus the pagefind input
        document.getElementById('mobile-search-toggle')?.addEventListener('click', function() {
            var searchInput = document.querySelector('.pagefind-ui__search-input');
            if (searchInput) {
                searchInput.focus();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        });
        // Theme toggle
        (function() {
            function getCookie(name) {
                var v = document.cookie.match('(^|;)\\s*' + name + '\\s*=\\s*([^;]+)');
                return v ? v.pop() : '';
            }
            function setCookie(name, value, days) {
                var d = new Date();
                d.setTime(d.getTime() + days * 24 * 60 * 60 * 1000);
                document.cookie = name + '=' + value + ';expires=' + d.toUTCString() + ';path=/;SameSite=Lax';
            }
            var btn = document.getElementById('theme-toggle');
            if (btn) {
                btn.addEventListener('click', function() {
                    var isDark = document.documentElement.classList.toggle('dark');
                    setCookie('theme', isDark ? 'dark' : 'light', 365);
                });
            }
        })();
    </script>
</body>
</html>

<style is:global>
    /* Light theme (default) — warm off-white, inspired by opencode.ai */
    :root {
        --color-bg: #f5f2ef;
        --color-surface: #fdfcfc;
        --color-surface-alt: #ede9e4;
        --color-surface-elevated: #ffffff;
        --color-text: #201d1d;
        --color-text-muted: #6e6466;
        --color-news: #0969da;
        --color-wiki: #8250df;
        --color-model: #9a6700;
        --color-tutorial: #1a7f37;
        --color-skill: #cf222e;
        --color-projects: #e36414;
        --color-dot: #cf222e;
        --color-pass: #1a7f37;
        --color-fail: #cf222e;
        --text-xs: 0.75rem;
        --text-sm: 0.8125rem;
        --text-base: 1rem;
        --text-lg: 1.0625rem;
        --text-xl: 1.25rem;
        --text-2xl: 1.5rem;
        --text-3xl: 2rem;
        --text-4xl: 2.5rem;
        --color-border: rgba(15, 0, 0, 0.10);
        --color-border-strong: rgba(15, 0, 0, 0.20);
        --font-heading: 'Space Grotesk', 'Pretendard Variable', sans-serif;
        --font-body: 'Pretendard Variable', Pretendard, -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        --font-mono: 'Cascadia Mono', 'Cascadia Code', ui-monospace, 'SFMono-Regular', 'IBM Plex Mono', 'Segoe UI Mono', Menlo, Monaco, Consolas, 'Liberation Mono', monospace;
    }
    /* Dark theme */
    html.dark {
        --color-bg: #0a0a1a;
        --color-surface: #14142a;
        --color-surface-alt: #1e1e2e;
        --color-surface-elevated: #2a2a3e;
        --color-text: #e0e0e0;
        --color-text-muted: #888;
        --color-news: #4fc3f7;
        --color-wiki: #ce93d8;
        --color-model: #fff176;
        --color-tutorial: #81c784;
        --color-skill: #f48fb1;
        --color-projects: #ffb347;
        --color-dot: #ef5350;
        --color-pass: #81c784;
        --color-fail: #ef5350;
        --color-border: rgba(255, 255, 255, 0.08);
        --color-border-strong: rgba(255, 255, 255, 0.15);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    html.dark { color-scheme: dark; }
    ::selection { background: rgba(9, 105, 218, 0.2); color: var(--color-text); }
    html.dark ::selection { background: rgba(79, 195, 247, 0.3); color: #fff; }
    :focus-visible { outline: 2px solid var(--color-news); outline-offset: 2px; }
    body {
        font-family: var(--font-body);
        font-size: var(--text-base);
        background: var(--color-bg);
        background-image: radial-gradient(ellipse at 50% 0%, rgba(9, 105, 218, 0.04) 0%, transparent 60%);
        color: var(--color-text);
        line-height: 1.6;
        transition: background 0.2s ease, color 0.2s ease;
    }
    html.dark body {
        background-image: radial-gradient(ellipse at 50% 0%, rgba(79, 195, 247, 0.05) 0%, transparent 60%);
    }
    h1, h2, h3 { font-family: var(--font-heading); text-wrap: balance; }
    code,
    pre,
    kbd,
    samp {
        font-family: var(--font-mono);
        font-variant-ligatures: none;
    }
    code,
    kbd,
    samp {
        font-size: 0.95em;
    }
    .site-nav {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 16px 24px;
        border-bottom: 1px solid var(--color-border);
        backdrop-filter: blur(12px);
        background: rgba(245, 242, 239, 0.90);
        position: sticky;
        top: 0;
        z-index: 100;
        transition: background 0.2s ease, border-color 0.2s ease;
    }
    html.dark .site-nav {
        background: rgba(10, 10, 26, 0.85);
    }
    .site-logo {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-family: var(--font-heading);
        font-size: 22px;
        font-weight: 700;
        color: var(--color-news);
        text-decoration: none;
        text-shadow: 0 0 20px rgba(9, 105, 218, 0.2);
    }
    .site-logo img {
        width: 32px;
        height: 32px;
        border-radius: 9px;
        object-fit: cover;
        box-shadow: 0 6px 18px rgba(0, 0, 0, 0.16);
        border: 1px solid rgba(9, 105, 218, 0.22);
    }
    :global(.sr-only) {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }
    html.dark .site-logo {
        text-shadow: 0 0 20px rgba(79, 195, 247, 0.3);
    }
    .nav-links { display: flex; gap: 16px; flex: 1; }
    .nav-links a {
        color: var(--color-text-muted);
        text-decoration: none;
        font-size: 14px;
        padding: 10px 4px;
        transition: color 0.2s ease;
        position: relative;
    }
    .nav-links a:hover { color: var(--color-text); }
    .nav-links a::after {
        content: '';
        position: absolute;
        bottom: -4px;
        left: 0;
        right: 0;
        height: 2px;
        background: var(--color-news);
        transform: scaleX(0);
        transition: transform 0.2s ease;
    }
    .nav-links a:hover::after { transform: scaleX(1); }
    .nav-toggle {
        display: none;
        flex-direction: column;
        gap: 4px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 4px;
    }
    .nav-toggle span {
        display: block;
        width: 20px;
        height: 2px;
        background: var(--color-text);
        transition: transform 0.2s ease;
    }
    @media (max-width: 768px) {
        .nav-toggle { display: flex; }
        .nav-links {
            display: none;
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            flex-direction: column;
            background: var(--color-surface);
            padding: 16px 24px;
            border-bottom: 1px solid var(--color-border);
            gap: 12px;
        }
        .nav-links.open { display: flex; }
        .nav-links a { font-size: 16px; padding: 12px 0; }
        .site-nav { flex-wrap: wrap; position: relative; }
    }
    @media (max-width: 640px) {
        main { padding: 20px 12px; }
    }
    .theme-toggle {
        background: none;
        border: 1px solid var(--color-border-strong);
        border-radius: 4px;
        color: var(--color-text-muted);
        cursor: pointer;
        padding: 5px 8px;
        display: flex;
        align-items: center;
        transition: color 0.2s ease, border-color 0.2s ease;
        flex-shrink: 0;
    }
    .theme-toggle:hover { color: var(--color-text); border-color: var(--color-text-muted); }
    /* Show sun in dark mode, moon in light mode */
    .icon-moon { display: block; }
    .icon-sun { display: none; }
    html.dark .icon-moon { display: none; }
    html.dark .icon-sun { display: block; }
    .lang-switch {
        color: var(--color-text-muted);
        text-decoration: none;
        font-size: 12px;
        padding: 4px 10px;
        border: 1px solid var(--color-border-strong);
        border-radius: 4px;
        transition: color 0.2s ease, border-color 0.2s ease;
    }
    .lang-switch:hover { color: var(--color-text); border-color: var(--color-text-muted); }
    .nav-divider {
        width: 1px;
        height: 20px;
        background: var(--color-border-strong);
        flex-shrink: 0;
    }
    .nav-social {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        height: 32px;
        padding: 0 10px;
        border-radius: 9999px;
        color: var(--color-text-muted);
        text-decoration: none;
        flex-shrink: 0;
        white-space: nowrap;
        transition: color 0.15s ease, background 0.15s ease;
    }
    .nav-social:hover {
        color: var(--color-text);
        background: color-mix(in srgb, var(--color-text) 6%, transparent);
    }
    .nav-social-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 14px;
        height: 14px;
        flex-shrink: 0;
    }
    .nav-social :global(svg) {
        width: 13px;
        height: 13px;
        flex-shrink: 0;
    }
    .nav-social-label {
        font-size: 12.5px;
        font-weight: 700;
        line-height: 1;
        transform: translateY(-0.5px);
    }
    main { max-width: 960px; margin: 0 auto; padding: 32px 20px; }
    main:has(.project-page--showcase-native) { max-width: none; padding-left: 0; padding-right: 0; }
    :global(.prose) {
        max-width: 70ch;
        margin-inline: auto;
    }
    :global(.prose) a[data-link-kind] {
        font-weight: 600;
        text-decoration-line: underline;
        text-decoration-thickness: 1.5px;
        text-underline-offset: 0.16em;
        text-decoration-skip-ink: auto;
        transition:
            color 0.15s ease,
            background-color 0.15s ease,
            text-decoration-color 0.15s ease,
            text-decoration-thickness 0.15s ease;
    }
    :global(.prose) a[data-link-kind="internal"] {
        color: color-mix(in srgb, var(--color-wiki) 82%, var(--color-text) 18%);
        text-decoration-style: solid;
        text-decoration-color: color-mix(in srgb, var(--color-wiki) 58%, transparent);
    }
    :global(.prose) a[data-link-kind="external"] {
        color: color-mix(in srgb, var(--color-news) 82%, var(--color-text) 18%);
        text-decoration-style: dashed;
        text-decoration-color: color-mix(in srgb, var(--color-news) 62%, transparent);
        background: color-mix(in srgb, var(--color-news) 8%, transparent);
        border-radius: 4px;
        padding-inline: 0.08em;
    }
    :global(.prose) a[data-link-kind="external"]::after {
        content: '↗';
        display: inline-block;
        font-size: 0.78em;
        font-weight: 700;
        line-height: 1;
        vertical-align: text-top;
        color: color-mix(in srgb, var(--color-text-muted) 72%, var(--color-news) 28%);
    }
    :global(.prose) a[data-link-kind]:hover {
        text-decoration-thickness: 2px;
    }
    :global(.prose) a[data-link-kind="internal"]:hover {
        color: var(--color-wiki);
    }
    :global(.prose) a[data-link-kind="external"]:hover {
