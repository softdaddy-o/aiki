        flex-direction: column;
        align-items: center;
        gap: 10px;
    }
    .site-footer a { color: var(--color-text-muted); }
    /* Bottom tab bar — mobile only */
    .bottom-nav { display: none; }
    @media (max-width: 900px) {
        .bottom-nav {
            display: flex;
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            z-index: 100;
            background: color-mix(in srgb, var(--color-surface-elevated) 84%, transparent);
            backdrop-filter: blur(22px) saturate(145%);
            border-top: 1px solid var(--color-border);
            padding: 6px 0 calc(6px + env(safe-area-inset-bottom, 0px));
            justify-content: space-around;
            transition: background 0.2s ease;
        }
        .bottom-tab {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 2px;
            min-height: 48px;
            padding: 6px 12px;
            color: var(--color-text-muted);
            text-decoration: none;
            font-size: 10px;
            font-weight: 600;
            background: none;
            border: none;
            cursor: pointer;
            transition: color 0.15s ease;
            min-width: 64px;
        }
        .bottom-tab[data-section="home"].active { color: var(--color-text); }
        .bottom-tab[data-section="news"].active { color: var(--color-news); }
        .bottom-tab[data-section="wiki"].active { color: var(--color-wiki); }
        .bottom-tab[data-section="projects"].active { color: var(--color-projects); }
        .bottom-tab:active { color: var(--color-text); }
        html.dark .bottom-nav { background: color-mix(in srgb, var(--color-bg) 92%, transparent); }
        /* Hide hamburger and top nav links on mobile — bottom nav replaces them */
        .nav-toggle { display: none !important; }
        .nav-links { display: none !important; }
        .lang-switch { display: none; }
        .nav-divider { display: none; }
        .site-nav {
            grid-template-columns: auto minmax(0, 1fr) auto auto;
            justify-content: space-between;
            margin-top: 10px;
        }
        @media (max-width: 520px) {
            .site-nav {
                grid-template-columns: auto minmax(0, 1fr);
                border-radius: 28px;
            }
            .site-logo {
                grid-column: 1;
                grid-row: 1;
            }
            .nav-social {
