---
import { t, getLocaleFromUrl } from '../i18n/utils';
import Search from '../components/Search.astro';

interface Props {
    title?: string;
    description?: string;
}

const lang = getLocaleFromUrl(Astro.url);
const { title, description } = Astro.props;
const siteTitle = title ? `${title} | ${t(lang, 'site.title')}` : t(lang, 'site.title');
const siteDesc = description ?? t(lang, 'site.description');
const otherLang = lang === 'ko' ? 'en' : 'ko';
const otherPath = Astro.url.pathname.replace(`/${lang}/`, `/${otherLang}/`);

const navItems = [
    { key: 'nav.home', href: `/${lang}/` },
    { key: 'nav.news', href: `/${lang}/news/` },
    { key: 'nav.wiki', href: `/${lang}/wiki/` },
    { key: 'nav.models', href: `/${lang}/models/` },
    { key: 'nav.tutorials', href: `/${lang}/tutorials/` },
    { key: 'nav.about', href: `/${lang}/about/` },
];
---
<!DOCTYPE html>
<html lang={lang}>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{siteTitle}</title>
    <meta name="description" content={siteDesc} />
    <link rel="alternate" hreflang={otherLang} href={otherPath} />
</head>
<body data-pagefind-body>
    <nav class="site-nav">
        <a href={`/${lang}/`} class="site-logo">AIKI</a>
        <div class="nav-links">
            {navItems.map(item => (
                <a href={item.href}>{t(lang, item.key)}</a>
            ))}
        </div>
        <Search />
        <a href={otherPath} class="lang-switch">{otherLang.toUpperCase()}</a>
    </nav>
    <main>
        <slot />
    </main>
    <footer class="site-footer">
        <p>AIKI — AI-curated, human-verified. <a href={`/${lang}/about/`}>{t(lang, 'nav.about')}</a></p>
    </footer>
</body>
</html>

<style is:global>
    :root {
        --color-bg: #0a0a1a;
        --color-surface: #1e1e2e;
        --color-surface-alt: #2a2a3e;
        --color-text: #e0e0e0;
        --color-text-muted: #888;
        --color-news: #4fc3f7;
        --color-wiki: #ce93d8;
        --color-model: #fff176;
        --color-tutorial: #81c784;
        --color-skill: #f48fb1;
        --color-dot: #ef5350;
        --color-pass: #81c784;
        --color-fail: #ef5350;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: var(--color-bg);
        color: var(--color-text);
        line-height: 1.6;
    }
    .site-nav {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 16px 24px;
        border-bottom: 1px solid #222;
    }
    .site-logo {
        font-size: 20px;
        font-weight: 800;
        color: var(--color-news);
        text-decoration: none;
        letter-spacing: 2px;
    }
    .nav-links { display: flex; gap: 16px; flex: 1; }
    .nav-links a { color: var(--color-text-muted); text-decoration: none; font-size: 14px; }
    .nav-links a:hover { color: var(--color-text); }
    .lang-switch {
        color: var(--color-text-muted);
        text-decoration: none;
        font-size: 12px;
        padding: 4px 8px;
        border: 1px solid #444;
        border-radius: 4px;
    }
    main { max-width: 960px; margin: 0 auto; padding: 24px 16px; }
    .site-footer {
        text-align: center;
        padding: 32px 16px;
        color: var(--color-text-muted);
        font-size: 13px;
        border-top: 1px solid #222;
    }
    .site-footer a { color: var(--color-text-muted); }
</style>
