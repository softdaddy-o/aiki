    .nav-links a[data-section="home"]::after { background: var(--color-aiki-blue); }
    .nav-links a[data-section="news"]::after,
    .nav-links a[data-section="wiki"]::after,
    .nav-links a[data-section="projects"]::after { background: var(--color-aiki-blue); }
    .nav-links a.active::after,
    .nav-links a:hover::after { transform: scaleX(1); }
    .nav-toggle {
        display: none;
        flex-direction: column;
        gap: 4px;
        background: none;
        border: none;
        cursor: pointer;
        min-width: 44px;
        min-height: 44px;
        padding: 10px;
