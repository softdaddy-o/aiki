---
import { t, getLocaleFromUrl } from '../i18n/utils';
import Search from '../components/Search.astro';

interface Props {
    title?: string;
    description?: string;
    ogImage?: string;
    ogType?: 'website' | 'article';
    ogImageAlt?: string;
}

const lang = getLocaleFromUrl(Astro.url);
const { title, description, ogImage, ogType = 'website', ogImageAlt } = Astro.props;
const siteTitle = title ? `${title} | ${t(lang, 'site.title')}` : t(lang, 'site.title');
const siteDesc = description ?? t(lang, 'site.description');
const siteUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.href;
const resolvedOgImage = ogImage ?? '/og/site-default.png';
const ogImageUrl = new URL(resolvedOgImage, Astro.site ?? Astro.url).href;
const ogImageExt = resolvedOgImage.split('.').pop()?.toLowerCase();
const ogImageMimeType = ogImageExt === 'png'
    ? 'image/png'
    : ogImageExt === 'webp'
        ? 'image/webp'
        : 'image/jpeg';
const socialImageAlt = ogImageAlt ?? title ?? t(lang, 'site.title');
const otherLang = lang === 'ko' ? 'en' : 'ko';
const otherPath = lang === 'ko' ? '/en/' : '/ko/';
const searchPlaceholder = lang === 'ko' ? '검색...' : 'Search...';
const searchAriaLabel = lang === 'ko' ? '전체 검색' : 'Global search';
const threadsIcon = `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017c.03-3.579.879-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717C4.307 6.504 3.616 8.914 3.589 12c.027 3.086.718 5.496 2.057 7.164 1.43 1.783 3.631 2.698 6.54 2.717 2.623-.02 4.358-.631 5.8-2.045 1.647-1.613 1.618-3.593 1.09-4.798-.31-.71-.873-1.3-1.634-1.75-.192 1.352-.622 2.446-1.284 3.272-.886 1.102-2.14 1.704-3.73 1.79-1.202.065-2.361-.218-3.259-.801-1.063-.689-1.685-1.74-1.752-2.964-.065-1.19.408-2.285 1.33-3.082.88-.76 2.119-1.207 3.583-1.291a13.853 13.853 0 0 1 3.02.142c-.126-.742-.375-1.332-.75-1.757-.513-.586-1.308-.883-2.359-.89h-.029c-.844 0-1.992.232-2.721 1.32L7.734 7.847c.98-1.454 2.568-2.256 4.478-2.256h.044c3.194.02 5.097 1.975 5.287 5.388.108.046.216.094.321.142 1.49.7 2.58 1.761 3.154 3.07.797 1.82.871 4.79-1.548 7.158-1.85 1.81-4.094 2.628-7.277 2.65Zm1.003-11.69c-.242 0-.487.007-.739.021-1.836.103-2.98.946-2.916 2.143.067 1.256 1.452 1.839 2.784 1.767 1.224-.065 2.818-.543 3.086-3.71a10.5 10.5 0 0 0-2.215-.221z"/></svg>`;

type TopNavItem = {
    key: string;
    href: string;
    section: 'home' | 'news' | 'wiki' | 'projects';
    activePrefix?: string;
};

const resolvedSearchPlaceholder = lang === 'ko' ? '검색...' : 'Search...';
const resolvedSearchAriaLabel = lang === 'ko' ? '전체 검색' : 'Global search';
const searchButtonLabel = lang === 'ko' ? '검색' : 'Search';
const currentPath = Astro.url.pathname;
const homePath = `/${lang}/`;
const orderedNavItems: TopNavItem[] = lang === 'ko'
    ? [
        { key: 'nav.home', href: '/ko/', section: 'home', activePrefix: '/ko/' },
        { key: 'nav.news', href: '/ko/news/', section: 'news', activePrefix: '/ko/news/' },
        { key: 'nav.wiki', href: '/ko/wiki/', section: 'wiki', activePrefix: '/ko/wiki/' },
        { key: 'nav.projects', href: '/ko/projects/', section: 'projects', activePrefix: '/ko/projects/' },
    ]
    : [
        { key: 'nav.home', href: '/en/', section: 'home', activePrefix: '/en/' },
        { key: 'nav.news', href: '/en/', section: 'news' },
        { key: 'nav.wiki', href: '/en/', section: 'wiki' },
    ];

function isTopNavActive(item: TopNavItem): boolean {
    if (!item.activePrefix) return false;
    if (item.activePrefix === homePath) return currentPath === homePath;
    return currentPath === item.activePrefix || currentPath.startsWith(item.activePrefix);
}

const navItems = lang === 'en'
    ? [
        { key: 'nav.home', href: '/en/' },
        { key: 'nav.news', href: '/en/' },
        { key: 'nav.wiki', href: '/en/' },
    ]
    : [
        { key: 'nav.home', href: '/ko/' },
        { key: 'nav.projects', href: '/ko/projects/' },
        { key: 'nav.news', href: '/ko/news/' },
        { key: 'nav.wiki', href: '/ko/wiki/' },
        // { key: 'nav.models', href: `/${lang}/models/` },
        // { key: 'nav.tutorials', href: `/${lang}/tutorials/` },
        // { key: 'nav.about', href: `/${lang}/about/` },
    ];
---
<!DOCTYPE html>
<html lang={lang}>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{siteTitle}</title>
    <meta name="description" content={siteDesc} />
    <link rel="canonical" href={siteUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDesc} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content="AIKI" />
    <meta property="og:locale" content={lang === 'ko' ? 'ko_KR' : 'en_US'} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:type" content={ogImageMimeType} />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={siteDesc} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={socialImageAlt} />
    <link rel="icon" type="image/jpeg" href="/softdaddy-logo.jpg" />
    <link rel="apple-touch-icon" href="/softdaddy-logo.jpg" />
    <link rel="alternate" hreflang={otherLang} href={otherPath} />
    <script is:inline>
        (function() {
            function getCookie(name) {
                var v = document.cookie.match('(^|;)\\s*' + name + '\\s*=\\s*([^;]+)');
                return v ? v.pop() : '';
            }
            if (getCookie('theme') === 'dark') {
                document.documentElement.classList.add('dark');
            }
        })();
    </script>
    <link rel="stylesheet" as="style" crossorigin
        href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Hahmlet:wght@500;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <script defer src="https://cloud.umami.is/script.js" data-website-id="1e50ef50-5315-4044-b642-804a3fb40355"></script>
</head>
<body data-pagefind-body>
    <nav class="site-nav">
        <a href={`/${lang}/`} class="site-logo" aria-label="Soft Daddy home">
            <img src="/softdaddy-logo.jpg" alt="Soft Daddy" />
            <span class="site-logo-word">AIKI</span>
        </a>
        <button class="nav-toggle" aria-label="Toggle navigation">
            <span></span><span></span><span></span>
        </button>
        <div class="nav-links">
            {orderedNavItems.map((item) => {
                const active = isTopNavActive(item);

                return (
                    <a
                        href={item.href}
                        class:list={{ active }}
                        aria-current={active ? 'page' : undefined}
                        data-section={item.section}
                    >
                        {t(lang, item.key)}
                    </a>
                );
            })}
        </div>
        <Search placeholder={resolvedSearchPlaceholder} ariaLabel={resolvedSearchAriaLabel} />
        <span class="nav-divider" aria-hidden="true"></span>
        <a
            href="https://www.threads.net/@softdaddy_o"
            target="_blank"
            rel="noopener noreferrer"
            class="nav-social"
            aria-label="Threads @softdaddy_o"
            title="@softdaddy_o"
        >
            <span class="nav-social-icon" aria-hidden="true">
                <Fragment set:html={threadsIcon} />
            </span>
            <span class="nav-social-label">softdaddy_o</span>
        </a>
        <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
            <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        <a href={otherPath} class="lang-switch">{otherLang.toUpperCase()}</a>
    </nav>
    <main>
        <slot />
    </main>
    <footer class="site-footer">
        <p>AIKI — AI-curated, human-verified.</p>
    </footer>
    <!--
    <nav class="bottom-nav" aria-label="Mobile navigation">
        <a href={`/${lang}/`} class="bottom-tab" data-path={`/${lang}/`}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <span>홈</span>
        </a>
        <a href={`/${lang}/projects/`} class="bottom-tab" data-path={`/${lang}/projects/`}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
            <span>{t(lang, 'nav.projects')}</span>
        </a>
        <a href={`/${lang}/news/`} class="bottom-tab" data-path={`/${lang}/news/`}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 22h16a2 2 0 002-2V4a2 2 0 00-2-2H8a2 2 0 00-2 2v16a2 2 0 01-2 2zm0 0a2 2 0 01-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8m8-4h-8m5 8h-5"/></svg>
            <span>뉴스</span>
        </a>
        <a href={`/${lang}/wiki/`} class="bottom-tab" data-path={`/${lang}/wiki/`}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
            <span>위키</span>
        </a>
        <button class="bottom-tab" id="mobile-search-toggle" aria-label="검색">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <span>검색</span>
        </button>
    </nav>
    -->
    <nav class="bottom-nav" aria-label="Mobile navigation">
        <a href={`/${lang}/`} class="bottom-tab" data-path={`/${lang}/`} data-section="home">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <span>{t(lang, 'nav.home')}</span>
        </a>
        <a href={`/${lang}/news/`} class="bottom-tab" data-path={`/${lang}/news/`} data-section="news">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8m8-4h-8m5 8h-5"/></svg>
            <span>{t(lang, 'nav.news')}</span>
        </a>
        <a href={`/${lang}/wiki/`} class="bottom-tab" data-path={`/${lang}/wiki/`} data-section="wiki">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
            <span>{t(lang, 'nav.wiki')}</span>
        </a>
        <a href={`/${lang}/projects/`} class="bottom-tab" data-path={`/${lang}/projects/`} data-section="projects">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
            <span>{t(lang, 'nav.projects')}</span>
        </a>
        <button class="bottom-tab" id="mobile-search-toggle" aria-label={searchButtonLabel}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <span>{searchButtonLabel}</span>
        </button>
    </nav>
    <script is:inline>
        document.querySelector('.nav-toggle')?.addEventListener('click', () => {
            document.querySelector('.nav-links')?.classList.toggle('open');
        });
        // Highlight active bottom tab
        const path = window.location.pathname;
        document.querySelectorAll('.bottom-tab').forEach(tab => {
            const tabPath = tab.getAttribute('data-path');
            if (tabPath && (path === tabPath || (tabPath !== `/${document.documentElement.lang}/` && path.startsWith(tabPath)))) {
                tab.classList.add('active');
            }
        });
        // Mobile search toggle — focus the pagefind input
        document.getElementById('mobile-search-toggle')?.addEventListener('click', function() {
            var searchInput = document.querySelector('.pagefind-ui__search-input');
            if (searchInput) {
                searchInput.focus();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        });
        // Theme toggle
        (function() {
            function getCookie(name) {
                var v = document.cookie.match('(^|;)\\s*' + name + '\\s*=\\s*([^;]+)');
                return v ? v.pop() : '';
            }
            function setCookie(name, value, days) {
                var d = new Date();
                d.setTime(d.getTime() + days * 24 * 60 * 60 * 1000);
                document.cookie = name + '=' + value + ';expires=' + d.toUTCString() + ';path=/;SameSite=Lax';
            }
            var btn = document.getElementById('theme-toggle');
            if (btn) {
                btn.addEventListener('click', function() {
                    var isDark = document.documentElement.classList.toggle('dark');
                    setCookie('theme', isDark ? 'dark' : 'light', 365);
                });
            }
        })();
    </script>
</body>
</html>

<style is:global>
    /* Light theme (default) — soft spatial intelligence */
    :root {
        --color-bg: #f7f8fb;
        --color-surface: rgba(255, 255, 255, 0.68);
        --color-surface-alt: rgba(239, 246, 255, 0.62);
        --color-surface-elevated: rgba(255, 255, 255, 0.82);
        --color-text: #0a1426;
        --color-text-muted: #647084;
        --color-aiki-blue: #6d9dff;
        --color-aiki-cyan: #82e4dc;
        --color-aiki-violet: #b9a7ff;
        --color-aiki-cream: #fff8ed;
        --color-aiki-coral: #ff8c7a;
        --color-aiki-olive: #9bd5bd;
        --color-news: #6d9dff;
        --color-wiki: #7bd8cf;
        --color-model: #b9a7ff;
        --color-tutorial: #9bd5bd;
        --color-skill: #ff8c7a;
        --color-projects: #8fbcff;
        --color-dot: #6d9dff;
        --color-pass: #44bfa8;
        --color-fail: #df6258;
        --text-xs: 0.75rem;
        --text-sm: 0.8125rem;
        --text-base: 1rem;
        --text-lg: 1.0625rem;
        --text-xl: 1.25rem;
        --text-2xl: 1.5rem;
        --text-3xl: 2rem;
        --text-4xl: 2.5rem;
        --color-border: rgba(86, 103, 141, 0.16);
        --color-border-strong: rgba(86, 103, 141, 0.32);
        --shadow-card: 0 24px 70px rgba(39, 61, 93, 0.10), 0 1px 0 rgba(255, 255, 255, 0.82) inset;
        --shadow-card-hover: 0 32px 90px rgba(39, 61, 93, 0.16), 0 1px 0 rgba(255, 255, 255, 0.88) inset;
        --radius-xl: 28px;
        --radius-lg: 22px;
        --radius-md: 16px;
        --font-display: 'Outfit', 'Pretendard Variable', Pretendard, sans-serif;
        --font-heading: 'Outfit', 'Pretendard Variable', Pretendard, sans-serif;
        --font-body: 'Pretendard Variable', Pretendard, -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        --font-mono: 'Cascadia Mono', 'Cascadia Code', ui-monospace, 'SFMono-Regular', 'IBM Plex Mono', 'Segoe UI Mono', Menlo, Monaco, Consolas, 'Liberation Mono', monospace;
    }
    /* Dark theme */
    html.dark {
        --color-bg: #07111f;
        --color-surface: rgba(13, 26, 43, 0.72);
        --color-surface-alt: rgba(18, 39, 62, 0.72);
        --color-surface-elevated: rgba(16, 31, 51, 0.84);
        --color-text: #f4f8ff;
        --color-text-muted: #aab7c8;
        --color-aiki-blue: #8db5ff;
        --color-aiki-cyan: #7be4dd;
        --color-aiki-violet: #c5b8ff;
        --color-aiki-cream: #222b38;
        --color-aiki-coral: #ff9a86;
        --color-aiki-olive: #99dfc9;
        --color-news: #8db5ff;
        --color-wiki: #7be4dd;
        --color-model: #c5b8ff;
        --color-tutorial: #99dfc9;
        --color-skill: #ff9a86;
        --color-projects: #9dc2ff;
        --color-dot: #8db5ff;
        --color-pass: #79e2ca;
        --color-fail: #ff8378;
        --color-border: rgba(211, 226, 255, 0.14);
        --color-border-strong: rgba(211, 226, 255, 0.28);
        --shadow-card: 0 28px 90px rgba(0, 0, 0, 0.24), 0 1px 0 rgba(255, 255, 255, 0.08) inset;
        --shadow-card-hover: 0 34px 110px rgba(0, 0, 0, 0.32), 0 1px 0 rgba(255, 255, 255, 0.12) inset;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    html.dark { color-scheme: dark; }
    ::selection { background: rgba(9, 105, 218, 0.2); color: var(--color-text); }
    html.dark ::selection { background: rgba(79, 195, 247, 0.3); color: #fff; }
    :focus-visible { outline: 2px solid var(--color-news); outline-offset: 2px; }
    body {
        font-family: var(--font-body);
        font-size: var(--text-base);
        background:
            linear-gradient(120deg, rgba(207, 225, 255, 0.62) 0%, rgba(247, 248, 251, 0) 28%),
            linear-gradient(38deg, rgba(247, 248, 251, 0) 42%, rgba(188, 246, 234, 0.46) 62%, rgba(247, 248, 251, 0) 84%),
            linear-gradient(162deg, rgba(255, 196, 184, 0.24) 0%, rgba(247, 248, 251, 0) 28%),
            var(--color-bg);
        color: var(--color-text);
        line-height: 1.6;
        transition: background 0.2s ease, color 0.2s ease;
        min-height: 100vh;
    }
    body::before {
        content: '';
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: -1;
        background:
            linear-gradient(115deg, rgba(255, 255, 255, 0.72) 0%, rgba(255, 255, 255, 0) 36%),
            linear-gradient(70deg, rgba(129, 228, 220, 0.16), rgba(185, 167, 255, 0.12), rgba(255, 140, 122, 0.08));
        opacity: 0.86;
    }
    body::after {
        content: '';
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: -1;
        opacity: 0.18;
        background-image:
            linear-gradient(rgba(10, 20, 38, 0.04) 1px, transparent 1px),
            linear-gradient(90deg, rgba(10, 20, 38, 0.035) 1px, transparent 1px);
        background-size: 46px 46px;
        mask-image: linear-gradient(to bottom, black, transparent 78%);
    }
    html.dark body {
        background:
            radial-gradient(circle at 8% 0%, rgba(141, 181, 255, 0.20), transparent 30%),
            radial-gradient(circle at 82% 24%, rgba(123, 228, 221, 0.14), transparent 34%),
            linear-gradient(135deg, #050b14 0%, #091827 48%, #101824 100%);
    }
    html.dark body::before {
        background:
            linear-gradient(116deg, rgba(141, 181, 255, 0.16), rgba(255, 255, 255, 0) 38%),
            linear-gradient(68deg, rgba(123, 228, 221, 0.10), rgba(197, 184, 255, 0.10), rgba(255, 154, 134, 0.06));
        opacity: 0.74;
    }
    html.dark body::after {
        opacity: 0.12;
        background-image:
            linear-gradient(rgba(211, 226, 255, 0.06) 1px, transparent 1px),
            linear-gradient(90deg, rgba(211, 226, 255, 0.05) 1px, transparent 1px);
    }
    h1, h2, h3 { font-family: var(--font-heading); text-wrap: balance; letter-spacing: 0; }
    code,
    pre,
    kbd,
    samp {
        font-family: var(--font-mono);
        font-variant-ligatures: none;
    }
