---
import BaseLayout from '../../layouts/BaseLayout.astro';

const sections = [
    {
        title: '뉴스',
        desc: '업데이트를 빠르게 훑고, 과장된 문장을 줄인 요약으로 흐름을 먼저 잡습니다.',
        href: '/ko/news/',
    },
    {
        title: '위키',
        desc: '모델, 개념, 기법을 서로 연결해 처음 보는 용어도 맥락 안에서 따라가게 합니다.',
        href: '/ko/wiki/',
    },
    {
        title: '쇼케이스',
        desc: '직접 실행한 결과와 도입 판단에 필요한 근거를 한 화면에서 비교합니다.',
        href: '/ko/projects/',
    },
];
---

<BaseLayout
    title="AIKI 소개"
    description="AIKI는 AI 뉴스, 위키, 쇼케이스를 연결해 AI 지식을 흐름으로 읽게 하는 지식 지도입니다."
>
    <section class="about-page" aria-labelledby="about-title">
        <div class="about-hero">
            <p class="about-eyebrow">About AIKI</p>
            <h1 id="about-title">AI 지식을 흐름으로 읽는 곳</h1>
            <p>
                AIKI는 흩어진 AI 뉴스, 모델 정보, 개념, 오픈소스 프로젝트를 하나의 지식 지도처럼 엮습니다.
                빠르게 읽되, 무엇을 믿고 어디까지 판단할지 확인할 수 있게 만드는 것이 목표입니다.
            </p>
        </div>

        <div class="about-grid" aria-label="AIKI 구성">
            {sections.map((section) => (
                <a href={section.href} class="about-card">
                    <span>{section.title}</span>
                    <p>{section.desc}</p>
                </a>
            ))}
        </div>

        <div class="about-panel">
            <div>
                <h2>AIKI가 중요하게 보는 것</h2>
                <p>
                    새 소식을 많이 모으는 것보다, 읽는 사람이 바로 다음 판단을 할 수 있는 구조를 더 중요하게 봅니다.
                    그래서 요약, 근거, 연결 문서, 실행 결과를 같은 톤과 같은 정보 위계로 정리합니다.
                </p>
            </div>
            <div class="about-principles">
                <span>과장 줄이기</span>
                <span>근거 남기기</span>
                <span>맥락 연결하기</span>
                <span>도입 판단 돕기</span>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    .about-page {
        display: grid;
        gap: 18px;
        max-width: 1000px;
        margin: 0 auto;
    }

    .about-hero,
    .about-card,
    .about-panel {
        border: 1px solid var(--color-border);
        background: color-mix(in srgb, var(--color-surface-elevated) 78%, transparent);
        box-shadow: var(--shadow-card);
        backdrop-filter: blur(20px) saturate(140%);
    }

    .about-hero {
        min-height: 390px;
        display: grid;
        align-content: center;
        gap: 16px;
        padding: 54px;
        border-radius: var(--radius-xl);
        overflow: hidden;
        position: relative;
    }

    .about-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
            radial-gradient(circle at 82% 28%, rgba(123, 228, 221, 0.22), transparent 30%),
            linear-gradient(118deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0) 40%),
            linear-gradient(300deg, rgba(141, 181, 255, 0.18), rgba(197, 184, 255, 0.12));
        pointer-events: none;
    }

    .about-eyebrow,
    .about-hero h1,
    .about-hero p {
        position: relative;
        z-index: 1;
    }

    .about-eyebrow {
        margin: 0;
        color: var(--color-text-muted);
        font-family: var(--font-heading);
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
    }

    .about-hero h1 {
        max-width: 700px;
        margin: 0;
        color: var(--color-text);
        font-size: clamp(3rem, 8vw, 5.8rem);
        font-weight: 900;
        line-height: 0.98;
        letter-spacing: 0;
        overflow-wrap: anywhere;
    }

    .about-hero p,
    .about-panel p {
        max-width: 680px;
        margin: 0;
        color: var(--color-text-muted);
        font-size: var(--text-lg);
        font-weight: 600;
        line-height: 1.75;
        word-break: keep-all;
    }

    .about-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
    }

    .about-card {
        min-height: 190px;
        display: grid;
        align-content: start;
        gap: 12px;
        padding: 22px;
        border-radius: var(--radius-lg);
        color: var(--color-text);
        text-decoration: none;
        transition: background 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
    }

    .about-card:hover {
        background: color-mix(in srgb, var(--color-aiki-blue) 12%, var(--color-surface-elevated) 88%);
        box-shadow: var(--shadow-card-hover);
        transform: translateY(-2px);
    }

    .about-card span {
        font-family: var(--font-heading);
        font-size: var(--text-2xl);
        font-weight: 900;
        line-height: 1.1;
    }

    .about-card p {
        margin: 0;
        color: var(--color-text-muted);
        font-size: var(--text-sm);
        line-height: 1.7;
        word-break: keep-all;
    }

    .about-panel {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(260px, 0.55fr);
        gap: 24px;
        align-items: center;
        padding: 28px;
        border-radius: var(--radius-lg);
    }

    .about-panel h2 {
        margin: 0 0 8px;
        color: var(--color-text);
        font-size: var(--text-3xl);
        line-height: 1.1;
    }

    .about-principles {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: flex-end;
    }

    .about-principles span {
        display: inline-flex;
        align-items: center;
        min-height: 38px;
        padding: 0 12px;
        border: 1px solid var(--color-border);
        border-radius: 999px;
        background: color-mix(in srgb, var(--color-surface-alt) 76%, transparent);
        color: var(--color-text);
        font-size: var(--text-sm);
        font-weight: 800;
    }

    html.dark .about-hero::before {
        background:
            radial-gradient(circle at 82% 28%, rgba(123, 228, 221, 0.15), transparent 32%),
            linear-gradient(118deg, rgba(255, 255, 255, 0.09), rgba(255, 255, 255, 0) 40%),
            linear-gradient(300deg, rgba(141, 181, 255, 0.16), rgba(197, 184, 255, 0.10));
    }

    @media (max-width: 820px) {
        .about-hero {
            min-height: 0;
            padding: 34px 24px;
        }

        .about-grid,
        .about-panel {
            grid-template-columns: minmax(0, 1fr);
        }

        .about-principles {
            justify-content: flex-start;
        }
    }
</style>
