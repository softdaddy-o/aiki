---
import BaseLayout from '../../layouts/BaseLayout.astro';

const roles = [
    {
        title: '뉴스',
        label: '지금 바뀐 것',
        desc: '새 발표와 논문 흐름을 짧게 잡아. 원문보다 빠르게 읽되, 숫자와 출처는 남겨.',
        href: '/ko/news/',
    },
    {
        title: '위키',
        label: '계속 남길 것',
        desc: '뉴스에서 튀어나온 모델, 기법, 도구를 다시 찾을 수 있는 설명으로 묶어.',
        href: '/ko/wiki/',
    },
    {
        title: '쇼케이스',
        label: '써볼지 가를 것',
        desc: '오픈소스 프로젝트는 실행 흐름, 장점, 조심할 지점을 같은 화면에서 비교해.',
        href: '/ko/projects/',
    },
];

const principles = [
    {
        title: '과장보다 판단',
        desc: '좋다는 말보다 어디에 맞고 어디서 막히는지를 먼저 적어.',
    },
    {
        title: '요약보다 근거',
        desc: '요약은 짧게 두고, 날짜·수치·출처·검증 상태를 같이 남겨.',
    },
    {
        title: '문서보다 연결',
        desc: '뉴스 하나로 끝내지 않고 관련 용어와 프로젝트로 이어서 읽게 만들어.',
    },
    {
        title: '존칭보다 대화',
        desc: '보고서 문장 대신 옆에서 같이 고르는 말투를 써. 딱딱한 격식체는 줄여.',
    },
];

const workflow = [
    '오늘 들어온 신호를 먼저 모아',
    '쓸 만한 뉴스와 노이즈를 갈라',
    '반복해서 나오는 용어를 위키로 묶어',
    '도입 판단이 필요한 프로젝트는 쇼케이스로 내려',
];
---

<BaseLayout
    title="AIKI 소개"
    description="AIKI가 AI 뉴스, 위키, 쇼케이스를 나누고 연결하는 기준."
>
    <section class="about-page" aria-labelledby="about-title">
        <div class="about-hero">
            <p class="about-eyebrow">About AIKI</p>
            <h1 id="about-title">AIKI가 고르는 방식</h1>
            <p>
                AIKI는 AI 소식을 많이 쌓는 곳이 아니야. 오늘 움직인 신호를 고르고, 다시 볼 개념으로 묶고,
                실제 도입 판단까지 이어지게 정리하는 지식 작업대야.
            </p>
        </div>

        <section class="role-panel" aria-labelledby="roles-title">
            <div class="section-heading">
                <p class="about-eyebrow">Content roles</p>
                <h2 id="roles-title">홈과 소개가 맡는 일</h2>
            </div>
            <div class="role-compare">
                <div class="compare-card current">
                    <span>홈</span>
                    <strong>오늘의 브리핑</strong>
                    <p>새 뉴스, 많이 언급된 용어, 도입 후보 프로젝트를 바로 보여줘. 매번 바뀌는 화면이야.</p>
                </div>
                <div class="compare-card">
                    <span>소개</span>
                    <strong>고르는 기준</strong>
                    <p>왜 이걸 골랐고 어떤 원칙으로 검증하는지 남겨. 자주 바뀌지 않는 기준점이야.</p>
                </div>
            </div>
        </section>

        <section class="roles-grid" aria-label="AIKI 문서 역할">
            {roles.map((role) => (
                <a href={role.href} class="role-card">
                    <span>{role.label}</span>
                    <strong>{role.title}</strong>
                    <p>{role.desc}</p>
                </a>
            ))}
        </section>

        <section class="principles-panel" aria-labelledby="principles-title">
            <div class="section-heading">
                <p class="about-eyebrow">Editorial principles</p>
                <h2 id="principles-title">편집 원칙</h2>
            </div>
            <div class="principles-grid">
                {principles.map((item) => (
                    <article>
                        <h3>{item.title}</h3>
                        <p>{item.desc}</p>
                    </article>
                ))}
            </div>
        </section>

        <section class="workflow-panel" aria-labelledby="workflow-title">
            <div>
                <p class="about-eyebrow">Operating loop</p>
                <h2 id="workflow-title">AIKI가 하루를 정리하는 순서</h2>
            </div>
            <ol>
                {workflow.map((item, index) => (
                    <li>
                        <span>{String(index + 1).padStart(2, '0')}</span>
                        <strong>{item}</strong>
                    </li>
                ))}
            </ol>
        </section>
    </section>
</BaseLayout>

<style>
    .about-page {
        display: grid;
        gap: 18px;
        max-width: 1040px;
        margin: 0 auto;
    }

    .about-hero,
    .role-panel,
    .role-card,
    .principles-panel,
    .workflow-panel {
        border: 1px solid var(--color-border);
        background: color-mix(in srgb, var(--color-surface-elevated) 82%, transparent);
        box-shadow: var(--shadow-card);
        backdrop-filter: blur(22px) saturate(145%);
    }

    .about-hero {
        min-height: 380px;
        display: grid;
        align-content: center;
        gap: 16px;
        padding: 54px;
        border-radius: var(--radius-xl);
        position: relative;
        overflow: hidden;
    }

    .about-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
            radial-gradient(circle at 78% 24%, rgba(123, 228, 221, 0.22), transparent 32%),
            radial-gradient(circle at 12% 96%, rgba(255, 140, 122, 0.15), transparent 30%),
            linear-gradient(118deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0) 42%);
        pointer-events: none;
    }

    .about-hero > * {
        position: relative;
        z-index: 1;
    }

    .about-eyebrow {
        width: fit-content;
        margin: 0;
        padding: 6px 11px;
        border-radius: 999px;
        background: color-mix(in srgb, var(--color-aiki-blue) 14%, transparent);
        color: color-mix(in srgb, var(--color-aiki-blue) 72%, var(--color-text) 28%);
        font-family: var(--font-heading);
        font-size: 0.72rem;
        font-weight: 900;
        letter-spacing: 0;
        text-transform: uppercase;
    }

    .about-hero h1 {
        max-width: 780px;
        margin: 0;
        color: var(--color-text);
        font-family: var(--font-display);
        font-size: clamp(3.4rem, 9vw, 7rem);
        font-weight: 900;
        line-height: 0.9;
        letter-spacing: 0;
        overflow-wrap: anywhere;
    }

    .about-hero p {
        max-width: 700px;
        margin: 0;
        color: var(--color-text-muted);
        font-size: var(--text-xl);
        font-weight: 700;
        line-height: 1.65;
        word-break: keep-all;
    }

    .role-panel,
    .principles-panel,
    .workflow-panel {
        padding: 24px;
        border-radius: var(--radius-lg);
    }

    .section-heading {
        display: grid;
        gap: 10px;
        margin-bottom: 16px;
    }

    .section-heading h2,
    .workflow-panel h2 {
        margin: 0;
        color: var(--color-text);
        font-family: var(--font-heading);
        font-size: clamp(1.7rem, 4vw, 2.7rem);
        font-weight: 900;
        line-height: 1.05;
        letter-spacing: 0;
    }

    .role-compare,
    .roles-grid,
    .principles-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }

    .roles-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .compare-card,
    .role-card,
    .principles-grid article {
        min-width: 0;
        padding: 18px;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        background: color-mix(in srgb, var(--color-surface-alt) 64%, transparent);
    }

    .compare-card.current {
        background: color-mix(in srgb, var(--color-aiki-blue) 10%, var(--color-surface-alt) 90%);
        border-color: color-mix(in srgb, var(--color-aiki-blue) 44%, var(--color-border) 56%);
    }

    .compare-card span,
    .role-card span {
        color: var(--color-aiki-blue);
        font-size: var(--text-xs);
        font-weight: 900;
        text-transform: uppercase;
    }

    .compare-card strong,
    .role-card strong {
        display: block;
        margin-top: 8px;
        color: var(--color-text);
        font-family: var(--font-heading);
        font-size: var(--text-2xl);
        font-weight: 900;
        line-height: 1.08;
    }

    .compare-card p,
    .role-card p,
    .principles-grid p {
        margin: 10px 0 0;
        color: var(--color-text-muted);
        font-size: var(--text-sm);
        font-weight: 650;
        line-height: 1.7;
        word-break: keep-all;
    }

    .role-card {
        min-height: 190px;
        color: var(--color-text);
        text-decoration: none;
        transition: border-color 0.16s ease, background 0.16s ease, transform 0.16s ease;
    }

    .role-card:hover {
        border-color: color-mix(in srgb, var(--color-aiki-blue) 52%, var(--color-border) 48%);
        background: color-mix(in srgb, var(--color-aiki-blue) 9%, var(--color-surface-alt) 91%);
        transform: translateY(-2px);
    }

    .principles-grid h3 {
        margin: 0;
        color: var(--color-text);
        font-family: var(--font-heading);
        font-size: var(--text-xl);
        font-weight: 900;
        line-height: 1.12;
    }

    .workflow-panel {
        display: grid;
        grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
        gap: 24px;
        align-items: start;
    }

    .workflow-panel ol {
        display: grid;
        gap: 8px;
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .workflow-panel li {
        display: grid;
        grid-template-columns: 42px minmax(0, 1fr);
        gap: 12px;
        align-items: center;
        min-height: 58px;
        padding: 10px 12px;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        background: color-mix(in srgb, var(--color-surface-alt) 62%, transparent);
    }

    .workflow-panel li span {
        color: var(--color-aiki-blue);
        font-family: var(--font-display);
        font-size: var(--text-lg);
        font-weight: 900;
    }

    .workflow-panel li strong {
        color: var(--color-text);
        font-size: var(--text-base);
        font-weight: 850;
        line-height: 1.3;
    }

    html.dark .about-hero::before {
        background:
            radial-gradient(circle at 78% 24%, rgba(123, 228, 221, 0.13), transparent 34%),
            radial-gradient(circle at 12% 96%, rgba(255, 140, 122, 0.08), transparent 32%),
            linear-gradient(118deg, rgba(255, 255, 255, 0.09), rgba(255, 255, 255, 0) 42%);
    }

    @media (max-width: 820px) {
        .about-hero {
            min-height: 0;
            padding: 34px 24px;
        }

        .about-hero p {
            font-size: var(--text-base);
        }

        .role-compare,
        .roles-grid,
        .principles-grid,
        .workflow-panel {
            grid-template-columns: minmax(0, 1fr);
        }
    }
</style>
