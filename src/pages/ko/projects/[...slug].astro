---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import FactCheck from '../../../components/FactCheck.astro';
import SocialShare from '../../../components/SocialShare.astro';
import YfinanceShowcase from '../../../components/projects/showcases/yfinance/index.tsx';
import NfiShowcase from '../../../components/projects/showcases/nfi/index.tsx';
import NautilusShowcase from '../../../components/projects/showcases/nautilus-trader/index.tsx';
import LightRagShowcase from '../../../components/projects/showcases/lightrag/index.tsx';
import HyperFramesShowcase from '../../../components/projects/showcases/hyperframes/index.tsx';
import NemotronOcrShowcase from '../../../components/projects/showcases/nemotron-ocr-v2/index.tsx';

const categoryLabels: Record<string, string> = {
    library: '라이브러리',
    framework: '프레임워크',
    agent: '에이전트',
    model: '모델',
    tool: '도구',
    bot: '봇',
};

export async function getStaticPaths() {
    const entries = await getCollection('projects', ({ data }) => data.lang === 'ko' && !data.draft);
    return entries.map((entry) => ({
        params: { slug: entry.data.slug },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const {
    title,
    summary,
    category,
    githubUrl,
    sourceMetric,
    tags,
    stars,
    license,
    showcaseComponent,
    factCheck,
} = entry.data;
const categoryLabel = categoryLabels[category] ?? category;
const sourceUrl = githubUrl;
const displayedMetric = sourceMetric ?? stars;

function getSourceMeta(url: string) {
    if (url.includes('huggingface.co/')) {
        return {
            provider: 'Hugging Face',
            title: '쇼케이스 기본 정보',
            itemLabel: '모델',
            metricLabel: '좋아요',
            mark: 'HF',
            className: 'huggingface',
            path: url.replace(/^https:\/\/huggingface\.co\//, '').replace(/\/$/, ''),
        };
    }

    if (url.includes('github.com/')) {
        return {
            provider: 'GitHub',
            title: '쇼케이스 기본 정보',
            itemLabel: '저장소',
            metricLabel: '스타',
            mark: 'GH',
            className: 'github',
            path: url.replace(/^https:\/\/github\.com\//, '').replace(/\/$/, ''),
        };
    }

    return {
        provider: 'Source',
        title: '쇼케이스 기본 정보',
        itemLabel: '소스',
        metricLabel: '지표',
        mark: 'SRC',
        className: 'source',
        path: url.replace(/^https?:\/\//, '').replace(/\/$/, ''),
    };
}

const sourceMeta = getSourceMeta(sourceUrl);
const usesShowcaseNarrative = showcaseComponent === 'hyperframes';

function formatStars(value: number): string {
    if (value >= 1000) {
        const compact = (value / 1000).toFixed(1);
        return (compact.endsWith('.0') ? compact.slice(0, -2) : compact) + 'k';
    }
    return String(value);
}

const shareUrl = Astro.url.href;
---

<BaseLayout title={title} description={summary} ogImage={`/og/projects/${entry.data.slug}.png`}>
    <article class:list={['project-page', { 'project-page--showcase-native': usesShowcaseNarrative }]}>
        {!usesShowcaseNarrative && (
        <header class="project-hero">
            <div class="hero-top">
                <span class="category-badge">{categoryLabel}</span>
                <div class="hero-share">
                    <SocialShare
                        title={title}
                        text={summary}
                        url={shareUrl}
                        iconOnly={true}
                    />
                </div>
            </div>
            <h1 class="project-title">{title}</h1>
            <p class="project-summary">{summary}</p>
            <section class="model-card" aria-label={sourceMeta.title}>
                <div class="model-card-head">
                    <span class={`source-mark ${sourceMeta.className}`} aria-hidden="true">{sourceMeta.mark}</span>
                    <div>
                        <p class="model-card-kicker">{sourceMeta.provider}</p>
                        <h2>{sourceMeta.title}</h2>
                    </div>
                </div>
                <dl class="model-card-grid">
                    <div>
                        <dt>{sourceMeta.itemLabel}</dt>
                        <dd>{sourceMeta.path}</dd>
                    </div>
                    <div>
                        <dt>{sourceMeta.metricLabel}</dt>
                        <dd>{formatStars(displayedMetric)}</dd>
                    </div>
                    <div>
                        <dt>라이선스</dt>
                        <dd>{license}</dd>
                    </div>
                </dl>
            </section>
            <div class="hero-tags">
                {tags.map((tag) => <span class="tag-pill">{tag}</span>)}
            </div>
        </header>
        )}

        {showcaseComponent === 'yfinance' && (
            <section class="showcase-area" aria-label={`${title} 인터랙티브 쇼케이스`} id="showcase">
                <div class="showcase-shell">
                    <div class="showcase-frame showcase-frame-with-nav">
                        <header class="showcase-intro">
                            <p>인터랙티브 쇼케이스</p>
                            <h2>yfinance로 바로 훑어보는 시장 데이터 흐름</h2>
                            <span>시장 샘플, 묶음 조회, 검색 탐색, 종목 상세, 확인한 API 범위를 한 화면에서 이어서 볼 수 있어.</span>
                        </header>
                        <YfinanceShowcase client:load slug={entry.data.slug} />
                    </div>
                </div>
            </section>
        )}

        {showcaseComponent === 'nfi' && (
            <section class="showcase-area" aria-label={`${title} 인터랙티브 쇼케이스`} id="showcase">
                <div class="showcase-shell">
                    <div class="showcase-frame showcase-frame-with-nav">
                        <header class="showcase-intro">
                            <p>인터랙티브 쇼케이스</p>
                            <h2>NostalgiaForInfinity 운용 구조를 한 화면에서 보기</h2>
                            <span>전략 계보, 권장 설정, 보호 장치, 백테스트 체크리스트를 공개 문서 기준으로 정리했어.</span>
                        </header>
                        <NfiShowcase client:load slug={entry.data.slug} />
                    </div>
                </div>
            </section>
        )}

        {showcaseComponent === 'nautilus-trader' && (
            <section class="showcase-area" aria-label={`${title} 인터랙티브 쇼케이스`} id="showcase">
                <div class="showcase-shell">
                    <div class="showcase-frame showcase-frame-with-nav">
                        <header class="showcase-intro">
                            <p>인터랙티브 쇼케이스</p>
                            <h2>NautilusTrader 아키텍처와 거래소 연동을 한 화면에서 보기</h2>
                            <span>이벤트 드리븐 컴포넌트, 지원 자산군, 거래소 어댑터, 성능 프로파일을 공식 문서 기준으로 정리했어.</span>
                        </header>
                        <NautilusShowcase client:load slug={entry.data.slug} />
                    </div>
                </div>
            </section>
        )}

        {showcaseComponent === 'lightrag' && (
            <section class="showcase-area" aria-label={`${title} 인터랙티브 쇼케이스`} id="showcase">
                <div class="showcase-shell">
                    <div class="showcase-frame showcase-frame-with-nav">
                        <header class="showcase-intro">
                            <p>인터랙티브 쇼케이스</p>
                            <h2>LightRAG가 문서를 그래프로 읽고 citation 답변으로 꺼내는 흐름</h2>
                            <span>샘플 문서 인덱싱, 엔터티 관계 추출, reranker와 mix mode 감각, 서버 운영 포인트를 한 화면에서 정리했어.</span>
                        </header>
                        <LightRagShowcase client:load slug={entry.data.slug} />
                    </div>
                </div>
            </section>
        )}

        {showcaseComponent === 'hyperframes' && (
            <section class:list={['showcase-area', 'showcase-area--lead']} aria-label={`${title} 인터랙티브 쇼케이스`} id="showcase">
                <div class="showcase-shell hf-shell">
                    <div class="showcase-frame showcase-frame-with-nav hf-frame">
                        <HyperFramesShowcase
                            client:load
                            slug={entry.data.slug}
                            title={title}
                            summary={summary}
                            tags={tags}
                            sourceMeta={sourceMeta}
                            metricValue={formatStars(displayedMetric)}
                            license={license}
                        />
                        {factCheck && (
                            <div class="hf-fact-wrap" id="hf-section-fact">
                                <FactCheck
                                    status={factCheck.status}
                                    date={factCheck.date}
                                    checks={factCheck.checks}
                                    sources={factCheck.sources}
                                    lang="ko"
                                />
                            </div>
                        )}
                    </div>
                </div>
            </section>
        )}

        {showcaseComponent === 'nemotron-ocr-v2' && (
            <section class="showcase-area" aria-label={`${title} 인터랙티브 쇼케이스`} id="showcase">
                <div class="showcase-shell">
                    <div class="showcase-frame showcase-frame-with-nav">
                        <header class="showcase-intro">
                            <p>인터랙티브 쇼케이스</p>
                            <h2>한글 테스트 이미지를 실제로 돌린 OCR 결과와 속도 감각</h2>
                            <span>입력 이미지, 주석 결과, 실제 추출 텍스트, 공식 처리량과 메모리 조건을 한 화면에서 같이 볼 수 있어.</span>
                        </header>
                        <NemotronOcrShowcase client:load slug={entry.data.slug} />
                    </div>
                </div>
            </section>
        )}

        {!usesShowcaseNarrative && (
            <section class="project-explainer" aria-labelledby="project-explainer-title">
                <div class="project-explainer-head">
                    <p>Explanation</p>
                    <h2 id="project-explainer-title">판단 근거와 주의점은 아래에서 읽기</h2>
                    <span>쇼케이스로 감을 먼저 잡고, 실제 도입 판단에 필요한 설명과 주의점은 이 아래에서 이어서 읽으면 돼.</span>
                </div>
                <div class="project-body prose">
                    <Content />
                </div>
            </section>
        )}

        {factCheck && !usesShowcaseNarrative && (
            <FactCheck
                status={factCheck.status}
                date={factCheck.date}
                checks={factCheck.checks}
                sources={factCheck.sources}
                lang="ko"
            />
        )}

        <footer class="project-footer">
            <a href="/ko/projects/" class="back-link">&larr; AI 쇼케이스 리스트</a>
        </footer>
    </article>
</BaseLayout>

<style>
    .project-page {
        max-width: 960px;
        margin: 0 auto;
    }

    .project-page--showcase-native {
        max-width: none;
    }

    .project-hero {
        margin-bottom: 32px;
    }

    .hero-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px 14px;
        margin-bottom: 12px;
    }

    .hero-share {
        margin-left: auto;
    }

    .category-badge {
        padding: 3px 10px;
        border-radius: 6px;
        background: color-mix(in srgb, var(--color-projects) 15%, transparent);
        color: var(--color-projects);
        font-size: var(--text-xs);
        font-weight: 700;
    }

    .project-title {
        margin-bottom: 8px;
        font-size: var(--text-4xl);
        line-height: 1.15;
    }

    .project-summary {
        max-width: 720px;
        margin-bottom: 16px;
        color: var(--color-text-muted);
        font-size: var(--text-lg);
    }

    .hero-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .tag-pill {
        padding: 3px 9px;
        border-radius: 5px;
        background: var(--color-surface-alt);
        color: var(--color-text-muted);
        font-size: 12px;
    }

    .model-card {
        max-width: 760px;
        margin: 22px 0 16px;
        padding: 18px;
        border: 1px solid var(--color-border);
        border-radius: 8px;
        background: var(--color-surface-alt);
    }

    .model-card-head {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 14px;
    }

    .source-mark {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 38px;
        height: 38px;
        border-radius: 8px;
        flex-shrink: 0;
        font-size: 12px;
        font-weight: 900;
        letter-spacing: 0.08em;
    }

    .source-mark.github {
        background: #24292f;
        color: #fff;
    }

    .source-mark.huggingface {
        background: #ffd166;
        color: #3d2a00;
    }

    .source-mark.source {
        background: var(--color-text);
        color: var(--color-surface);
    }

    .model-card-kicker {
        margin: 0;
        color: var(--color-text-muted);
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .model-card h2 {
        margin: 2px 0 0;
        font-size: var(--text-lg);
    }

    .model-card-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
        margin: 0;
    }

    .model-card-grid div {
        min-width: 0;
        padding: 10px;
        border-radius: 7px;
        background: var(--color-surface);
    }

    .model-card-grid dt {
        margin-bottom: 5px;
        color: var(--color-text-muted);
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
    }

    .model-card-grid dd {
        margin: 0;
        overflow-wrap: anywhere;
        font-size: var(--text-sm);
        font-weight: 750;
    }

    .project-explainer {
        display: grid;
        gap: 18px;
        margin: 40px auto 0;
    }

    .project-explainer-head {
        max-width: 760px;
    }

    .project-explainer-head p {
        margin: 0 0 8px;
        color: var(--color-projects);
        font-family: var(--font-heading);
        font-size: 0.82rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .project-explainer-head h2 {
        margin: 0 0 10px;
        font-size: clamp(1.3rem, 2vw, 1.9rem);
        line-height: 1.25;
    }

    .project-explainer-head span {
        display: block;
        max-width: 720px;
        color: var(--color-text-muted);
        font-size: var(--text-base);
        line-height: 1.65;
    }

    .project-body {
        max-width: 680px;
        margin-bottom: 40px;
    }

    .project-body :global(h2) {
        margin-top: 28px;
        margin-bottom: 12px;
        font-size: var(--text-xl);
    }

    .project-body :global(p) {
        margin-bottom: 14px;
        line-height: 1.7;
    }

    .project-body :global(ul),
    .project-body :global(ol) {
        margin-bottom: 14px;
        padding-left: 20px;
    }

    .project-body :global(blockquote) {
        margin: 20px 0;
        padding: 14px 16px;
        border-left: 3px solid var(--color-projects);
        border-radius: 0 8px 8px 0;
        background: var(--color-surface-alt);
        color: var(--color-text-muted);
    }

    .project-body :global(blockquote p:last-child) {
        margin-bottom: 0;
    }

    .project-page :global(.term-hint) {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        vertical-align: baseline;
        white-space: normal;
    }

    .project-page :global(.term-hint__label) {
        color: var(--color-projects);
        font-weight: 700;
    }

    .project-page :global(.term-hint__button) {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 18px;
        height: 18px;
        padding: 0;
        border: 1px solid color-mix(in srgb, var(--color-projects) 44%, transparent);
        border-radius: 999px;
        background: color-mix(in srgb, var(--color-projects) 12%, transparent);
        color: var(--color-projects);
        font: inherit;
        font-size: 11px;
        font-weight: 800;
        line-height: 1;
        cursor: help;
    }

    .project-page :global(.term-hint__tooltip) {
        position: absolute;
        left: 0;
        top: calc(100% + 10px);
        z-index: 12;
        width: min(280px, calc(100vw - 48px));
        padding: 10px 12px;
        border: 1px solid var(--color-border);
        border-radius: 10px;
        background: color-mix(in srgb, var(--color-surface) 96%, #000 4%);
        box-shadow: 0 12px 28px rgba(0, 0, 0, 0.22);
        color: var(--color-text);
        font-size: 13px;
        font-weight: 500;
        line-height: 1.55;
        opacity: 0;
        pointer-events: none;
        transform: translateY(4px);
        transition:
            opacity 140ms ease,
            transform 140ms ease;
    }

    .project-page :global(.term-hint:hover .term-hint__tooltip),
    .project-page :global(.term-hint:focus-within .term-hint__tooltip) {
        opacity: 1;
        transform: translateY(0);
    }

    .showcase-area {
        position: relative;
        margin-top: 64px;
        padding: 32px 0 40px;
    }

    .showcase-area--lead {
        margin-top: 16px;
    }

    .showcase-area::before {
        content: '';
        position: absolute;
        inset: 0 calc(-50vw + 50%);
        border-top: 1px solid var(--color-border);
        border-bottom: 1px solid var(--color-border);
        background:
            linear-gradient(180deg, color-mix(in srgb, var(--color-projects) 8%, transparent), transparent 28%),
            var(--color-surface-alt);
        z-index: 0;
    }

    .showcase-shell {
        position: relative;
        z-index: 1;
        max-width: 1120px;
        margin: 0 auto;
        padding: 22px clamp(16px, 2.2vw, 28px) 26px;
        border: 1px solid color-mix(in srgb, var(--color-border) 88%, transparent);
        border-radius: 24px;
        background: color-mix(in srgb, var(--color-surface) 90%, var(--color-surface-alt));
        box-shadow: 0 20px 48px rgba(0, 0, 0, 0.08);
        backdrop-filter: blur(10px);
    }

    .hf-shell {
        max-width: min(1440px, calc(100vw - 24px));
        backdrop-filter: none;
    }

    .hf-frame :global(.showcase-section-nav) {
        grid-column: 1;
        grid-row: 1 / span 2;
    }

    .hf-fact-wrap {
        grid-column: 2;
        min-width: 0;
        margin-top: 18px;
        scroll-margin-top: 100px;
    }

    @media (min-width: 1280px) {
        .hf-shell {
            margin-left: max(220px, calc((100vw - 1440px) / 2));
            margin-right: auto;
            max-width: min(1440px, calc(100vw - 236px));
        }

        .showcase-frame.hf-frame {
            grid-template-columns: minmax(0, 1fr);
        }

        .showcase-frame.hf-frame :global(.hf-main) {
            grid-column: 1;
        }

        .hf-fact-wrap {
            grid-column: 1;
        }

        .showcase-frame.hf-frame :global(.showcase-section-nav) {
            position: fixed;
            top: 92px;
            left: 16px;
            width: 188px;
            max-height: calc(100vh - 120px);
            overflow-y: auto;
            z-index: 40;
            grid-row: auto;
            grid-column: auto;
            box-shadow: 0 22px 48px rgba(0, 0, 0, 0.32);
        }
    }

    @media (max-width: 1279px) {
        .hf-shell {
            max-width: min(1240px, calc(100vw - 24px));
        }
    }

    @media (max-width: 900px) {
        .hf-shell {
            max-width: 100%;
            padding: 16px 12px 20px;
            border-radius: 18px;
        }
    }

    .showcase-frame {
        display: grid;
        grid-template-columns: 180px minmax(0, 1fr);
        align-items: start;
        column-gap: 18px;
        row-gap: 12px;
        max-width: none;
        margin: 0;
        padding-top: 0;
    }

    .showcase-frame-with-nav {
        max-width: none;
    }

    .showcase-intro {
        grid-column: 1 / -1;
        margin: 0;
        padding: 0 0 12px;
    }

    .showcase-intro p {
        margin: 0 0 10px;
        color: var(--color-projects);
        font-family: var(--font-heading);
        font-size: clamp(2.1rem, 5vw, 4.8rem);
        font-weight: 850;
        line-height: 0.96;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

    .showcase-intro h2 {
        margin: 0 0 12px;
        max-width: 820px;
        font-size: clamp(1.35rem, 2.2vw, 2.05rem);
        line-height: 1.25;
    }

    .showcase-intro span {
        display: block;
        max-width: 760px;
        color: var(--color-text-muted);
        font-size: var(--text-lg);
        line-height: 1.65;
    }

    .project-footer {
        margin-top: 40px;
        padding-top: 20px;
        border-top: 1px solid var(--color-border);
    }

    .project-page--showcase-native .project-footer {
        max-width: min(1520px, calc(100vw - 24px));
        margin: 32px auto 0;
    }

    .back-link {
        color: var(--color-projects);
        font-size: var(--text-sm);
        font-weight: 700;
        text-decoration: none;
    }

    .back-link:hover {
        text-decoration: underline;
    }

    @media (max-width: 900px) {
        .showcase-frame {
            grid-template-columns: minmax(0, 1fr);
            gap: 14px;
            padding-top: 32px;
        }

        .hf-frame :global(.showcase-section-nav) {
            grid-row: auto;
        }

        .hf-fact-wrap {
            grid-column: 1;
        }
    }

    @media (max-width: 640px) {
        .hero-share {
            width: 100%;
            margin-left: 0;
        }

        .project-title {
            font-size: var(--text-2xl);
