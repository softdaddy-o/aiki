---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import YfinanceShowcase from '../../../components/projects/showcases/yfinance/index.tsx';

const categoryLabels: Record<string, string> = {
    library: '라이브러리',
    framework: '프레임워크',
    agent: '에이전트',
    model: '모델',
    tool: '도구',
    bot: '봇',
};

export async function getStaticPaths() {
    const entries = await getCollection('projects', ({ data }) => data.lang === 'ko' && !data.draft);
    return entries.map((entry) => ({
        params: { slug: entry.data.slug },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, summary, category, githubUrl, tags, stars, license, showcaseComponent } = entry.data;
const categoryLabel = categoryLabels[category] ?? category;
const repoPath = githubUrl.replace(/^https:\/\/github\.com\//, '').replace(/\/$/, '');

function formatStars(value: number): string {
    if (value >= 1000) {
        const compact = (value / 1000).toFixed(1);
        return (compact.endsWith('.0') ? compact.slice(0, -2) : compact) + 'k';
    }
    return String(value);
}

---

<BaseLayout title={title} description={summary}>
    <article class="project-page">
        <header class="project-hero">
            <div class="hero-top">
                <span class="category-badge">{categoryLabel}</span>
            </div>
            <h1 class="project-title">{title}</h1>
            <p class="project-summary">{summary}</p>
            <section class="model-card" aria-label="프로젝트 기본 정보">
                <div class="model-card-head">
                    <span class="github-mark" aria-hidden="true">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
                    </span>
                    <div>
                        <p class="model-card-kicker">Project Card</p>
                        <h2>GitHub 기본 정보</h2>
                    </div>
                </div>
                <dl class="model-card-grid">
                    <div>
                        <dt>Repository</dt>
                        <dd>{repoPath}</dd>
                    </div>
                    <div>
                        <dt>Stars</dt>
                        <dd>{formatStars(stars)}</dd>
                    </div>
                    <div>
                        <dt>License</dt>
                        <dd>{license}</dd>
                    </div>
                    <div>
                        <dt>Category</dt>
                        <dd>{categoryLabel}</dd>
                    </div>
                    <div>
                        <dt>Data Surface</dt>
                        <dd>Yahoo Finance public market data</dd>
                    </div>
                    <div>
                        <dt>Affiliation</dt>
                        <dd>Yahoo, Inc.와 별도 관계 없음</dd>
                    </div>
                </dl>
            </section>
            <div class="hero-tags">
                {tags.map((tag) => <span class="tag-pill">{tag}</span>)}
            </div>
        </header>

        <div class="project-body prose">
            <Content />
        </div>

        {showcaseComponent === 'yfinance' && (
            <section class="showcase-area" aria-label={`${title} interactive showcase`} id="showcase">
                <header class="showcase-intro">
                    <p>Interactive Showcase</p>
                    <h2>yfinance로 실제로 열어볼 수 있는 데이터</h2>
                    <span>아래 플로팅 버튼을 눌러 시장 샘플, 배치 다운로드, 검색/스크리너, 종목 딥다이브, API 커버리지를 오가며 볼 수 있어.</span>
                </header>
                <YfinanceShowcase client:load slug={entry.data.slug} />
            </section>
        )}

        <footer class="project-footer">
            <a href="/ko/projects/" class="back-link">&larr; AI 프로젝트 쇼케이스</a>
        </footer>
    </article>
</BaseLayout>

<style>
    .project-page {
        max-width: 960px;
        margin: 0 auto;
    }

    .project-hero {
        margin-bottom: 32px;
    }

    .hero-top {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 12px;
    }

    .category-badge {
        padding: 3px 10px;
        border-radius: 6px;
        background: color-mix(in srgb, var(--color-projects) 15%, transparent);
        color: var(--color-projects);
        font-size: var(--text-xs);
        font-weight: 700;
    }

    .project-title {
        margin-bottom: 8px;
        font-size: var(--text-4xl);
        line-height: 1.15;
    }

    .project-summary {
        max-width: 720px;
        margin-bottom: 16px;
        color: var(--color-text-muted);
        font-size: var(--text-lg);
    }

    .hero-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .tag-pill {
        padding: 3px 9px;
        border-radius: 5px;
        font-size: 12px;
    }

    .tag-pill {
        background: var(--color-surface-alt);
        color: var(--color-text-muted);
    }

    .model-card {
        max-width: 760px;
        margin: 22px 0 16px;
        padding: 18px;
        border: 1px solid var(--color-border);
        border-radius: 8px;
        background: var(--color-surface-alt);
    }

    .model-card-head {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 14px;
    }

    .github-mark {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 38px;
        height: 38px;
        border-radius: 8px;
        background: #24292f;
        color: #fff;
        flex-shrink: 0;
    }

    .model-card-kicker {
        margin: 0;
        color: var(--color-text-muted);
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .model-card h2 {
        margin: 2px 0 0;
        font-size: var(--text-lg);
    }

    .model-card-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
        margin: 0;
    }

    .model-card-grid div {
        min-width: 0;
        padding: 10px;
        border-radius: 7px;
        background: var(--color-surface);
    }

    .model-card-grid dt {
        margin-bottom: 5px;
        color: var(--color-text-muted);
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
    }

    .model-card-grid dd {
        margin: 0;
        overflow-wrap: anywhere;
        font-size: var(--text-sm);
        font-weight: 750;
    }

    .project-body {
        max-width: 680px;
        margin-bottom: 40px;
    }

    .project-body :global(h2) {
        margin-top: 28px;
        margin-bottom: 12px;
        font-size: var(--text-xl);
    }

    .project-body :global(p) {
        margin-bottom: 14px;
        line-height: 1.7;
    }

    .project-body :global(ul),
    .project-body :global(ol) {
        margin-bottom: 14px;
        padding-left: 20px;
    }

    .project-body :global(blockquote) {
        margin: 20px 0;
        padding: 14px 16px;
        border-left: 3px solid var(--color-projects);
        border-radius: 0 8px 8px 0;
        background: var(--color-surface-alt);
        color: var(--color-text-muted);
    }

    .project-body :global(blockquote p:last-child) {
        margin-bottom: 0;
    }

    .showcase-area {
        margin-right: calc(-50vw + 50%);
        margin-left: calc(-50vw + 50%);
        margin-top: 64px;
        padding: 0 24px 48px;
        border-top: 1px solid var(--color-border);
        border-bottom: 1px solid var(--color-border);
        background: var(--color-surface-alt);
    }

    .showcase-intro {
        max-width: 1180px;
        margin: 0 auto 28px;
        padding: 40px 0 12px;
    }

    .showcase-intro p {
        margin: 0 0 10px;
        color: var(--color-projects);
        font-family: var(--font-heading);
        font-size: clamp(2.1rem, 5vw, 4.8rem);
        font-weight: 850;
        line-height: 0.96;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

    .showcase-intro h2 {
        margin: 0 0 12px;
        max-width: 820px;
        font-size: clamp(1.35rem, 2.2vw, 2.05rem);
        line-height: 1.25;
    }

    .showcase-intro span {
        display: block;
        max-width: 760px;
        color: var(--color-text-muted);
        font-size: var(--text-lg);
        line-height: 1.65;
    }

    .project-footer {
        margin-top: 40px;
        padding-top: 20px;
        border-top: 1px solid var(--color-border);
    }

    .back-link {
        color: var(--color-projects);
        font-size: var(--text-sm);
        font-weight: 700;
        text-decoration: none;
    }

    .back-link:hover {
        text-decoration: underline;
    }

    @media (max-width: 640px) {
        .project-title {
            font-size: var(--text-2xl);
        }

        .project-summary {
            font-size: var(--text-base);
        }

        .model-card-grid {
            grid-template-columns: 1fr;
        }

        .showcase-area {
            margin-top: 48px;
            padding: 0 12px 30px;
        }

        .showcase-intro {
            padding-top: 24px;
        }

        .showcase-intro p {
            font-size: clamp(2rem, 14vw, 3.3rem);
            letter-spacing: 0.06em;
        }

        .showcase-intro span {
            font-size: var(--text-base);
        }
    }
</style>
