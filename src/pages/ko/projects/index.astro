---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProjectCard from '../../../components/projects/ProjectCard.astro';
import { t } from '../../../i18n/utils';
import { projectPopularity, projectRecency, sortProjectsByPopular } from '../../../lib/catalogSort.js';

const lang = 'ko';
const allProjects = await getCollection('projects', ({ data }) => data.lang === lang && !data.draft);
const projects = sortProjectsByPopular(allProjects);
const categories = ['library', 'framework', 'agent', 'model', 'tool', 'bot', 'dataset'] as const;
---

<BaseLayout title={t(lang, 'projects.title')} description="직접 실행한 결과와 도입 판단 포인트를 함께 보여주는 AI 쇼케이스">
    <section class="projects-catalog" aria-labelledby="projects-catalog-title">
        <div class="catalog-heading">
            <h1 id="projects-catalog-title" class="catalog-title">{t(lang, 'projects.title')}</h1>
            <p class="catalog-desc">너만 모르는 AI 프로젝트</p>
        </div>

        <div class="catalog-controls">
            <div class="category-tabs" aria-label="Showcase categories">
                <button type="button" class="cat-tab active" data-filter="all">{t(lang, 'filter.all')}</button>
                {categories.map((category) => {
                    const count = projects.filter((project) => project.data.category === category).length;
                    return count > 0 ? (
                        <button type="button" class="cat-tab" data-filter={category}>{t(lang, `projects.category.${category}`)}</button>
                    ) : null;
                })}
            </div>
            <div class="sort-tabs" aria-label="쇼케이스 정렬">
                <button type="button" class="sort-tab active" data-sort-mode="popular" aria-pressed="true">인기순</button>
                <button type="button" class="sort-tab" data-sort-mode="recent" aria-pressed="false">최근 추가</button>
            </div>
        </div>

        <div class="projects-grid" id="projects-grid">
            {projects.map((project) => (
                <ProjectCard
                    title={project.data.title}
                    slug={project.data.slug}
                    summary={project.data.summary}
                    category={project.data.category}
                    tags={project.data.tags}
                    sourceUrl={project.data.githubUrl}
                    metric={project.data.sourceMetric ?? project.data.stars}
                    license={project.data.license}
                    version={project.data.version}
                    date={project.data.date}
                    popularity={projectPopularity(project)}
                    recency={projectRecency(project)}
                    lang={lang}
                />
            ))}
        </div>

    </section>
</BaseLayout>

<script is:inline>
    const cards = Array.from(document.querySelectorAll('[data-project-card]'));
    const tabs = Array.from(document.querySelectorAll('.cat-tab'));
    const sortTabs = Array.from(document.querySelectorAll('.sort-tab'));
    const grid = document.querySelector('#projects-grid');
    let activeFilter = 'all';
    let activeSort = 'popular';

    function filterCards() {
        cards.forEach((card) => {
            const matchCategory = activeFilter === 'all' || card.getAttribute('data-category') === activeFilter;
            const show = matchCategory;
            card.hidden = !show;
        });
    }

    function sortCards() {
        if (!grid) return;
        const metric = activeSort === 'recent' ? 'recency' : 'popularity';
        const sortedCards = [...cards].sort((left, right) => {
            const leftValue = Number(left.getAttribute(`data-${metric}`) || 0);
            const rightValue = Number(right.getAttribute(`data-${metric}`) || 0);
            if (rightValue !== leftValue) return rightValue - leftValue;
            return (left.getAttribute('data-title') || '').localeCompare(right.getAttribute('data-title') || '', 'ko');
        });
        sortedCards.forEach((card) => grid.appendChild(card));
    }

    tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
            tabs.forEach((item) => item.classList.remove('active'));
            tab.classList.add('active');
            activeFilter = tab.getAttribute('data-filter') || 'all';
            filterCards();
        });
    });

    sortTabs.forEach((tab) => {
        tab.addEventListener('click', () => {
            sortTabs.forEach((item) => {
                const active = item === tab;
                item.classList.toggle('active', active);
                item.setAttribute('aria-pressed', active ? 'true' : 'false');
            });
            activeSort = tab.getAttribute('data-sort-mode') || 'popular';
            sortCards();
            filterCards();
        });
    });
</script>

<style>
    .projects-catalog {
        max-width: 1000px;
        margin: 0 auto;
    }

    .catalog-heading {
        margin: 22px 0 26px;
        padding-bottom: 16px;
    }

    .catalog-title {
        max-width: 920px;
        margin-bottom: 8px;
        color: var(--color-text);
        font-family: var(--font-display);
        font-size: 4rem;
        font-weight: 900;
        line-height: 1.02;
        overflow-wrap: anywhere;
    }

    .catalog-desc {
        max-width: 580px;
        margin: 0;
        color: var(--color-text-muted);
        font-size: var(--text-base);
        font-weight: 650;
        line-height: 1.7;
    }

    .catalog-controls {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 32px;
    }

    .category-tabs,
    .sort-tabs {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        min-width: 0;
    }

    .sort-tabs {
        margin-left: auto;
        border: 1px solid var(--color-border);
        border-radius: 999px;
        background: color-mix(in srgb, var(--color-surface-elevated) 68%, transparent);
        padding: 3px;
    }

    .cat-tab,
    .sort-tab {
        min-height: 44px;
        padding: 0 16px;
        border: 1px solid var(--color-border);
        border-radius: 999px;
        background: color-mix(in srgb, var(--color-surface-elevated) 68%, transparent);
        color: var(--color-text-muted);
        cursor: pointer;
        font: inherit;
        font-size: var(--text-sm);
        font-weight: 600;
        transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
    }

    .sort-tab {
        min-height: 34px;
        border-color: transparent;
        background: transparent;
        font-weight: 750;
    }

    .cat-tab:hover,
    .sort-tab:hover {
        background: rgba(255, 255, 255, 0.68);
        color: var(--color-text);
    }

    .cat-tab.active,
    .sort-tab.active {
        border-color: var(--color-text);
        background: var(--color-text);
        color: #fff;
    }

    .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
        gap: 14px;
        border-top: 0;
        border-left: 0;
    }

    @media (max-width: 640px) {
        .catalog-title {
            font-size: 2.75rem;
        }

        .catalog-desc {
            font-size: var(--text-lg);
        }

        .projects-grid {
            grid-template-columns: minmax(0, 1fr);
            border-left: 0;
        }

        .catalog-controls {
            align-items: flex-start;
        }

        .sort-tabs {
            margin-left: 0;
        }
    }
</style>
