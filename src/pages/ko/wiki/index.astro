---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const lang = 'ko';
const allWiki = await getCollection('wiki', ({ data }) => data.lang === lang && !data.draft);

const categoryLabels: Record<string, string> = {
    concept: '개념',
    technique: '기법',
    framework: '프레임워크',
    tool: '도구',
    model: '모델',
};

const categoryOrder = ['concept', 'model', 'technique', 'tool', 'framework'];

const grouped: Record<string, typeof allWiki> = {};
for (const entry of allWiki) {
    const cat = entry.data.category;
    if (!grouped[cat]) grouped[cat] = [];
    grouped[cat].push(entry);
}

for (const cat of Object.keys(grouped)) {
    grouped[cat].sort((a, b) => b.data.mentionCount - a.data.mentionCount);
}
---

<BaseLayout title="AI 용어 사전">
    <h1 class="page-title">AI 용어 사전</h1>
    <p class="page-desc">AI 뉴스에서 자주 나오는 용어를 빠르게 찾고, 바로 이해할 수 있게 정리했어.</p>

    <div class="wiki-filters" aria-label="위키 카테고리 필터">
        <button type="button" class="wiki-filter active" data-filter="all">전체</button>
        {categoryOrder.filter((cat) => grouped[cat]?.length).map((cat) => (
            <button type="button" class="wiki-filter" data-filter={cat}>{categoryLabels[cat]}</button>
        ))}
    </div>

    {categoryOrder.filter((cat) => grouped[cat]?.length).map((cat) => (
        <section class="wiki-section" data-wiki-section={cat} id={`wiki-section-${cat}`}>
            <h2 class="section-title">
                <span class="section-badge">{categoryLabels[cat]}</span>
            </h2>
            <div class="wiki-grid">
                {grouped[cat].map((entry) => {
                    const slug = entry.id.replace(/^ko\//, '');
                    return (
                        <a
                            href={`/ko/wiki/${slug}/`}
                            class="wiki-card"
                            data-wiki-card
                            data-title={entry.data.title}
                            data-summary={entry.data.summary}
                            data-aliases={(entry.data.aliases || []).join(' ')}
                            data-category={categoryLabels[cat]}
                        >
                            <h3 class="wiki-card-title">{entry.data.title}</h3>
                            <p class="wiki-card-summary">{entry.data.summary}</p>
                            <div class="wiki-card-meta">
                                <span class="wiki-card-category">{categoryLabels[cat]}</span>
                                {entry.data.mentionCount > 0 && (
                                    <span class="mention-count">{entry.data.mentionCount}회 언급</span>
                                )}
                            </div>
                        </a>
                    );
                })}
            </div>
        </section>
    ))}
</BaseLayout>

<script is:inline>
    const tabs = Array.from(document.querySelectorAll('.wiki-filter'));
    const sections = Array.from(document.querySelectorAll('[data-wiki-section]'));
    let activeFilter = 'all';

    function applyWikiFilter() {
        sections.forEach((section) => {
            const sectionKey = section.getAttribute('data-wiki-section');
            section.hidden = activeFilter !== 'all' && sectionKey !== activeFilter;
        });
    }

    tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
            tabs.forEach((item) => item.classList.remove('active'));
            tab.classList.add('active');
            activeFilter = tab.getAttribute('data-filter') || 'all';
            applyWikiFilter();
        });
    });
</script>

<style>
    .page-title {
        text-align: center;
        font-size: 24px;
        margin-bottom: 8px;
    }

    .page-desc {
        text-align: center;
        color: var(--color-text-muted);
        font-size: 14px;
        margin-bottom: 28px;
    }

    .wiki-filters {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 28px;
    }

    .wiki-filter {
        min-height: 34px;
        padding: 0 13px;
        border: 1px solid var(--color-border);
        border-radius: 8px;
        background: var(--color-surface-elevated);
        color: var(--color-text-muted);
        cursor: pointer;
        font: inherit;
        font-size: var(--text-sm);
        font-weight: 600;
        transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
    }

    .wiki-filter:hover {
        border-color: var(--color-border-strong);
        color: var(--color-text);
    }

    .wiki-filter.active {
        border-color: var(--color-wiki);
        background: var(--color-wiki);
        color: #000;
    }

    .wiki-section {
        margin-bottom: 32px;
    }

    .section-title {
        margin-bottom: 12px;
    }

    .section-badge {
        background: var(--color-wiki);
        color: #000;
        padding: 2px 10px;
        border-radius: 4px;
        font-size: 13px;
        font-weight: bold;
    }

    .wiki-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 16px;
    }

    .wiki-card {
        display: block;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-left: 3px solid var(--color-wiki);
        border-radius: 8px;
        padding: 18px 20px;
        text-decoration: none;
        color: inherit;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
        transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    }

    .wiki-card:hover {
        background: var(--color-surface-alt);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
    }

    .wiki-card-title {
        font-size: 15px;
        font-weight: bold;
        margin-bottom: 6px;
    }

    .wiki-card-summary {
        font-size: 12px;
        color: var(--color-text-muted);
        line-height: 1.55;
        margin-bottom: 10px;
    }

    .wiki-card-meta {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        align-items: center;
    }

    .wiki-card-category {
        display: inline-flex;
        align-items: center;
        padding: 4px 8px;
        border-radius: 999px;
        background: color-mix(in srgb, var(--color-wiki) 12%, transparent);
        color: var(--color-wiki);
        font-size: 11px;
        font-weight: 700;
    }

    .mention-count {
        font-size: 11px;
        color: var(--color-wiki);
    }

    @media (max-width: 640px) {
        .wiki-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
