---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { sortWikiByPopular, sortWikiByRecent } from '../../../lib/catalogSort.js';

const lang = 'ko';
const allWiki = await getCollection('wiki', ({ data }) => data.lang === lang && !data.draft);
const popularWiki = sortWikiByPopular(allWiki);
const recentWiki = sortWikiByRecent(allWiki);

const categoryLabels: Record<string, string> = {
    concept: '개념',
    technique: '기법',
    framework: '프레임워크',
    tool: '도구',
    model: '모델',
};

const categoryOrder = ['concept', 'model', 'technique', 'tool', 'framework'];

const grouped: Record<string, typeof allWiki> = {};
for (const entry of popularWiki) {
    const cat = entry.data.category;
    if (!grouped[cat]) grouped[cat] = [];
    grouped[cat].push(entry);
}

function wikiSlug(entry: (typeof allWiki)[number]): string {
    return entry.id.replace(/^ko\//, '');
}

function formatWikiDate(value?: string): string {
    if (!value) return '날짜 없음';
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return value;
    return new Intl.DateTimeFormat('ko-KR', { month: 'numeric', day: 'numeric' }).format(date);
}
---

<BaseLayout title="AI 용어 사전">
    <h1 class="page-title">AI 용어 사전</h1>
    <p class="page-desc">너만 모르는 AI 용어</p>

    <div class="wiki-controls">
        <div class="wiki-filters" aria-label="위키 카테고리 필터">
            <button type="button" class="wiki-filter active" data-filter="all">전체</button>
            {categoryOrder.filter((cat) => grouped[cat]?.length).map((cat) => (
                <button type="button" class="wiki-filter" data-filter={cat}>{categoryLabels[cat]}</button>
            ))}
        </div>
        <div class="wiki-sort-tabs" aria-label="위키 정렬">
            <button type="button" class="wiki-sort-tab active" data-sort-mode="popular" aria-pressed="true">인기순</button>
            <button type="button" class="wiki-sort-tab" data-sort-mode="recent" aria-pressed="false">최근 추가</button>
        </div>
    </div>

    {categoryOrder.filter((cat) => grouped[cat]?.length).map((cat) => (
        <section class="wiki-section" data-wiki-section={cat} id={`wiki-section-${cat}`}>
            <h2 class="section-title">
                <span class="section-badge">{categoryLabels[cat]}</span>
            </h2>
            <div class="wiki-grid">
                {grouped[cat].map((entry) => {
                    const slug = wikiSlug(entry);
                    return (
                        <a
                            href={`/ko/wiki/${slug}/`}
                            class="wiki-card"
                            data-wiki-card
                            data-title={entry.data.title}
                            data-summary={entry.data.summary}
                            data-aliases={(entry.data.aliases || []).join(' ')}
                            data-category={categoryLabels[cat]}
                            data-category-key={cat}
                        >
                            <h3 class="wiki-card-title">{entry.data.title}</h3>
                            <p class="wiki-card-summary">{entry.data.summary}</p>
                            <div class="wiki-card-meta">
                                <span class="wiki-card-category">{categoryLabels[cat]}</span>
                                {entry.data.mentionCount > 0 && (
                                    <span class="mention-count">{entry.data.mentionCount}회 언급</span>
                                )}
                            </div>
                        </a>
                    );
                })}
            </div>
        </section>
    ))}

    <section class="wiki-section" id="wiki-section-recent" data-wiki-recent-section hidden>
        <h2 class="section-title">
            <span class="section-badge">최근 추가</span>
        </h2>
        <div class="wiki-grid">
            {recentWiki.map((entry) => {
                const cat = entry.data.category;
                const slug = wikiSlug(entry);
                return (
                    <a
                        href={`/ko/wiki/${slug}/`}
                        class="wiki-card"
                        data-wiki-recent-card
                        data-category-key={cat}
                    >
                        <h3 class="wiki-card-title">{entry.data.title}</h3>
                        <p class="wiki-card-summary">{entry.data.summary}</p>
                        <div class="wiki-card-meta">
                            <span class="wiki-card-category">{categoryLabels[cat]}</span>
                            <span class="mention-count">추가 {formatWikiDate(entry.data.firstMentioned)}</span>
                        </div>
                    </a>
                );
            })}
        </div>
    </section>
</BaseLayout>

<script is:inline>
    const tabs = Array.from(document.querySelectorAll('.wiki-filter'));
    const sortTabs = Array.from(document.querySelectorAll('.wiki-sort-tab'));
    const sections = Array.from(document.querySelectorAll('[data-wiki-section]'));
    const recentSection = document.querySelector('[data-wiki-recent-section]');
    const recentCards = Array.from(document.querySelectorAll('[data-wiki-recent-card]'));
    let activeFilter = 'all';
    let activeSort = 'popular';

    function applyWikiFilter() {
        const showRecent = activeSort === 'recent';
        sections.forEach((section) => {
            const sectionKey = section.getAttribute('data-wiki-section');
            section.hidden = showRecent || (activeFilter !== 'all' && sectionKey !== activeFilter);
        });
        if (recentSection) recentSection.hidden = !showRecent;
        recentCards.forEach((card) => {
            const matchCategory = activeFilter === 'all' || card.getAttribute('data-category-key') === activeFilter;
            card.hidden = !showRecent || !matchCategory;
        });
    }

    tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
            tabs.forEach((item) => item.classList.remove('active'));
            tab.classList.add('active');
            activeFilter = tab.getAttribute('data-filter') || 'all';
            applyWikiFilter();
        });
    });

    sortTabs.forEach((tab) => {
        tab.addEventListener('click', () => {
            sortTabs.forEach((item) => {
                const active = item === tab;
                item.classList.toggle('active', active);
                item.setAttribute('aria-pressed', active ? 'true' : 'false');
            });
            activeSort = tab.getAttribute('data-sort-mode') || 'popular';
            applyWikiFilter();
        });
    });
</script>

<style>
    .page-title {
        max-width: 900px;
        margin: 22px 0 8px;
        color: var(--color-text);
        font-family: var(--font-display);
        font-size: 4rem;
        line-height: 1.02;
        font-weight: 800;
        overflow-wrap: anywhere;
    }

    .page-desc {
        max-width: 560px;
        color: var(--color-text-muted);
        font-size: var(--text-base);
        font-weight: 650;
        line-height: 1.7;
        margin: 0 0 26px;
    }

    .wiki-controls {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 28px;
    }

    .wiki-filters,
    .wiki-sort-tabs {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: flex-start;
        padding-bottom: 2px;
        overflow-x: auto;
    }

    .wiki-sort-tabs {
        margin-left: auto;
        border: 1px solid var(--color-border);
        border-radius: 999px;
        background: color-mix(in srgb, var(--color-surface-elevated) 68%, transparent);
        padding: 3px;
    }

    .wiki-filter,
    .wiki-sort-tab {
        min-height: 38px;
        padding: 0 16px;
        border: 1px solid var(--color-border);
        border-radius: 999px;
        background: color-mix(in srgb, var(--color-surface-elevated) 68%, transparent);
        color: var(--color-text-muted);
        cursor: pointer;
        font: inherit;
        font-size: var(--text-sm);
        font-weight: 600;
        transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
    }

    .wiki-sort-tab {
        min-height: 32px;
        border-color: transparent;
        background: transparent;
        font-weight: 750;
    }

    .wiki-filter:hover,
    .wiki-sort-tab:hover {
        background: rgba(255, 255, 255, 0.68);
        color: var(--color-text);
    }

    .wiki-filter.active,
    .wiki-sort-tab.active {
        border-color: var(--color-text);
        background: var(--color-text);
        color: #fff;
    }

    .wiki-section {
        margin-bottom: 28px;
    }

    .section-title {
        margin: 0 0 12px;
        padding: 0;
    }

    .section-badge {
        background: transparent;
        color: var(--color-text);
        padding: 0;
        border-radius: 0;
        font-family: var(--font-heading);
        font-size: var(--text-2xl);
        font-weight: 800;
        line-height: 1;
    }

    .wiki-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 14px;
        border-top: 0;
    }

    .wiki-card {
        display: block;
        min-width: 0;
        background: color-mix(in srgb, var(--color-surface-elevated) 75%, transparent);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: 20px;
        text-decoration: none;
        color: inherit;
        box-shadow: var(--shadow-card);
        backdrop-filter: blur(18px) saturate(135%);
        transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    }

    .wiki-card:hover {
        background: color-mix(in srgb, var(--color-wiki) 13%, var(--color-surface-elevated) 87%);
        box-shadow: var(--shadow-card-hover);
        transform: translateY(-3px);
    }

    .wiki-card-title {
        font-family: var(--font-display);
        font-size: var(--text-xl);
        font-weight: 800;
        margin-bottom: 8px;
        line-height: 1.34;
        color: var(--color-text);
    }

    .wiki-card-summary {
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        line-height: 1.58;
        margin-bottom: 12px;
    }

    .wiki-card-meta {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        align-items: center;
    }

    .wiki-card-category {
        display: inline-flex;
        align-items: center;
        padding: 3px 8px;
        border-radius: 999px;
        border: 1px solid var(--color-border);
        background: rgba(255, 255, 255, 0.46);
        color: var(--color-text);
        font-size: 11px;
        font-weight: 800;
    }

    .mention-count {
        font-size: 11px;
        color: var(--color-text-muted);
    }

    @media (max-width: 640px) {
        .page-title {
            font-size: 2.75rem;
        }

        .page-desc {
            font-size: var(--text-lg);
        }

        .wiki-grid {
            grid-template-columns: minmax(0, 1fr);
        }

        .wiki-controls {
            align-items: flex-start;
        }

        .wiki-sort-tabs {
            margin-left: 0;
        }

        .wiki-card {
            border-right: 0;
        }
    }
</style>
