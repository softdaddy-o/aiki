---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BackLinks from '../../../components/BackLinks.astro';
import FactCheck from '../../../components/FactCheck.astro';
import ModelProfile from '../../../components/ModelProfile.astro';
import SocialShare from '../../../components/SocialShare.astro';
import TechStackMap from '../../../components/TechStackMap.tsx';
import wikiTermsJson from '../../../../data/wiki-terms.json';

const categoryLabels: Record<string, string> = {
    concept: '개념',
    technique: '기법',
    framework: '프레임워크',
    tool: '도구',
    model: '모델',
};

export async function getStaticPaths() {
    const entries = await getCollection('wiki', ({ data }) => data.lang === 'ko' && !data.draft);
    return entries.map(entry => ({
        params: { slug: entry.id.replace(/^ko\//, '') },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const fc = entry.data.factCheck;
const allWikiEntries = await getCollection('wiki', ({ data }) => data.lang === 'ko' && !data.draft);

const techStackTerms = wikiTermsJson.map((t: any) => ({
    slug: t.term,
    title: t.title,
    category: t.category,
}));

const parentEntry = entry.data.parentModel
    ? allWikiEntries.find((candidate) => candidate.data.term === entry.data.parentModel)
    : null;

const childEntries = allWikiEntries
    .filter((candidate) => candidate.data.parentModel === entry.data.term)
    .sort((a, b) => a.data.title.localeCompare(b.data.title, 'en'));

const wikiBacklinks = allWikiEntries
    .filter((candidate) =>
        candidate.data.term !== entry.data.term
        && (
            candidate.data.relatedTerms.includes(entry.data.term)
            || candidate.data.parentModel === entry.data.term
        ))
    .sort((a, b) => b.data.mentionCount - a.data.mentionCount || a.data.title.localeCompare(b.data.title, 'en'));

// 중복 방지: backlinks에 이미 있는 term은 related에서 제외
const backlinkTerms = new Set(wikiBacklinks.map(e => e.data.term));
const relatedTermsDeduped = entry.data.relatedTerms.filter(t => !backlinkTerms.has(t));

const shareUrl = Astro.url.href;
const ogImage = `/og/wiki/${entry.data.term}.png`;
---

<BaseLayout title={entry.data.title} description={entry.data.summary} ogImage={ogImage} ogType="article">
    <article class="wiki-article">
        <div class="article-meta">
            <div class="article-meta-primary">
                <span class="category-badge">{categoryLabels[entry.data.category]}</span>
                {entry.data.mentionCount > 0 && (
                    <span class="mention-count">{entry.data.mentionCount}회 언급</span>
                )}
            </div>
            <div class="article-share article-share-header">
                <SocialShare
                    title={entry.data.title}
                    text={entry.data.summary}
                    url={shareUrl}
                    iconOnly={true}
                />
            </div>
        </div>

        <h1>{entry.data.title}</h1>

        {entry.data.aliases.length > 0 && (
            <div class="aliases">
                <span class="aliases-label">다른 이름:</span>
                {entry.data.aliases.map(alias => (
                    <span class="alias">{alias}</span>
                ))}
            </div>
        )}

        <div class="wiki-lead-card">
            <p class="wiki-lead">{entry.data.summary}</p>
        </div>

        {entry.data.category === 'model' && entry.data.modelType === 'version' && entry.data.modelProfile && (
            <ModelProfile profile={entry.data.modelProfile} />
        )}

        {entry.data.category === 'model' && parentEntry && (
            <div class="info-card">
                <h2 class="card-title">상위 모델</h2>
                <div class="related-list">
                    <a href={`/ko/wiki/${parentEntry.data.term}/`} class="related-link">{parentEntry.data.title}</a>
                </div>
            </div>
        )}

        {entry.data.category === 'model' && childEntries.length > 0 && (
            <div class="info-card">
                <h2 class="card-title">버전 페이지</h2>
                <div class="related-list">
                    {childEntries.map((child) => (
                        <a href={`/ko/wiki/${child.data.term}/`} class="related-link">{child.data.title}</a>
                    ))}
                </div>
            </div>
        )}

        <div class="info-card tech-stack-card">
            <h2 class="card-title">전체 AI 기술 맵에서의 위치</h2>
            <TechStackMap
                client:visible
                activeTerm={entry.data.term.toLowerCase()}
                terms={techStackTerms}
            />
        </div>

        <div class="article-body prose">
            <Content />
        </div>

        {relatedTermsDeduped.length > 0 && (
            <div class="info-card">
                <h2 class="card-title">관련 용어</h2>
                <div class="related-list">
                    {relatedTermsDeduped.map(term => (
                        <a href={`/ko/wiki/${term}/`} class="related-link">{term}</a>
                    ))}
                </div>
            </div>
        )}

        {wikiBacklinks.length > 0 && (
            <div class="info-card">
                <h2 class="card-title">이 항목을 참조하는 위키</h2>
                <div class="related-list">
                    {wikiBacklinks.map((refEntry) => (
                        <a href={`/ko/wiki/${refEntry.data.term}/`} class="related-link">{refEntry.data.title}</a>
                    ))}
                </div>
            </div>
        )}

        <BackLinks term={entry.data.term.toLowerCase()} minScore={40} />

        <div class="doc-meta">
            <span class="doc-meta-item">포맷 v{entry.data.formatVersion}</span>
            {entry.data.guideVersion && (
                <span class="doc-meta-item">가이드 wiki {entry.data.guideVersion.wiki}</span>
            )}
        </div>

        {fc && (
            <FactCheck
                status={fc.status}
                date={fc.date}
                checks={fc.checks}
                sources={fc.sources}
                lang="ko"
            />
        )}
    </article>
</BaseLayout>

<script>
    // 마크다운 "관련 용어" 섹션은 템플릿이 frontmatter로 직접 렌더하므로 body에서 제외
    const SKIP_HEADINGS = /^(관련\s*용어|관련\s*항목|참조|더\s*보기|see\s*also)/i;

    const bodyEl = document.querySelector('.article-body');
    if (bodyEl) {
        const children = Array.from(bodyEl.children);
        bodyEl.innerHTML = '';
        let preamble: HTMLElement | null = null;
        let currentCard: HTMLElement | null = null;
        let skipCurrent = false;

        children.forEach(el => {
            if (el.tagName === 'H2') {
                skipCurrent = SKIP_HEADINGS.test(el.textContent?.trim() ?? '');
                if (!skipCurrent) {
                    currentCard = document.createElement('div');
                    currentCard.className = 'prose-card';
                    bodyEl.appendChild(currentCard);
                    currentCard.appendChild(el);
                }
            } else if (!skipCurrent) {
                if (currentCard) {
                    currentCard.appendChild(el);
                } else {
                    if (!preamble) {
                        preamble = document.createElement('div');
                        preamble.className = 'prose-preamble';
                        bodyEl.insertBefore(preamble, bodyEl.firstChild);
                    }
                    preamble.appendChild(el);
                }
            }
        });
    }
</script>

<style>
    .wiki-article { max-width: 820px; margin: 0 auto; padding-top: 18px; }

    .article-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px 14px;
        margin-bottom: 18px;
        padding-bottom: 14px;
        border-bottom: 1px solid var(--color-border);
    }

    .article-meta-primary {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
        min-width: 0;
    }

    .category-badge {
        background: var(--color-text);
        color: #fff;
        padding: 3px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 900;
        letter-spacing: 0;
    }

    .mention-count {
        color: var(--color-text-muted);
        font-size: 12px;
        font-variant-numeric: tabular-nums;
    }

    .article-share-header { margin-left: auto; }

    h1 {
        max-width: 760px;
        color: var(--color-text);
        font-family: var(--font-display);
        font-size: 3.25rem;
        font-weight: 800;
        margin-bottom: 14px;
        line-height: 1.08;
        letter-spacing: 0;
        word-break: keep-all;
        overflow-wrap: anywhere;
    }

    .aliases {
        display: flex;
        gap: 6px;
        align-items: center;
        flex-wrap: wrap;
        margin: 0 0 16px;
    }

    .aliases-label { font-size: 12px; color: var(--color-text-muted); }

    .alias {
        background: transparent;
        border: 1px solid var(--color-border);
        padding: 3px 10px;
        border-radius: 999px;
        font-size: 12px;
        color: var(--color-text-muted);
    }

    /* Lead card */
    .wiki-lead-card {
        border: 1px solid var(--color-border);
        border-left: 0;
        background: color-mix(in srgb, var(--color-surface-elevated) 76%, transparent);
        border-radius: var(--radius-lg);
        padding: 18px;
        margin-bottom: 16px;
        box-shadow: var(--shadow-card);
        backdrop-filter: blur(18px);
    }

    .wiki-lead {
        font-size: 18px;
        font-weight: 750;
        line-height: 1.56;
        margin: 0;
        word-break: keep-all;
        color: var(--color-text);
    }

    /* Generic info card — used for tech-map, related, backlinks, hierarchy */
    .info-card {
        background: transparent;
        border: 0;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: 18px;
        margin-bottom: 14px;
        background: color-mix(in srgb, var(--color-surface-elevated) 74%, transparent);
        box-shadow: var(--shadow-card);
        backdrop-filter: blur(18px);
    }

    /* Card title — same visual weight as prose-card h2 */
    .card-title {
        color: var(--color-aiki-blue);
        font-size: var(--text-xl);
        font-weight: 900;
        letter-spacing: 0;
        line-height: 1.3;
        word-break: keep-all;
        color: var(--color-text);
        margin: 0 0 16px;
        padding-bottom: 13px;
        border-bottom: 1px solid var(--color-border);
    }

    .tech-stack-card { margin-bottom: 10px; }

    /* Prose section cards (JS-injected) */
    .article-body { font-size: 16px; line-height: 1.82; margin-bottom: 0; }

    .article-body :global(.prose-preamble p) { margin-bottom: 14px; word-break: keep-all; }

    .article-body :global(.prose-card) {
        background: transparent;
        border: 0;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: 20px;
        margin-bottom: 14px;
        background: color-mix(in srgb, var(--color-surface-elevated) 74%, transparent);
        box-shadow: var(--shadow-card);
        backdrop-filter: blur(18px);
    }

    .article-body :global(.prose-card h2) {
        color: var(--color-aiki-blue);
        font-size: var(--text-xl);
        font-weight: 900;
        margin: 0 0 16px;
        padding-bottom: 13px;
        border-bottom: 1px solid var(--color-border);
        letter-spacing: 0;
        word-break: keep-all;
        color: var(--color-text);
        line-height: 1.3;
    }

    .article-body :global(.prose-card h3) { font-size: 15px; font-weight: 600; margin: 18px 0 8px; }
    .article-body :global(.prose-card p) { margin-bottom: 12px; word-break: keep-all; }
    .article-body :global(.prose-card p:last-child) { margin-bottom: 0; }
    .article-body :global(.prose-card ul),
    .article-body :global(.prose-card ol) { padding-left: 18px; margin-bottom: 12px; }
    .article-body :global(.prose-card li) { margin-bottom: 5px; word-break: keep-all; }
    .article-body :global(.prose-card code) { max-width: 100%; min-width: 0; overflow: auto; }
    .article-body :global(.prose-card pre) { max-width: 100%; min-width: 0; overflow: auto; }

    /* Fallback (no-JS) */
    .article-body :global(h2) { font-size: 20px; margin: 32px 0 12px; letter-spacing: 0; }
    .article-body :global(h3) { font-size: 17px; margin: 24px 0 8px; }
    .article-body :global(p) { margin-bottom: 14px; word-break: keep-all; }
    .article-body :global(ul), .article-body :global(ol) { padding-left: 20px; margin-bottom: 14px; }
    .article-body :global(li) { margin-bottom: 5px; word-break: keep-all; }
    .article-body :global(code) { max-width: 100%; min-width: 0; overflow: auto; }
    .article-body :global(pre) { max-width: 100%; min-width: 0; overflow: auto; }

    /* Related chips */
    .related-list { display: flex; gap: 8px; flex-wrap: wrap; }

    .related-link {
        background: transparent;
        border: 1px solid var(--color-border);
        padding: 5px 14px;
        border-radius: 999px;
        font-size: 13px;
        color: var(--color-text);
        text-decoration: none;
        transition: background 0.15s ease, border-color 0.15s ease;
    }

    .related-link:hover {
        background: color-mix(in srgb, var(--color-wiki) 12%, transparent);
        border-color: var(--color-wiki);
    }

    .doc-meta {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        margin-top: 28px;
        padding-top: 16px;
        border-top: 1px solid var(--color-border);
    }

    .doc-meta-item {
        font-size: 11px;
        color: var(--color-text-muted);
        font-variant-numeric: tabular-nums;
        letter-spacing: 0.04em;
        opacity: 0.6;
    }

    @media (max-width: 640px) {
        .wiki-article { padding-top: 12px; }
        h1 { font-size: 2.35rem; }
        .article-meta { align-items: stretch; gap: 8px 12px; }
        .article-share-header { width: 100%; margin-left: 0; }
        .article-body :global(.prose-card) { padding: 16px 18px; }
        .info-card { padding: 16px 18px; }
    }
</style>
