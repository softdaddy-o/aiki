---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BackLinks from '../../../components/BackLinks.astro';
import FactCheck from '../../../components/FactCheck.astro';
import ModelProfile from '../../../components/ModelProfile.astro';
import SocialShare from '../../../components/SocialShare.astro';
import TechStackMap from '../../../components/TechStackMap.tsx';
import wikiTermsJson from '../../../../data/wiki-terms.json';

const categoryLabels: Record<string, string> = {
    concept: '개념',
    technique: '기법',
    framework: '프레임워크',
    tool: '도구',
    model: '모델',
};

export async function getStaticPaths() {
    const entries = await getCollection('wiki', ({ data }) => data.lang === 'ko' && !data.draft);
    return entries.map(entry => ({
        params: { slug: entry.id.replace(/^ko\//, '') },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const fc = entry.data.factCheck;
const allWikiEntries = await getCollection('wiki', ({ data }) => data.lang === 'ko' && !data.draft);

const techStackTerms = wikiTermsJson.map((t: any) => ({
    slug: t.term,
    title: t.title,
    category: t.category,
}));

const parentEntry = entry.data.parentModel
    ? allWikiEntries.find((candidate) => candidate.data.term === entry.data.parentModel)
    : null;

const childEntries = allWikiEntries
    .filter((candidate) => candidate.data.parentModel === entry.data.term)
    .sort((a, b) => a.data.title.localeCompare(b.data.title, 'en'));

const wikiBacklinks = allWikiEntries
    .filter((candidate) =>
        candidate.data.term !== entry.data.term
        && (
            candidate.data.relatedTerms.includes(entry.data.term)
            || candidate.data.parentModel === entry.data.term
        ))
    .sort((a, b) => b.data.mentionCount - a.data.mentionCount || a.data.title.localeCompare(b.data.title, 'en'));
const shareUrl = Astro.url.href;
---

<BaseLayout title={entry.data.title}>
    <article class="wiki-article">
        <div class="article-meta">
            <span class="category-badge">{categoryLabels[entry.data.category]}</span>
            {entry.data.mentionCount > 0 && (
                <span class="mention-count">{entry.data.mentionCount}회 언급</span>
            )}
        </div>
        <h1>{entry.data.title}</h1>
        {entry.data.category === 'model' && entry.data.modelType === 'version' && entry.data.modelProfile && (
            <ModelProfile profile={entry.data.modelProfile} />
        )}

        <p class="wiki-summary">{entry.data.summary}</p>

        {entry.data.category === 'model' && parentEntry && (
            <div class="model-hierarchy">
                <h3>상위 모델</h3>
                <div class="related-list">
                    <a href={`/ko/wiki/${parentEntry.data.term}/`} class="related-link">{parentEntry.data.title}</a>
                </div>
            </div>
        )}

        {entry.data.category === 'model' && childEntries.length > 0 && (
            <div class="model-hierarchy">
                <h3>버전 페이지</h3>
                <div class="related-list">
                    {childEntries.map((child) => (
                        <a href={`/ko/wiki/${child.data.term}/`} class="related-link">{child.data.title}</a>
                    ))}
                </div>
            </div>
        )}

        {entry.data.aliases.length > 0 && (
            <div class="aliases">
                <span class="aliases-label">다른 이름:</span>
                {entry.data.aliases.map(alias => (
                    <span class="alias">{alias}</span>
                ))}
            </div>
        )}

        <div class="tech-stack-section">
            <h3 style="font-size: 14px; color: var(--color-text-muted); margin-bottom: 8px;">📍 AI 기술 맵에서의 위치</h3>
            <TechStackMap
                client:visible
                activeTerm={entry.data.term.toLowerCase()}
                terms={techStackTerms}
            />
        </div>

        <div class="article-body prose">
            <Content />
        </div>

        {entry.data.relatedTerms.length > 0 && (
            <div class="related-terms">
                <h3>관련 용어</h3>
                <div class="related-list">
                    {entry.data.relatedTerms.map(term => (
                        <a href={`/ko/wiki/${term}/`} class="related-link">{term}</a>
                    ))}
                </div>
            </div>
        )}

        {wikiBacklinks.length > 0 && (
            <div class="related-terms">
                <h3>이 항목을 참조하는 위키</h3>
                <div class="related-list">
                    {wikiBacklinks.map((refEntry) => (
                        <a href={`/ko/wiki/${refEntry.data.term}/`} class="related-link">{refEntry.data.title}</a>
                    ))}
                </div>
            </div>
        )}

        <BackLinks term={entry.data.term.toLowerCase()} minScore={40} />
        <SocialShare
            title={entry.data.title}
            text={entry.data.summary}
            url={shareUrl}
        />
        {fc && (
            <FactCheck
                status={fc.status}
                date={fc.date}
                checks={fc.checks}
                sources={fc.sources}
                lang="ko"
            />
        )}
    </article>
</BaseLayout>

<style>
    .wiki-article { max-width: 680px; margin: 0 auto; }
    .article-meta {
        display: flex; gap: 10px; align-items: center;
        margin-bottom: 12px;
    }
    .category-badge {
        background: var(--color-wiki);
        color: #000;
        padding: 2px 10px;
        border-radius: 4px;
        font-size: 12px;
        font-weight: bold;
    }
    .mention-count {
        color: var(--color-text-muted);
        font-size: 12px;
    }
    h1 { font-size: 28px; font-weight: 800; margin-bottom: 16px; line-height: 1.35; letter-spacing: -0.01em; }
    .wiki-summary {
        font-size: 15px;
        color: var(--color-text-muted);
        margin-bottom: 16px;
        line-height: 1.6;
    }
    .aliases {
        display: flex;
        gap: 6px;
        align-items: center;
        flex-wrap: wrap;
        margin-bottom: 20px;
    }
    .model-hierarchy {
        margin: 20px 0 24px;
    }
    .model-hierarchy h3 {
        font-size: 16px;
        margin-bottom: 10px;
    }
    .aliases-label {
        font-size: 12px;
        color: var(--color-text-muted);
    }
    .alias {
        background: var(--color-surface-alt);
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 12px;
        color: var(--color-text-muted);
    }
    .tech-stack-section {
        margin-bottom: 24px;
    }
    .article-body { font-size: 15px; line-height: 1.8; }
    .article-body :global(p) { margin-bottom: 12px; }
    .article-body :global(ul), .article-body :global(ol) { padding-left: 20px; margin-bottom: 12px; }
    .article-body :global(li) { margin-bottom: 4px; }
    .article-body :global(h2) { font-size: 18px; margin: 24px 0 12px; }
    .article-body :global(h3) { font-size: 16px; margin: 20px 0 8px; }
    .related-terms {
        border-top: 1px solid #333;
        margin-top: 32px;
        padding-top: 20px;
    }
    .related-terms h3 {
        font-size: 16px;
        margin-bottom: 10px;
    }
    .related-list {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }
    .related-link {
        background: var(--color-surface);
        border: 1px solid var(--color-wiki);
        padding: 4px 12px;
        border-radius: 4px;
        font-size: 13px;
        color: var(--color-wiki);
        text-decoration: none;
    }
    .related-link:hover {
        background: var(--color-surface-alt);
    }
</style>
