---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BackLinks from '../../../components/BackLinks.astro';
import FactCheck from '../../../components/FactCheck.astro';
import ModelProfile from '../../../components/ModelProfile.astro';
import SocialShare from '../../../components/SocialShare.astro';
import TechStackMap from '../../../components/TechStackMap.tsx';
import wikiTermsJson from '../../../../data/wiki-terms.json';

const categoryLabels: Record<string, string> = {
    concept: '개념',
    technique: '기법',
    framework: '프레임워크',
    tool: '도구',
    model: '모델',
};

export async function getStaticPaths() {
    const entries = await getCollection('wiki', ({ data }) => data.lang === 'ko' && !data.draft);
    return entries.map(entry => ({
        params: { slug: entry.id.replace(/^ko\//, '') },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const fc = entry.data.factCheck;
const allWikiEntries = await getCollection('wiki', ({ data }) => data.lang === 'ko' && !data.draft);

const techStackTerms = wikiTermsJson.map((t: any) => ({
    slug: t.term,
    title: t.title,
    category: t.category,
}));

const parentEntry = entry.data.parentModel
    ? allWikiEntries.find((candidate) => candidate.data.term === entry.data.parentModel)
    : null;

const childEntries = allWikiEntries
    .filter((candidate) => candidate.data.parentModel === entry.data.term)
    .sort((a, b) => a.data.title.localeCompare(b.data.title, 'en'));

const wikiBacklinks = allWikiEntries
    .filter((candidate) =>
        candidate.data.term !== entry.data.term
        && (
            candidate.data.relatedTerms.includes(entry.data.term)
            || candidate.data.parentModel === entry.data.term
        ))
    .sort((a, b) => b.data.mentionCount - a.data.mentionCount || a.data.title.localeCompare(b.data.title, 'en'));
const shareUrl = Astro.url.href;
const ogImage = `/og/wiki/${entry.data.term}.png`;
---

<BaseLayout title={entry.data.title} description={entry.data.summary} ogImage={ogImage} ogType="article">
    <article class="wiki-article">
        <div class="article-meta">
            <div class="article-meta-primary">
                <span class="category-badge">{categoryLabels[entry.data.category]}</span>
                {entry.data.mentionCount > 0 && (
                    <span class="mention-count">{entry.data.mentionCount}회 언급</span>
                )}
            </div>
            <div class="article-share article-share-header">
                <SocialShare
                    title={entry.data.title}
                    text={entry.data.summary}
                    url={shareUrl}
                    iconOnly={true}
                />
            </div>
        </div>
        <h1>{entry.data.title}</h1>
        {entry.data.aliases.length > 0 && (
            <div class="aliases">
                <span class="aliases-label">다른 이름:</span>
                {entry.data.aliases.map(alias => (
                    <span class="alias">{alias}</span>
                ))}
            </div>
        )}
        {entry.data.category === 'model' && entry.data.modelType === 'version' && entry.data.modelProfile && (
            <ModelProfile profile={entry.data.modelProfile} />
        )}

        <p class="wiki-summary">{entry.data.summary}</p>

        {entry.data.category === 'model' && parentEntry && (
            <div class="model-hierarchy">
                <h3>상위 모델</h3>
                <div class="related-list">
                    <a href={`/ko/wiki/${parentEntry.data.term}/`} class="related-link">{parentEntry.data.title}</a>
                </div>
            </div>
        )}

        {entry.data.category === 'model' && childEntries.length > 0 && (
            <div class="model-hierarchy">
                <h3>버전 페이지</h3>
                <div class="related-list">
                    {childEntries.map((child) => (
                        <a href={`/ko/wiki/${child.data.term}/`} class="related-link">{child.data.title}</a>
                    ))}
                </div>
            </div>
        )}

        <div class="tech-stack-section">
            <h3 class="tech-stack-title">전체 AI 기술 맵에서의 위치</h3>
            <TechStackMap
                client:visible
                activeTerm={entry.data.term.toLowerCase()}
                terms={techStackTerms}
            />
        </div>

        <div class="article-body prose">
            <Content />
        </div>

        {entry.data.relatedTerms.length > 0 && (
            <div class="related-terms">
                <h3>관련 용어</h3>
                <div class="related-list">
                    {entry.data.relatedTerms.map(term => (
                        <a href={`/ko/wiki/${term}/`} class="related-link">{term}</a>
                    ))}
                </div>
            </div>
        )}

        {wikiBacklinks.length > 0 && (
            <div class="related-terms">
                <h3>이 항목을 참조하는 위키</h3>
                <div class="related-list">
                    {wikiBacklinks.map((refEntry) => (
                        <a href={`/ko/wiki/${refEntry.data.term}/`} class="related-link">{refEntry.data.title}</a>
                    ))}
                </div>
            </div>
        )}

        <BackLinks term={entry.data.term.toLowerCase()} minScore={40} />
        {fc && (
            <FactCheck
                status={fc.status}
                date={fc.date}
                checks={fc.checks}
                sources={fc.sources}
                lang="ko"
            />
        )}
    </article>
</BaseLayout>

<style>
    .wiki-article { max-width: 720px; margin: 0 auto; padding-top: 20px; }

    .article-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px 14px;
        margin-bottom: 18px;
        padding-bottom: 14px;
        border-bottom: 1px solid var(--color-border);
    }

    .article-meta-primary {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
        min-width: 0;
    }

    .category-badge {
        background: var(--color-wiki);
        color: #000;
        padding: 3px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.02em;
    }

    .mention-count {
        color: var(--color-text-muted);
        font-size: 12px;
        font-variant-numeric: tabular-nums;
    }

    h1 {
        font-size: clamp(26px, 4.2vw, 34px);
        font-weight: 800;
        margin-bottom: 12px;
        line-height: 1.28;
        letter-spacing: -0.015em;
        word-break: keep-all;
        overflow-wrap: anywhere;
    }

    .wiki-summary {
        font-size: 16px;
        color: var(--color-text-muted);
        margin: 0 0 18px;
        line-height: 1.7;
        word-break: keep-all;
    }

    .article-share-header {
        margin-left: auto;
    }

    .aliases {
        display: flex;
        gap: 6px;
        align-items: center;
        flex-wrap: wrap;
        margin: 0 0 18px;
    }

    .model-hierarchy {
        margin: 22px 0 26px;
    }

    .model-hierarchy h3 {
        font-size: 14px;
        margin-bottom: 10px;
        color: var(--color-text-muted);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .aliases-label {
        font-size: 12px;
        color: var(--color-text-muted);
    }

    .alias {
        background: var(--color-surface-alt);
        border: 1px solid var(--color-border);
        padding: 3px 10px;
        border-radius: 999px;
        font-size: 12px;
        color: var(--color-text-muted);
    }

    .tech-stack-section {
        margin-bottom: 28px;
    }

    .tech-stack-title {
        font-size: 13px;
        color: var(--color-text-muted);
        margin-bottom: 10px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .article-body { font-size: 16px; line-height: 1.82; }
    .article-body :global(p) { margin-bottom: 14px; word-break: keep-all; }
    .article-body :global(ul), .article-body :global(ol) { padding-left: 20px; margin-bottom: 14px; }
    .article-body :global(li) { margin-bottom: 5px; word-break: keep-all; }
    .article-body :global(h2) {
        font-size: 20px;
        margin: 32px 0 12px;
        letter-spacing: -0.01em;
    }
    .article-body :global(h3) {
        font-size: 17px;
        margin: 24px 0 8px;
    }
    .article-body :global(code) {
        max-width: 100%;
        min-width: 0;
        overflow: auto;
    }
    .article-body :global(pre) {
        max-width: 100%;
        min-width: 0;
        overflow: auto;
    }

    .related-terms {
        border-top: 1px solid var(--color-border);
        margin-top: 36px;
        padding-top: 22px;
    }

    .related-terms h3 {
        font-size: 13px;
        margin-bottom: 12px;
        color: var(--color-text-muted);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .related-list {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .related-link {
        background: var(--color-surface);
        border: 1px solid color-mix(in srgb, var(--color-wiki) 55%, transparent);
        padding: 5px 14px;
        border-radius: 999px;
        font-size: 13px;
        color: var(--color-wiki);
        text-decoration: none;
        transition: background 0.15s ease, border-color 0.15s ease;
    }

    .related-link:hover {
        background: color-mix(in srgb, var(--color-wiki) 14%, transparent);
        border-color: var(--color-wiki);
    }

    @media (max-width: 640px) {
        .wiki-article { padding-top: 12px; }
        .article-meta {
            align-items: stretch;
            gap: 8px 12px;
        }
        .article-share-header {
            width: 100%;
            margin-left: 0;
        }
    }
</style>
