---
import { getCollection, render } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import FactCheck from '../../../components/FactCheck.astro';
import ScoreBadge from '../../../components/ScoreBadge.astro';
import SocialShare from '../../../components/SocialShare.astro';

export async function getStaticPaths() {
    const entries = await getCollection('news', ({ data }) => data.lang === 'ko' && !data.draft);
    return entries.map(entry => ({
        params: { slug: entry.id.replace(/^ko\//, '') },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const lang = 'ko';
const fc = entry.data.factCheck;
const slug = entry.id.replace(/^ko\//, '');
const externalOgImagePath = path.join(process.cwd(), 'public', 'og', 'news', `${slug}.jpg`);
const fallbackOgImagePath = path.join(process.cwd(), 'public', 'og', 'news-fallback', `${slug}.png`);
const ogImage = fs.existsSync(externalOgImagePath)
    ? `/og/news/${slug}.jpg`
    : fs.existsSync(fallbackOgImagePath)
        ? `/og/news-fallback/${slug}.png`
        : '/og/site-default.png';
const shareUrl = Astro.url.href;
---

<BaseLayout title={entry.data.title} description={entry.data.summary} ogImage={ogImage} ogImageAlt={entry.data.title} ogType="article">
    <article class="news-article">
        <div class="article-meta">
            <span class="article-date">{entry.data.date.split('T')[0]}</span>
            <ScoreBadge score={entry.data.score} sourceCount={entry.data.sourceCount} />
            {entry.data.sourceUrl && (
                <a
                    href={entry.data.sourceUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="article-source"
                    data-link-kind="external"
                >
                    📎 {entry.data.sourceTitle ?? '원문'}
                </a>
            )}
        </div>
        <h1>{entry.data.title}</h1>
        <div class="article-cover">
            <img src={ogImage} alt={entry.data.title} loading="eager" decoding="async" />
        </div>
        <SocialShare
            title={entry.data.title}
            text={entry.data.summary}
            url={shareUrl}
        />
        <div class="article-body prose">
            <Content />
        </div>
        {entry.data.tags.length > 0 && (
            <div class="article-tags">
                {entry.data.tags.map(tag => (
                    <span class="tag">#{tag}</span>
                ))}
            </div>
        )}
        {fc && (
            <FactCheck
                status={fc.status}
                date={fc.date}
                checks={fc.checks}
                sources={fc.sources}
                lang={lang}
            />
        )}
    </article>
</BaseLayout>

<style>
    .news-article { max-width: 680px; margin: 0 auto; padding-top: 16px; }
    .article-meta {
        display: flex; justify-content: space-between; align-items: center;
        flex-wrap: wrap; gap: 8px;
        margin-bottom: 16px; font-size: 13px; color: var(--color-text-muted);
    }
    .article-source {
        color: var(--color-news);
        text-decoration: none;
    }
    .article-source::after {
        content: '↗';
        display: inline-block;
        margin-left: 0.28em;
        font-size: 0.78em;
        line-height: 1;
        vertical-align: text-top;
    }
    h1 { font-size: 28px; font-weight: 800; margin-bottom: 24px; line-height: 1.35; letter-spacing: -0.01em; }
    .article-cover {
        margin-bottom: 20px;
        border-radius: 14px;
        overflow: hidden;
        border: 1px solid var(--color-border);
        background: var(--color-surface-alt);
        box-shadow: 0 12px 28px rgba(0, 0, 0, 0.12);
    }
    .article-cover img {
        width: 100%;
        aspect-ratio: 1200 / 630;
        display: block;
        object-fit: cover;
    }
    .article-body { font-size: 16px; line-height: 1.8; }
    .article-body :global(p) { margin-bottom: 12px; }
    .article-body :global(ul) { padding-left: 20px; margin-bottom: 12px; }
    .article-body :global(li) { margin-bottom: 4px; }
    .article-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 20px; }
    .tag {
        background: var(--color-surface-alt); padding: 4px 8px;
        border-radius: 4px; font-size: 12px; color: var(--color-text-muted);
    }
</style>
