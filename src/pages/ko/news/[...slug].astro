---
import { getCollection, render } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import FactCheck from '../../../components/FactCheck.astro';
import ScoreBadge from '../../../components/ScoreBadge.astro';
import SocialShare from '../../../components/SocialShare.astro';

export async function getStaticPaths() {
    const entries = await getCollection('news', ({ data }) => data.lang === 'ko' && !data.draft);
    return entries.map(entry => ({
        params: { slug: entry.id.replace(/^ko\//, '') },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const lang = 'ko';
const fc = entry.data.factCheck;
const slug = entry.id.replace(/^ko\//, '');
const externalOgImagePath = path.join(process.cwd(), 'public', 'og', 'news', `${slug}.jpg`);
const fallbackOgImagePath = path.join(process.cwd(), 'public', 'og', 'news-fallback', `${slug}.png`);
const hasExternalOg = fs.existsSync(externalOgImagePath);
const hasFallbackOg = fs.existsSync(fallbackOgImagePath);
const ogImage = hasExternalOg
    ? `/og/news/${slug}.jpg`
    : hasFallbackOg
        ? `/og/news-fallback/${slug}.png`
        : '/og/site-default.png';
const showCover = hasExternalOg || hasFallbackOg;
const shareUrl = Astro.url.href;
---

<BaseLayout title={entry.data.title} description={entry.data.summary} ogImage={ogImage} ogImageAlt={entry.data.title} ogType="article">
    <article class="news-article">
        <div class="article-meta">
            <div class="article-meta-primary">
                <span class="article-date">{entry.data.date.split('T')[0]}</span>
                <ScoreBadge score={entry.data.score} sourceCount={entry.data.sourceCount} />
                {entry.data.sourceUrl && (
                    <a
                        href={entry.data.sourceUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="article-source"
                        data-link-kind="external"
                    >
                        원문 {entry.data.sourceTitle ?? '보기'}
                    </a>
                )}
            </div>
            <div class="article-share article-share-header">
                <SocialShare
                    title={entry.data.title}
                    text={entry.data.summary}
                    url={shareUrl}
                    iconOnly={true}
                />
            </div>
        </div>
        <h1>{entry.data.title}</h1>

        <div class="news-lead-card">
            <p class="article-summary">{entry.data.summary}</p>
        </div>

        {showCover && (
            <div class="article-cover">
                <img src={ogImage} alt={entry.data.title} loading="eager" decoding="async" />
            </div>
        )}
        <div class="article-body prose">
            <Content />
        </div>
        {entry.data.tags.length > 0 && (
            <div class="info-card tags-card">
                <div class="card-kicker">태그</div>
                <div class="tags-list">
                    {entry.data.tags.map(tag => (
                        <span class="tag">#{tag}</span>
                    ))}
                </div>
            </div>
        )}
        <div class="doc-meta">
            <span class="doc-meta-item">포맷 v{entry.data.formatVersion}</span>
            {entry.data.guideVersion && (
                <span class="doc-meta-item">가이드 news {entry.data.guideVersion.news}</span>
            )}
        </div>

        {fc && (
            <FactCheck
                status={fc.status}
                date={fc.date}
                checks={fc.checks}
                sources={fc.sources}
                lang={lang}
            />
        )}
    </article>
</BaseLayout>

<script>
    const bodyEl = document.querySelector('.article-body');
    if (bodyEl) {
        const children = Array.from(bodyEl.children);
        bodyEl.innerHTML = '';
        let preamble: HTMLElement | null = null;
        let currentCard: HTMLElement | null = null;

        children.forEach(el => {
            if (el.tagName === 'H2') {
                currentCard = document.createElement('div');
                currentCard.className = 'prose-card';
                bodyEl.appendChild(currentCard);
                currentCard.appendChild(el);
            } else if (currentCard) {
                currentCard.appendChild(el);
            } else {
                if (!preamble) {
                    preamble = document.createElement('div');
                    preamble.className = 'prose-preamble';
                    bodyEl.insertBefore(preamble, bodyEl.firstChild);
                }
                preamble.appendChild(el);
            }
        });
    }
</script>

<style>
    .news-article { max-width: 720px; margin: 0 auto; padding-top: 20px; }

    .article-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px 14px;
        margin-bottom: 20px;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--color-border);
        font-size: 13px;
        color: var(--color-text-muted);
    }

    .article-meta-primary {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        min-width: 0;
    }

    .article-date {
        font-variant-numeric: tabular-nums;
        letter-spacing: 0.02em;
        color: var(--color-text-muted);
    }

    .article-source {
        color: var(--color-news);
        text-decoration: none;
        padding: 3px 10px;
        border: 1px solid color-mix(in srgb, var(--color-news) 45%, transparent);
        border-radius: 999px;
        font-size: 12px;
        line-height: 1.4;
        transition: background 0.15s ease, border-color 0.15s ease;
    }

    .article-source:hover {
        background: color-mix(in srgb, var(--color-news) 12%, transparent);
        border-color: var(--color-news);
    }

    .article-source::after {
        content: '↗';
        display: inline-block;
        margin-left: 0.28em;
        font-size: 0.78em;
        line-height: 1;
        vertical-align: text-top;
    }

    h1 {
        font-size: clamp(26px, 4.2vw, 34px);
        font-weight: 800;
        margin-bottom: 12px;
        line-height: 1.28;
        letter-spacing: -0.015em;
        word-break: keep-all;
        overflow-wrap: anywhere;
    }

    /* Lead card */
    .news-lead-card {
        border-left: 3px solid var(--color-news);
        background: color-mix(in srgb, var(--color-news) 7%, var(--color-surface));
        border-radius: 0 10px 10px 0;
        padding: 16px 20px;
        margin-bottom: 20px;
    }

    .article-summary {
        margin: 0;
        color: var(--color-text);
        font-size: 16px;
        line-height: 1.72;
        word-break: keep-all;
    }

    /* Generic info card */
    .info-card {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 12px;
        padding: 18px 20px;
        margin-top: 10px;
    }

    .card-kicker {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--color-text-muted);
        margin-bottom: 12px;
    }

    .tags-list { display: flex; gap: 6px; flex-wrap: wrap; }

    .article-share-header {
        margin-left: auto;
    }

    .article-cover {
        margin-bottom: 26px;
        border-radius: 14px;
        overflow: hidden;
        border: 1px solid var(--color-border);
        background: var(--color-surface-alt);
        box-shadow: 0 14px 34px rgba(0, 0, 0, 0.16);
    }

    .article-cover img {
        width: 100%;
        aspect-ratio: 1200 / 630;
        display: block;
        object-fit: cover;
        max-width: 100%;
    }

    .article-body { font-size: 16.5px; line-height: 1.82; margin-bottom: 0; }

    /* Section cards (injected by script) */
    .article-body :global(.prose-preamble p) { margin-bottom: 14px; word-break: keep-all; }

    .article-body :global(.prose-card) {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 12px;
        padding: 20px 24px;
        margin-bottom: 10px;
    }

    .article-body :global(.prose-card h2) {
        font-size: 19px;
        font-weight: 800;
        margin: 0 0 16px;
        padding-bottom: 13px;
        border-bottom: 2px solid color-mix(in srgb, var(--color-news) 35%, var(--color-border));
        letter-spacing: -0.02em;
        word-break: keep-all;
        color: var(--color-text);
        line-height: 1.3;
    }

    .article-body :global(.prose-card h3) { font-size: 15px; font-weight: 600; margin: 18px 0 8px; }
    .article-body :global(.prose-card p) { margin-bottom: 12px; word-break: keep-all; }
    .article-body :global(.prose-card p:last-child) { margin-bottom: 0; }
    .article-body :global(.prose-card ul) { padding-left: 18px; margin-bottom: 12px; }
    .article-body :global(.prose-card li) { margin-bottom: 5px; word-break: keep-all; }
    .article-body :global(.prose-card code) { max-width: 100%; min-width: 0; overflow: auto; }
    .article-body :global(.prose-card pre) { max-width: 100%; min-width: 0; overflow: auto; }

    /* Fallback (no-JS / SSR) */
    .article-body :global(p) { margin-bottom: 14px; word-break: keep-all; }
    .article-body :global(ul) { padding-left: 20px; margin-bottom: 14px; }
    .article-body :global(li) { margin-bottom: 5px; word-break: keep-all; }
    .article-body :global(h2) { font-size: 20px; margin: 32px 0 12px; letter-spacing: -0.01em; }
    .article-body :global(h3) { font-size: 17px; margin: 24px 0 8px; }
    .article-body :global(code) { max-width: 100%; min-width: 0; overflow: auto; }
    .article-body :global(pre) { max-width: 100%; min-width: 0; overflow: auto; }

    .tag {
        background: var(--color-surface-alt);
        border: 1px solid var(--color-border);
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 12px;
        color: var(--color-text-muted);
        transition: border-color 0.15s ease, color 0.15s ease;
    }

    .tag:hover {
        border-color: var(--color-news);
        color: var(--color-text);
    }

    .doc-meta {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        margin-top: 28px;
        padding-top: 16px;
        border-top: 1px solid var(--color-border);
    }

    .doc-meta-item {
        font-size: 11px;
        color: var(--color-text-muted);
        font-variant-numeric: tabular-nums;
        letter-spacing: 0.04em;
        opacity: 0.6;
    }

    @media (max-width: 640px) {
        .news-article { padding-top: 12px; }
        .article-meta {
            align-items: stretch;
            gap: 8px 12px;
        }
        .article-share-header {
            width: 100%;
            margin-left: 0;
        }
    }
</style>
