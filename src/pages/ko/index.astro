---
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const lang = 'ko';
const newsOgDir = join(process.cwd(), 'public', 'og', 'news');

const allNews = await getCollection('news', ({ data }) => data.lang === lang && !data.draft);
const allWiki = await getCollection('wiki', ({ data }) => data.lang === lang && !data.draft);
const allProjects = await getCollection('projects', ({ data }) => data.lang === lang && !data.draft);

const sortedNews = [...allNews].sort((a, b) => {
    const dateDiff = new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
    return dateDiff || (b.data.score ?? 0) - (a.data.score ?? 0);
});
const latestNewsDay = sortedNews[0]?.data.date.split('T')[0] ?? '';
const todayNews = sortedNews
    .filter((entry) => entry.data.date.startsWith(latestNewsDay))
    .sort((a, b) => (b.data.score ?? 0) - (a.data.score ?? 0))
    .slice(0, 4);
const backupNews = sortedNews.slice(0, 4);
const briefingNews = todayNews.length >= 3 ? todayNews : backupNews;

const trendingTerms = [...allWiki]
    .sort((a, b) => {
        const mentionDiff = (b.data.mentionCount ?? 0) - (a.data.mentionCount ?? 0);
        return mentionDiff || a.data.title.localeCompare(b.data.title, 'ko');
    })
    .slice(0, 9);

const trendingProjects = [...allProjects]
    .filter((project) => project.data.contentStatus === 'final')
    .sort((a, b) => {
        const aMetric = a.data.sourceMetric ?? a.data.stars ?? 0;
        const bMetric = b.data.sourceMetric ?? b.data.stars ?? 0;
        return bMetric - aMetric || a.data.title.localeCompare(b.data.title, 'ko');
    })
    .slice(0, 4);

function newsSlug(entry: (typeof allNews)[number]): string {
    return entry.id.replace(/^ko\//, '');
}

function wikiSlug(entry: (typeof allWiki)[number]): string {
    return entry.id.replace(/^ko\//, '');
}

function getNewsImage(slug: string): string | null {
    const filename = `${slug}.jpg`;
    return existsSync(join(newsOgDir, filename)) ? `/og/news/${filename}` : null;
}

function formatDay(dateStr: string): string {
    const date = new Date(dateStr);
    return new Intl.DateTimeFormat('ko-KR', { month: 'numeric', day: 'numeric', weekday: 'short' }).format(date);
}

function formatMetric(value: number | undefined): string {
    const metric = Number(value || 0);
    if (metric >= 1000) return `${Math.round(metric / 100) / 10}k`;
    return `${metric}`;
}

const latestDayLabel = latestNewsDay ? formatDay(`${latestNewsDay}T12:00:00Z`) : '오늘';
---

<BaseLayout
    title="AIKI"
    description="오늘 볼 AI 뉴스, 트렌딩 용어, 프로젝트를 한 화면에서 잡는 AI 브리핑."
>
    <div class="landing-brief">
        <section class="brief-hero" aria-labelledby="brief-title">
            <div class="brief-hero-copy">
                <p class="brief-eyebrow">AIKI Daily</p>
                <h1 id="brief-title">오늘 볼 AI 흐름</h1>
                <p>
                    뉴스는 빠르게, 용어는 짧게, 프로젝트는 써먹을 기준만. 지금 AI 판에서 움직이는 것부터 잡아.
                </p>
            </div>
            <div class="brief-hero-actions" aria-label="주요 이동">
                <a href="/ko/news/" class="primary-link">뉴스 보기</a>
                <a href="/ko/about/" class="secondary-link">AIKI 기준</a>
            </div>
            <div class="brief-snapshot" aria-label="AIKI 콘텐츠 현황">
                <span><strong>{allNews.length}+</strong> 뉴스</span>
                <span><strong>{allWiki.length}+</strong> 용어</span>
                <span><strong>{allProjects.length}+</strong> 프로젝트</span>
            </div>
        </section>

        <section class="brief-dashboard" aria-label="오늘 AIKI 브리핑">
            <div class="brief-main-panel">
                <div class="section-heading">
                    <div>
                        <span class="section-kicker">{latestDayLabel}</span>
                        <h2>오늘 뉴스</h2>
                    </div>
                    <a href="/ko/news/">전체 보기</a>
                </div>

                <div class="news-tiles">
                    {briefingNews.map((entry, index) => {
                        const slug = newsSlug(entry);
                        const image = getNewsImage(slug);
                        return (
                            <a href={`/ko/news/${slug}/`} class:list={['news-tile', { featured: index === 0 }]}>
                                {image ? (
                                    <img src={image} alt="" loading={index === 0 ? 'eager' : 'lazy'} />
                                ) : (
                                    <span class="news-image-fallback" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
                                )}
                                <span class="news-copy">
                                    <span class="news-meta">
                                        <span>{formatDay(entry.data.date)}</span>
                                        <span>{entry.data.score ?? 0}점</span>
                                    </span>
                                    <strong>{entry.data.title}</strong>
                                    <span>{entry.data.summary}</span>
                                </span>
                            </a>
                        );
                    })}
                </div>
            </div>

            <aside class="term-panel" aria-labelledby="terms-title">
                <div class="section-heading compact">
                    <div>
                        <span class="section-kicker">Trending terms</span>
                        <h2 id="terms-title">지금 같이 볼 용어</h2>
                    </div>
                    <a href="/ko/wiki/">위키</a>
                </div>
                <div class="term-list">
                    {trendingTerms.map((entry, index) => (
                        <a href={`/ko/wiki/${wikiSlug(entry)}/`} class="term-row">
                            <span>{String(index + 1).padStart(2, '0')}</span>
                            <strong>{entry.data.title}</strong>
                            <small>{entry.data.mentionCount ?? 0}회 언급</small>
                        </a>
                    ))}
                </div>
            </aside>
        </section>

        <section class="project-brief" aria-labelledby="project-title">
            <div class="section-heading">
                <div>
                    <span class="section-kicker">Project radar</span>
                    <h2 id="project-title">도입 후보 프로젝트</h2>
                </div>
                <a href="/ko/projects/">쇼케이스 전체</a>
            </div>

            <div class="project-strip">
                {trendingProjects.map((project) => (
                    <a href={`/ko/projects/${project.data.slug}/`} class="project-card">
                        <span class="project-type">{project.data.category}</span>
                        <strong>{project.data.title}</strong>
                        <span>{project.data.summary}</span>
                        <span class="project-meta">
                            <span>★ {formatMetric(project.data.sourceMetric ?? project.data.stars)}</span>
                            <span>{project.data.license}</span>
                            <span>{project.data.version}</span>
                        </span>
                    </a>
                ))}
            </div>
        </section>

        <section class="newsletter-section" aria-label="뉴스레터 사전 등록">
            <div>
                <span class="section-kicker">Newsletter</span>
                <h2>하루 흐름만 압축해서 받아봐</h2>
            </div>
            <button type="button" class="newsletter-btn" id="newsletter-trigger">사전 등록</button>
        </section>
    </div>
</BaseLayout>

<script is:inline src="https://tally.so/widgets/embed.js"></script>
<script is:inline>
    document.getElementById('newsletter-trigger')?.addEventListener('click', function() {
        if (typeof Tally !== 'undefined') {
            Tally.openPopup('kdR9bZ', {
                width: 400,
                emoji: { text: '\u{1F4EC}', animation: 'wave' },
            });
        } else {
            window.open('https://tally.so/r/kdR9bZ', '_blank');
        }
    });
</script>

<style>
    .landing-brief {
        display: grid;
        gap: 18px;
        max-width: 1120px;
        margin: 0 auto;
    }

    .brief-hero,
    .brief-main-panel,
    .term-panel,
    .project-brief,
    .newsletter-section {
        border: 1px solid var(--color-border);
        background: color-mix(in srgb, var(--color-surface-elevated) 82%, transparent);
        box-shadow: var(--shadow-card);
        backdrop-filter: blur(22px) saturate(145%);
    }

    .brief-hero {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 24px;
        min-height: 350px;
        padding: 42px;
        border-radius: var(--radius-xl);
        position: relative;
        overflow: hidden;
    }

    .brief-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
            radial-gradient(circle at 82% 18%, rgba(123, 228, 221, 0.24), transparent 28%),
            radial-gradient(circle at 8% 100%, rgba(255, 140, 122, 0.16), transparent 30%),
            linear-gradient(118deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0) 42%);
        pointer-events: none;
    }

    .brief-hero-copy,
    .brief-hero-actions,
    .brief-snapshot {
        position: relative;
        z-index: 1;
    }

    .brief-hero-copy {
        align-self: center;
        max-width: 720px;
    }

    .brief-eyebrow,
    .section-kicker {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        margin: 0 0 12px;
        padding: 6px 11px;
        border-radius: 999px;
        background: color-mix(in srgb, var(--color-aiki-blue) 14%, transparent);
        color: color-mix(in srgb, var(--color-aiki-blue) 72%, var(--color-text) 28%);
        font-family: var(--font-heading);
        font-size: 0.72rem;
        font-weight: 900;
        letter-spacing: 0;
        text-transform: uppercase;
    }

    .brief-hero h1 {
        max-width: 760px;
        margin: 0;
        color: var(--color-text);
        font-family: var(--font-display);
        font-size: clamp(3.7rem, 9vw, 7rem);
        font-weight: 900;
        line-height: 0.9;
        letter-spacing: 0;
        overflow-wrap: anywhere;
    }

    .brief-hero p {
        max-width: 620px;
        margin: 18px 0 0;
        color: var(--color-text-muted);
        font-size: var(--text-xl);
        font-weight: 700;
        line-height: 1.55;
        word-break: keep-all;
    }

    .brief-hero-actions {
        align-self: start;
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .primary-link,
    .secondary-link,
    .section-heading a,
    .newsletter-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 42px;
        padding: 0 15px;
        border: 1px solid var(--color-border-strong);
        border-radius: 999px;
        color: var(--color-text);
        background: color-mix(in srgb, var(--color-surface-elevated) 78%, transparent);
        font: inherit;
        font-size: var(--text-sm);
        font-weight: 850;
        text-decoration: none;
        cursor: pointer;
        transition: background 0.16s ease, border-color 0.16s ease, color 0.16s ease;
    }

    .primary-link {
        border-color: color-mix(in srgb, var(--color-aiki-blue) 62%, transparent);
        background: color-mix(in srgb, var(--color-aiki-blue) 18%, var(--color-surface-elevated) 82%);
    }

    .primary-link:hover,
    .secondary-link:hover,
    .section-heading a:hover,
    .newsletter-btn:hover {
        border-color: var(--color-aiki-blue);
        color: var(--color-text);
        background: color-mix(in srgb, var(--color-aiki-blue) 14%, var(--color-surface-elevated) 86%);
    }

    .brief-snapshot {
        grid-column: 1 / -1;
        align-self: end;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
        max-width: 650px;
    }

    .brief-snapshot span {
        min-height: 72px;
        padding: 14px 16px;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        background: color-mix(in srgb, var(--color-surface-alt) 72%, transparent);
        color: var(--color-text-muted);
        font-size: var(--text-sm);
        font-weight: 750;
    }

    .brief-snapshot strong {
        display: block;
        color: var(--color-text);
        font-size: var(--text-2xl);
        line-height: 1.1;
    }

    .brief-dashboard {
        display: grid;
        grid-template-columns: minmax(0, 1.55fr) minmax(300px, 0.8fr);
        gap: 18px;
        align-items: stretch;
    }

    .brief-main-panel,
    .term-panel,
    .project-brief {
        padding: 22px;
        border-radius: var(--radius-lg);
    }

    .section-heading {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 16px;
    }

    .section-heading.compact {
        margin-bottom: 12px;
    }

    .section-heading h2,
    .newsletter-section h2 {
        margin: 0;
        color: var(--color-text);
        font-family: var(--font-heading);
        font-size: clamp(1.45rem, 3vw, 2.15rem);
        font-weight: 900;
        line-height: 1.08;
        letter-spacing: 0;
    }

    .news-tiles {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }

    .news-tile {
        min-width: 0;
        display: grid;
        grid-template-columns: 104px minmax(0, 1fr);
        gap: 12px;
        min-height: 148px;
        padding: 10px;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        background: color-mix(in srgb, var(--color-surface-alt) 68%, transparent);
        color: var(--color-text);
        text-decoration: none;
        transition: border-color 0.16s ease, transform 0.16s ease, background 0.16s ease;
    }

    .news-tile.featured {
        grid-column: 1 / -1;
        grid-template-columns: minmax(190px, 0.52fr) minmax(0, 1fr);
        min-height: 250px;
    }

    .news-tile:hover {
        border-color: color-mix(in srgb, var(--color-aiki-blue) 58%, var(--color-border) 42%);
        background: color-mix(in srgb, var(--color-aiki-blue) 8%, var(--color-surface-alt) 92%);
        transform: translateY(-2px);
    }

    .news-tile img,
    .news-image-fallback {
        width: 100%;
        height: 100%;
        min-height: 128px;
        object-fit: cover;
        border-radius: calc(var(--radius-md) - 6px);
        background:
            radial-gradient(circle at 70% 20%, rgba(123, 228, 221, 0.3), transparent 36%),
            linear-gradient(135deg, rgba(141, 181, 255, 0.32), rgba(255, 140, 122, 0.14));
    }

    .news-image-fallback {
        display: grid;
        place-items: center;
        color: var(--color-aiki-blue);
        font-family: var(--font-display);
        font-size: var(--text-3xl);
        font-weight: 900;
    }

    .news-copy {
        min-width: 0;
        display: grid;
        align-content: start;
        gap: 8px;
        padding: 4px 2px;
    }

    .news-meta {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        color: var(--color-text-muted);
        font-size: var(--text-xs);
        font-weight: 800;
    }

    .news-copy strong {
        color: var(--color-text);
        font-family: var(--font-heading);
        font-size: var(--text-xl);
        font-weight: 900;
        line-height: 1.18;
        word-break: keep-all;
    }

    .news-tile.featured .news-copy strong {
        font-size: clamp(1.7rem, 4vw, 2.9rem);
        line-height: 1.04;
    }

    .news-copy > span:last-child {
        color: var(--color-text-muted);
        font-size: var(--text-sm);
        font-weight: 650;
        line-height: 1.65;
        word-break: keep-all;
    }

    .term-list {
        display: grid;
        gap: 8px;
    }

    .term-row {
        display: grid;
        grid-template-columns: 34px minmax(0, 1fr) auto;
        gap: 10px;
        align-items: center;
        min-height: 52px;
        padding: 10px 12px;
        border: 1px solid transparent;
        border-radius: var(--radius-md);
        color: var(--color-text);
        text-decoration: none;
        background: color-mix(in srgb, var(--color-surface-alt) 58%, transparent);
        transition: background 0.16s ease, border-color 0.16s ease;
    }

    .term-row:hover {
        border-color: color-mix(in srgb, var(--color-wiki) 52%, var(--color-border) 48%);
        background: color-mix(in srgb, var(--color-wiki) 10%, var(--color-surface-alt) 90%);
    }

    .term-row span {
        color: var(--color-aiki-blue);
        font-family: var(--font-display);
        font-size: var(--text-sm);
        font-weight: 900;
    }

    .term-row strong {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-size: var(--text-base);
        font-weight: 850;
    }

    .term-row small {
        color: var(--color-text-muted);
        font-size: var(--text-xs);
        font-weight: 750;
        white-space: nowrap;
    }

    .project-strip {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
    }

    .project-card {
        display: grid;
        align-content: start;
        gap: 10px;
        min-height: 210px;
        padding: 18px;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        background: color-mix(in srgb, var(--color-surface-alt) 66%, transparent);
        color: var(--color-text);
        text-decoration: none;
        transition: border-color 0.16s ease, transform 0.16s ease, background 0.16s ease;
    }

    .project-card:hover {
        border-color: color-mix(in srgb, var(--color-projects) 58%, var(--color-border) 42%);
        background: color-mix(in srgb, var(--color-projects) 10%, var(--color-surface-alt) 90%);
        transform: translateY(-2px);
    }

    .project-type {
        width: fit-content;
        padding: 4px 8px;
        border-radius: 999px;
        background: color-mix(in srgb, var(--color-projects) 16%, transparent);
        color: color-mix(in srgb, var(--color-projects) 72%, var(--color-text) 28%);
        font-size: var(--text-xs);
        font-weight: 900;
        text-transform: uppercase;
    }

    .project-card strong {
        color: var(--color-text);
        font-family: var(--font-heading);
        font-size: var(--text-xl);
        font-weight: 900;
        line-height: 1.08;
    }

    .project-card > span:not(.project-type):not(.project-meta) {
        color: var(--color-text-muted);
        font-size: var(--text-sm);
        font-weight: 650;
        line-height: 1.65;
        word-break: keep-all;
    }

    .project-meta {
        align-self: end;
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: auto;
    }

    .project-meta span {
        padding: 4px 8px;
        border-radius: 999px;
        background: color-mix(in srgb, var(--color-surface-elevated) 78%, transparent);
        color: var(--color-text-muted);
        font-size: var(--text-xs);
        font-weight: 800;
    }

    .newsletter-section {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        padding: 24px;
        border-radius: var(--radius-lg);
    }

    .newsletter-btn {
        min-width: 120px;
    }

    html.dark .brief-hero::before {
        background:
            radial-gradient(circle at 82% 18%, rgba(123, 228, 221, 0.14), transparent 30%),
            radial-gradient(circle at 8% 100%, rgba(255, 140, 122, 0.09), transparent 32%),
            linear-gradient(118deg, rgba(255, 255, 255, 0.09), rgba(255, 255, 255, 0) 42%);
    }

    @media (max-width: 980px) {
        .brief-hero,
        .brief-dashboard,
        .project-strip {
            grid-template-columns: minmax(0, 1fr);
        }

        .brief-hero-actions {
            justify-content: flex-start;
        }

        .news-tiles {
            grid-template-columns: minmax(0, 1fr);
        }
    }

    @media (max-width: 640px) {
        .landing-brief {
            gap: 14px;
        }

        .brief-hero {
            min-height: 0;
            padding: 28px 22px;
            border-radius: 26px;
        }

        .brief-hero p {
            font-size: var(--text-base);
        }

        .brief-snapshot {
            grid-template-columns: minmax(0, 1fr);
        }

        .brief-main-panel,
        .term-panel,
        .project-brief {
            padding: 16px;
        }

        .section-heading {
            align-items: flex-start;
            flex-direction: column;
            gap: 10px;
        }

        .news-tile,
        .news-tile.featured {
            grid-template-columns: minmax(0, 1fr);
        }

        .news-tile img,
        .news-image-fallback {
            aspect-ratio: 16 / 9;
            min-height: 0;
        }

        .term-row {
            grid-template-columns: 28px minmax(0, 1fr);
        }

        .term-row small {
            grid-column: 2;
        }

        .newsletter-section {
            align-items: flex-start;
            flex-direction: column;
        }
    }
</style>
