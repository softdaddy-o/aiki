---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const lang = 'ko';

const newsCount = (await getCollection('news', ({ data }) => data.lang === lang && !data.draft)).length;
const wikiCount = (await getCollection('wiki', ({ data }) => data.lang === lang && !data.draft)).length;
const projectCount = (await getCollection('projects', ({ data }) => data.lang === lang && !data.draft)).length;
---

<BaseLayout>
    <div class="landing">
        <!-- Hero -->
        <section class="hero">
            <p class="hero-eyebrow">AI Knowledge & Intelligence</p>
            <h1 class="hero-title">AIKI</h1>
            <p class="hero-subtitle">AI 뉴스, 용어, 프로젝트 쇼케이스를 한 곳에서</p>
        </section>

        <!-- Category cards -->
        <section class="categories" aria-label="AIKI 카테고리">
            <a href="/ko/news/" class="category-card news-card">
                <div class="card-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h16a2 2 0 002-2V4a2 2 0 00-2-2H8a2 2 0 00-2 2v16a2 2 0 01-2 2zm0 0a2 2 0 01-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8m8-4h-8m5 8h-5"/></svg>
                </div>
                <div class="card-body">
                    <h2>AI 뉴스</h2>
                    <p>AI 업계 핵심 뉴스를 팩트체크해서 전달합니다. 매일 업데이트되는 타임라인에서 중요한 흐름을 놓치지 마세요.</p>
                    <span class="card-count">{newsCount}건의 기사</span>
                </div>
                <span class="card-arrow">&rarr;</span>
            </a>

            <a href="/ko/wiki/" class="category-card wiki-card">
                <div class="card-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>
                </div>
                <div class="card-body">
                    <h2>AI 위키</h2>
                    <p>AI 개념, 기법, 도구, 모델을 한국어로 정리합니다. 처음 접하는 용어부터 깊이 있는 해설까지.</p>
                    <span class="card-count">{wikiCount}개의 용어</span>
                </div>
                <span class="card-arrow">&rarr;</span>
            </a>

            <a href="/ko/projects/" class="category-card projects-card">
                <div class="card-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>
                </div>
                <div class="card-body">
                    <h2>프로젝트 쇼케이스</h2>
                    <p>AI 오픈소스 프로젝트를 인터랙티브 데모와 함께 살펴봅니다. 아키텍처부터 실행까지.</p>
                    <span class="card-count">{projectCount}개의 프로젝트</span>
                </div>
                <span class="card-arrow">&rarr;</span>
            </a>
        </section>

        <!-- Newsletter signup (Tally) -->
        <section class="newsletter-section" aria-label="뉴스레터 신청">
            <div class="newsletter-card">
                <h3>AIKI 소식 받기</h3>
                <p>새 콘텐츠가 나오면 이메일로 알려드립니다.</p>
                <button type="button" class="newsletter-btn" id="newsletter-trigger">이메일 등록</button>
            </div>
        </section>
    </div>
</BaseLayout>

<script is:inline src="https://tally.so/widgets/embed.js"></script>
<script is:inline>
    document.getElementById('newsletter-trigger')?.addEventListener('click', function() {
        if (typeof Tally !== 'undefined') {
            Tally.openPopup('kdR9bZ', {
                width: 400,
                emoji: { text: '\u{1F4EC}', animation: 'wave' },
            });
        } else {
            window.open('https://tally.so/r/kdR9bZ', '_blank');
        }
    });
</script>

<style>
    .landing {
        max-width: 800px;
        margin: 0 auto;
    }

    /* Hero */
    .hero {
        text-align: center;
        padding: 56px 0 48px;
    }

    .hero-eyebrow {
        margin: 0 0 12px;
        color: var(--color-text-muted);
        font-size: var(--text-sm);
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        animation: fadeUp 0.6s ease-out;
    }

    .hero-title {
        font-size: clamp(3.5rem, 10vw, 6rem);
        font-weight: 850;
        letter-spacing: -0.02em;
        background: linear-gradient(135deg, var(--color-news), var(--color-wiki), var(--color-projects));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 16px;
        line-height: 1;
        animation: fadeUp 0.6s ease-out 0.05s both;
    }

    .hero-subtitle {
        margin: 0;
        font-size: var(--text-xl);
        color: var(--color-text-muted);
        line-height: 1.5;
        animation: fadeUp 0.6s ease-out 0.1s both;
    }

    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Category cards */
    .categories {
        display: grid;
        gap: 16px;
        margin-bottom: 48px;
    }

    .category-card {
        display: grid;
        grid-template-columns: 56px 1fr 28px;
        align-items: center;
        gap: 18px;
        padding: 24px;
        border: 1px solid var(--color-border);
        border-radius: 12px;
        background: var(--color-surface);
        color: var(--color-text);
        text-decoration: none;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
        animation: fadeUp 0.5s ease-out both;
    }

    .category-card:nth-child(1) { animation-delay: 0.15s; }
    .category-card:nth-child(2) { animation-delay: 0.22s; }
    .category-card:nth-child(3) { animation-delay: 0.29s; }

    .category-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    }

    .news-card { border-left: 3px solid var(--color-news); }
    .news-card:hover { border-color: var(--color-news); }
    .news-card .card-icon { color: var(--color-news); background: color-mix(in srgb, var(--color-news) 12%, transparent); }
    .news-card .card-count { color: var(--color-news); }

    .wiki-card { border-left: 3px solid var(--color-wiki); }
    .wiki-card:hover { border-color: var(--color-wiki); }
    .wiki-card .card-icon { color: var(--color-wiki); background: color-mix(in srgb, var(--color-wiki) 12%, transparent); }
    .wiki-card .card-count { color: var(--color-wiki); }

    .projects-card { border-left: 3px solid var(--color-projects); }
    .projects-card:hover { border-color: var(--color-projects); }
    .projects-card .card-icon { color: var(--color-projects); background: color-mix(in srgb, var(--color-projects) 12%, transparent); }
    .projects-card .card-count { color: var(--color-projects); }

    .card-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 56px;
        height: 56px;
        border-radius: 12px;
        flex-shrink: 0;
    }

    .card-body {
        min-width: 0;
    }

    .card-body h2 {
        margin: 0 0 6px;
        font-size: var(--text-lg);
        font-weight: 750;
    }

    .card-body p {
        margin: 0 0 8px;
        color: var(--color-text-muted);
        font-size: var(--text-sm);
        line-height: 1.55;
    }

    .card-count {
        font-size: var(--text-xs);
        font-weight: 700;
    }

    .card-arrow {
        color: var(--color-text-muted);
        font-size: var(--text-xl);
        transition: transform 0.2s ease;
    }

    .category-card:hover .card-arrow {
        transform: translateX(4px);
    }

    /* Newsletter */
    .newsletter-section {
        margin-bottom: 48px;
        animation: fadeUp 0.5s ease-out 0.35s both;
    }

    .newsletter-card {
        text-align: center;
        padding: 32px 24px;
        border: 1px solid var(--color-border);
        border-radius: 12px;
        background: var(--color-surface);
    }

    .newsletter-card h3 {
        margin: 0 0 6px;
        font-size: var(--text-lg);
        font-weight: 750;
    }

    .newsletter-card p {
        margin: 0 0 16px;
        color: var(--color-text-muted);
        font-size: var(--text-sm);
    }

    .newsletter-btn {
        display: inline-flex;
        align-items: center;
        min-height: 40px;
        padding: 0 24px;
        border: 1px solid var(--color-border);
        border-radius: 8px;
        background: var(--color-surface-elevated);
        color: var(--color-text);
        font: inherit;
        font-size: var(--text-sm);
        font-weight: 700;
        cursor: pointer;
        transition: background 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
    }

    .newsletter-btn:hover {
        border-color: var(--color-news);
        background: color-mix(in srgb, var(--color-news) 10%, var(--color-surface));
        transform: translateY(-1px);
    }

    @media (max-width: 640px) {
        .hero { padding: 36px 0 32px; }
        .hero-subtitle { font-size: var(--text-lg); }

        .category-card {
            grid-template-columns: 44px 1fr 24px;
            gap: 14px;
            padding: 18px;
        }

        .card-icon {
            width: 44px;
            height: 44px;
            border-radius: 10px;
        }

        .card-icon svg {
            width: 22px;
            height: 22px;
        }
    }
</style>
