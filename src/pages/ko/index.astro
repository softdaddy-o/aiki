---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const lang = 'ko';

const newsCount = (await getCollection('news', ({ data }) => data.lang === lang && !data.draft)).length;
const wikiCount = (await getCollection('wiki', ({ data }) => data.lang === lang && !data.draft)).length;
const projectCount = (await getCollection('projects', ({ data }) => data.lang === lang && !data.draft)).length;
---

<BaseLayout>
    <div class="landing">
        <section class="hero">
            <div class="hero-copy">
                <p class="hero-eyebrow">Welcome to AIKI</p>
                <h1 class="hero-title">모든 AI 지식이 연결되는 곳</h1>
                <p class="hero-subtitle">모델, 뉴스, 개념, 프로젝트를 한 장의 지도처럼 연결해서 AI의 흐름을 감각적으로 따라갑니다.</p>
                <div class="hero-actions">
                    <a href="/ko/wiki/" class="hero-primary">지식 탐색 시작</a>
                    <a href="/ko/about/" class="hero-secondary">AIKI 소개</a>
                </div>
            </div>
            <div class="hero-visual" aria-hidden="true">
                <span class="aurora-line line-one"></span>
                <span class="aurora-line line-two"></span>
                <span class="constellation-dot dot-one"></span>
                <span class="constellation-dot dot-two"></span>
                <span class="constellation-dot dot-three"></span>
            </div>
            <div class="hero-stats" aria-label="AIKI 요약">
                <span><strong>{wikiCount}+</strong> 지식 문서</span>
                <span><strong>{newsCount}+</strong> 뉴스 흐름</span>
                <span><strong>{projectCount}+</strong> 프로젝트</span>
            </div>
        </section>

        <section class="categories" aria-label="AIKI 카테고리">
            <a href="/ko/news/" class="category-card news-card">
                <div class="card-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8m8-4h-8m5 8h-5"/></svg>
                </div>
                <div class="card-body">
                    <h2>AI 뉴스</h2>
                    <p>중요한 업데이트를 빠르게 읽고, 과장된 문장은 줄인 요약으로 흐름만 먼저 따라갑니다.</p>
                    <span class="card-count">{newsCount}개의 기사</span>
                </div>
                <span class="card-arrow">&rarr;</span>
            </a>

            <a href="/ko/wiki/" class="category-card wiki-card">
                <div class="card-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                </div>
                <div class="card-body">
                    <h2>AI 위키</h2>
                    <p>개념, 기법, 도구, 모델을 연결해서 정리합니다. 처음 보는 용어와 맥락을 빠르게 따라잡을 수 있습니다.</p>
                    <span class="card-count">{wikiCount}개의 용어</span>
                </div>
                <span class="card-arrow">&rarr;</span>
            </a>

            <a href="/ko/projects/" class="category-card projects-card">
                <div class="card-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                </div>
                <div class="card-body">
                    <h2>AI 쇼케이스</h2>
                    <p>직접 실행한 결과를 먼저 보고, 도입 판단에 필요한 설명과 검증 근거를 바로 이어서 확인합니다.</p>
                    <span class="card-count">{projectCount}개의 쇼케이스</span>
                </div>
                <span class="card-arrow">&rarr;</span>
            </a>
        </section>

        <section class="newsletter-section" aria-label="뉴스레터 사전 등록">
            <div class="newsletter-card">
                <h3>AIKI 뉴스레터, 곧 시작합니다.</h3>
                <p>첫 발송 전에 미리 자리 맡아두세요.</p>
                <button type="button" class="newsletter-btn" id="newsletter-trigger">사전 등록하기</button>
            </div>
        </section>
    </div>
</BaseLayout>

<script is:inline src="https://tally.so/widgets/embed.js"></script>
<script is:inline>
    document.getElementById('newsletter-trigger')?.addEventListener('click', function() {
        if (typeof Tally !== 'undefined') {
            Tally.openPopup('kdR9bZ', {
                width: 400,
                emoji: { text: '\u{1F4EC}', animation: 'wave' },
            });
        } else {
            window.open('https://tally.so/r/kdR9bZ', '_blank');
        }
    });
</script>

<style>
    .landing {
        max-width: 1120px;
        margin: 0 auto;
    }

    .hero {
        display: grid;
        gap: 14px;
        padding: 28px 0 26px;
        border-bottom: 4px solid var(--color-aiki-blue);
    }

    .hero-eyebrow {
        width: fit-content;
        margin: 0;
        padding: 4px 10px 5px;
        border: 2px solid var(--color-aiki-blue);
        border-radius: 999px;
        color: var(--color-aiki-blue);
        font-size: var(--text-sm);
        font-weight: 900;
        letter-spacing: 0;
        text-transform: uppercase;
        animation: fadeUp 0.6s ease-out;
    }

    .hero-title {
        font-family: var(--font-display);
        font-size: 7rem;
        font-weight: 900;
        letter-spacing: 0;
        color: var(--color-aiki-blue);
        margin: 0;
        line-height: 0.82;
        overflow-wrap: anywhere;
        animation: fadeUp 0.6s ease-out 0.05s both;
    }

    .hero-subtitle {
        margin: 0;
        max-width: 620px;
        font-size: var(--text-2xl);
        font-weight: 850;
        color: var(--color-text);
        line-height: 1.28;
        animation: fadeUp 0.6s ease-out 0.1s both;
    }

    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .categories {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        gap: 0;
        margin-bottom: 34px;
        border-bottom: 3px solid var(--color-aiki-blue);
    }

    .category-card {
        display: grid;
        grid-template-columns: 68px minmax(0, 1fr) auto;
        align-items: center;
        gap: 18px;
        min-height: 118px;
        padding: 20px 0;
        border-top: 3px solid var(--color-aiki-blue);
        border-radius: 0;
        background: transparent;
        color: var(--color-text);
        text-decoration: none;
        box-shadow: none;
        transition: color 0.2s ease, background 0.2s ease, padding 0.2s ease;
        animation: fadeUp 0.5s ease-out both;
    }

    .category-card:nth-child(1) { animation-delay: 0.15s; }
    .category-card:nth-child(2) { animation-delay: 0.22s; }
    .category-card:nth-child(3) { animation-delay: 0.29s; }

    .category-card:hover {
        padding-left: 14px;
        background: color-mix(in srgb, var(--color-aiki-blue) 8%, transparent);
    }

    .news-card { --section-color: var(--color-news); }
    .wiki-card { --section-color: var(--color-wiki); }
    .projects-card { --section-color: var(--color-projects); }

    .category-card:hover .card-icon,
    .category-card:hover .card-count {
        color: var(--section-color);
    }

    .card-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 58px;
        height: 58px;
        border-radius: 50%;
        border: 2px solid var(--color-aiki-blue);
        color: var(--color-aiki-blue);
        background: var(--color-surface);
        flex-shrink: 0;
    }

    .card-body {
        min-width: 0;
    }

    .card-body h2 {
        margin: 0 0 4px;
        font-family: var(--font-display);
        font-size: var(--text-3xl);
        font-weight: 900;
        line-height: 1;
        color: var(--color-aiki-blue);
    }

    .card-body p {
        max-width: 680px;
        margin: 0 0 7px;
        color: var(--color-text);
        font-size: var(--text-base);
        line-height: 1.58;
    }

    .card-count {
        font-size: var(--text-xs);
        font-weight: 900;
        color: var(--color-aiki-blue);
    }

    .card-arrow {
        color: var(--color-aiki-blue);
        font-family: var(--font-display);
        font-size: var(--text-3xl);
        align-self: center;
        justify-self: end;
        transition: transform 0.2s ease;
    }

    .category-card:hover .card-arrow {
        transform: translateX(4px);
    }

    .newsletter-section {
        margin-bottom: 40px;
        animation: fadeUp 0.5s ease-out 0.35s both;
    }

    .newsletter-card {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: center;
        gap: 16px;
        padding: 18px 0;
        border-top: 3px solid var(--color-aiki-blue);
        border-bottom: 3px solid var(--color-aiki-blue);
        border-radius: 0;
        background: transparent;
        box-shadow: none;
    }

    .newsletter-card h3 {
        margin: 0 0 4px;
        font-size: var(--text-lg);
        font-weight: 900;
    }

    .newsletter-card p {
        margin: 0;
        color: var(--color-text-muted);
        font-size: var(--text-sm);
    }

    .newsletter-btn {
        display: inline-flex;
        align-items: center;
        min-height: 44px;
        padding: 0 24px;
        border: 2px solid var(--color-aiki-blue);
        border-radius: 999px;
        background: var(--color-aiki-blue);
        color: #fff;
        font: inherit;
        font-size: var(--text-sm);
        font-weight: 700;
        cursor: pointer;
        transition: background 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
    }

    .newsletter-btn:hover {
        border-color: var(--color-aiki-blue);
        background: transparent;
        color: var(--color-aiki-blue);
        transform: translateY(-1px);
    }

    @media (max-width: 640px) {
        .hero { padding: 26px 0 22px; }
        .hero-title { font-size: 4.2rem; }
        .hero-subtitle { font-size: var(--text-lg); }

        .category-card {
            grid-template-columns: minmax(0, 1fr) 24px;
            gap: 12px;
            min-height: 0;
            padding: 18px 0;
        }

        .card-icon {
            display: none;
        }

        .card-body h2 {
            font-size: var(--text-2xl);
        }

        .card-body p {
            font-size: var(--text-sm);
        }

        .newsletter-card {
            grid-template-columns: minmax(0, 1fr);
            align-items: start;
        }
    }

    .hero {
        position: relative;
        min-height: 520px;
        overflow: hidden;
        grid-template-columns: minmax(0, 1fr) 300px;
        align-items: center;
        gap: 28px;
        padding: 58px 52px 46px;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-xl);
        background:
            linear-gradient(118deg, rgba(255, 255, 255, 0.76), rgba(255, 255, 255, 0.3) 42%, rgba(219, 248, 242, 0.48)),
            linear-gradient(35deg, rgba(136, 178, 255, 0.34), rgba(255, 255, 255, 0) 42%, rgba(188, 172, 255, 0.24)),
            var(--color-surface-elevated);
        box-shadow: var(--shadow-card);
        backdrop-filter: blur(22px) saturate(145%);
    }

    .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
            linear-gradient(118deg, rgba(255, 255, 255, 0.94) 0%, rgba(255, 255, 255, 0) 34%),
            linear-gradient(300deg, rgba(130, 228, 220, 0.18), rgba(109, 157, 255, 0.16), rgba(185, 167, 255, 0.12));
        pointer-events: none;
    }

    .hero-copy,
    .hero-visual,
    .hero-stats {
        position: relative;
        z-index: 1;
    }

    .hero-copy {
        display: grid;
        gap: 16px;
    }

    .hero-eyebrow {
        border: 0;
        padding: 0;
        color: var(--color-text-muted);
        font-family: var(--font-heading);
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.12em;
    }

    .hero-title {
        max-width: 650px;
        color: var(--color-text);
        font-size: 4.35rem;
        line-height: 1.04;
        letter-spacing: 0;
        animation: none;
    }

    .hero-subtitle {
        max-width: 560px;
        color: var(--color-text-muted);
        font-size: var(--text-lg);
        font-weight: 600;
        line-height: 1.72;
        animation: none;
    }

    .hero-eyebrow {
        animation: none;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 6px;
    }

    .hero-primary,
    .hero-secondary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 0 20px;
        border-radius: 999px;
        font-size: var(--text-sm);
        font-weight: 800;
        text-decoration: none;
        transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
    }

    .hero-primary {
        background: var(--color-text);
        color: #fff;
        box-shadow: 0 14px 30px rgba(10, 20, 38, 0.16);
    }

    .hero-secondary {
        border: 1px solid var(--color-border-strong);
        background: rgba(255, 255, 255, 0.44);
        color: var(--color-text);
    }

    .hero-primary:hover,
    .hero-secondary:hover {
        transform: translateY(-2px);
    }

    .hero-visual {
        min-height: 300px;
        border-radius: 999px;
        background:
            linear-gradient(140deg, rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0)),
            linear-gradient(45deg, rgba(130, 228, 220, 0.12), rgba(185, 167, 255, 0.14));
    }

    .aurora-line {
        position: absolute;
        left: 8%;
        right: 4%;
        height: 1px;
        border-radius: 999px;
        background: linear-gradient(90deg, transparent, rgba(109, 157, 255, 0.62), rgba(130, 228, 220, 0.48), transparent);
        transform-origin: center;
    }

    .line-one { top: 38%; transform: rotate(-22deg); }
    .line-two { top: 56%; transform: rotate(18deg); opacity: 0.7; }

    .constellation-dot {
        position: absolute;
        width: 6px;
        height: 6px;
        border-radius: 999px;
        background: rgba(10, 20, 38, 0.64);
        box-shadow: 0 0 0 8px rgba(255, 255, 255, 0.34);
    }

    .dot-one { top: 30%; left: 28%; }
    .dot-two { top: 48%; right: 25%; background: var(--color-aiki-cyan); }
    .dot-three { bottom: 24%; left: 42%; background: var(--color-aiki-violet); }

    .hero-stats {
        grid-column: 1 / -1;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
        max-width: 620px;
        padding: 14px;
        border: 1px solid var(--color-border);
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.48);
        backdrop-filter: blur(16px);
    }

    .hero-stats span {
        display: grid;
        gap: 2px;
        color: var(--color-text-muted);
        font-size: var(--text-xs);
    }

    .hero-stats strong {
        color: var(--color-text);
        font-family: var(--font-heading);
        font-size: var(--text-xl);
        line-height: 1;
    }

    .categories {
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
        margin: 28px 0 34px;
        border: 0;
    }

    .category-card {
        grid-template-columns: minmax(0, 1fr);
        align-content: start;
        min-height: 230px;
        padding: 22px;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        background: color-mix(in srgb, var(--color-surface-elevated) 76%, transparent);
        box-shadow: var(--shadow-card);
        backdrop-filter: blur(18px) saturate(135%);
        animation: none;
    }

    .category-card:hover {
        padding-left: 22px;
        background: color-mix(in srgb, var(--section-color) 12%, var(--color-surface-elevated) 88%);
        box-shadow: var(--shadow-card-hover);
    }

    .card-icon {
        width: 48px;
        height: 48px;
        border: 1px solid var(--color-border);
        color: var(--section-color);
        background: rgba(255, 255, 255, 0.5);
    }

    .card-body h2 {
        margin-top: 12px;
        color: var(--color-text);
        font-family: var(--font-heading);
        font-size: var(--text-2xl);
    }

    .card-body p {
        color: var(--color-text-muted);
    }

    .card-count {
        color: var(--section-color);
    }

    .card-arrow {
        justify-self: start;
        color: var(--section-color);
        font-family: var(--font-heading);
        font-size: var(--text-xl);
    }

    .newsletter-card {
        padding: 22px;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        background: color-mix(in srgb, var(--color-surface-elevated) 78%, transparent);
        box-shadow: var(--shadow-card);
        backdrop-filter: blur(18px);
    }

    .newsletter-section {
        animation: none;
    }

    .newsletter-btn {
        border: 0;
        background: var(--color-text);
        box-shadow: 0 12px 30px rgba(10, 20, 38, 0.14);
    }

    .newsletter-btn:hover {
        background: var(--color-aiki-blue);
        color: #fff;
    }

    html.dark .hero {
        background:
            linear-gradient(118deg, rgba(11, 23, 39, 0.92), rgba(18, 36, 57, 0.66) 46%, rgba(17, 55, 63, 0.64)),
            linear-gradient(35deg, rgba(141, 181, 255, 0.18), rgba(255, 255, 255, 0) 42%, rgba(197, 184, 255, 0.12)),
            var(--color-surface-elevated);
        box-shadow: 0 28px 90px rgba(0, 0, 0, 0.34), 0 1px 0 rgba(255, 255, 255, 0.10) inset;
    }

    html.dark .hero::before {
        background:
            linear-gradient(118deg, rgba(255, 255, 255, 0.10) 0%, rgba(255, 255, 255, 0) 36%),
            radial-gradient(circle at 80% 28%, rgba(123, 228, 221, 0.16), transparent 32%),
            linear-gradient(300deg, rgba(141, 181, 255, 0.18), rgba(197, 184, 255, 0.12));
    }

    html.dark .hero-primary,
    html.dark .newsletter-btn {
        background: #f4f8ff;
        color: #07111f;
        box-shadow: 0 14px 34px rgba(0, 0, 0, 0.32);
    }

    html.dark .hero-secondary,
    html.dark .hero-stats,
    html.dark .category-card,
    html.dark .newsletter-card {
        background: color-mix(in srgb, var(--color-surface-elevated) 78%, transparent);
        border-color: rgba(211, 226, 255, 0.16);
    }

    html.dark .card-icon {
        background: rgba(211, 226, 255, 0.08);
        border-color: rgba(211, 226, 255, 0.18);
    }

    html.dark .constellation-dot {
        background: #dce8ff;
        box-shadow: 0 0 0 8px rgba(211, 226, 255, 0.18);
    }

    @media (max-width: 820px) {
        .hero {
            grid-template-columns: minmax(0, 1fr);
            min-height: 0;
            padding: 34px 24px 24px;
        }

        .hero-visual {
            min-height: 150px;
        }

        .hero-title {
            font-size: 3rem;
        }

        .hero-stats,
        .categories {
            grid-template-columns: minmax(0, 1fr);
        }

        .category-card {
            min-height: 0;
        }
    }
</style>
