---
import fs from 'node:fs';
import path from 'node:path';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const lang = 'ko';

const allNews = await getCollection('news', ({ data }) => data.lang === lang && !data.draft);
const allWiki = await getCollection('wiki', ({ data }) => data.lang === lang && !data.draft);
const allProjects = await getCollection('projects', ({ data }) => data.lang === lang && !data.draft);

const sortedNews = [...allNews].sort((a, b) => {
    const dateDiff = new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
    return dateDiff || (b.data.score ?? 0) - (a.data.score ?? 0);
});

const latestNewsDay = sortedNews[0]?.data.date.split('T')[0] ?? '';
const sameDayNews = sortedNews
    .filter((entry) => entry.data.date.startsWith(latestNewsDay))
    .sort((a, b) => (b.data.score ?? 0) - (a.data.score ?? 0));
const briefingNews = (sameDayNews.length >= 3 ? sameDayNews : sortedNews).slice(0, 5);
const featureNews = briefingNews[0];
const sideNews = briefingNews.slice(1, 3);

const trendingTerms = [...allWiki]
    .sort((a, b) => {
        const mentionDiff = (b.data.mentionCount ?? 0) - (a.data.mentionCount ?? 0);
        return mentionDiff || a.data.title.localeCompare(b.data.title, 'ko');
    })
    .slice(0, 5);

const trendingProjects = [...allProjects]
    .filter((project) => project.data.contentStatus === 'final')
    .sort((a, b) => {
        const aMetric = a.data.sourceMetric ?? a.data.stars ?? 0;
        const bMetric = b.data.sourceMetric ?? b.data.stars ?? 0;
        return bMetric - aMetric || a.data.title.localeCompare(b.data.title, 'ko');
    })
    .slice(0, 3);

function newsSlug(entry: (typeof allNews)[number]): string {
    return entry.id.replace(/^ko\//, '');
}

function newsThumbSrc(entry: (typeof allNews)[number]): string {
    const slug = newsSlug(entry);
    const externalThumbPath = path.join(process.cwd(), 'public', 'og', 'news', `${slug}.jpg`);
    const fallbackThumbPath = path.join(process.cwd(), 'public', 'og', 'news-fallback', `${slug}.png`);
    if (fs.existsSync(externalThumbPath)) return `/og/news/${slug}.jpg`;
    if (fs.existsSync(fallbackThumbPath)) return `/og/news-fallback/${slug}.png`;
    return '/og/site-default.png';
}

function wikiSlug(entry: (typeof allWiki)[number]): string {
    return entry.id.replace(/^ko\//, '');
}

function formatBriefingDate(dateStr: string): string {
    const date = new Date(dateStr);
    return new Intl.DateTimeFormat('ko-KR', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
        weekday: 'long',
    }).format(date);
}

function formatShortDate(dateStr: string): string {
    const date = new Date(dateStr);
    return new Intl.DateTimeFormat('ko-KR', { month: 'numeric', day: 'numeric', weekday: 'short' }).format(date);
}

function formatNumber(value: number | undefined): string {
    const number = Number(value || 0);
    if (number >= 1000) return `${Math.round(number / 100) / 10}k`;
    return `${number}`;
}

function newsLabel(entry: (typeof allNews)[number], index = 0): string {
    if (index === 0) return '주요 뉴스';
    if (entry.data.category === 'model') return '모델';
    if (entry.data.category === 'skill') return '스킬';
    if (entry.data.category === 'tutorial') return '가이드';
    return '뉴스';
}

function projectMetric(project: (typeof allProjects)[number]): string {
    return formatNumber(project.data.sourceMetric ?? project.data.stars);
}

function projectLogo(project: (typeof allProjects)[number]): string {
    return project.data.title
        .replace(/[^0-9A-Za-z가-힣]/g, '')
        .slice(0, 2)
        .toUpperCase();
}

const latestDayLabel = latestNewsDay ? formatBriefingDate(`${latestNewsDay}T12:00:00+09:00`) : '오늘';
---

<BaseLayout
    title="AIKI"
    description="오늘 볼 AI 뉴스, 위키 용어, 실무형 프로젝트를 한 화면에서 연결하는 AI 브리핑."
>
    <div class="aiki-landing">
        <section class="concept-stage" aria-label="AIKI 데일리 브리핑">
            <article class="brief-app" aria-labelledby="landing-title">
                <header class="brief-nav" aria-label="AIKI 홈 내비게이션">
                    <a class="brief-logo" href="/ko/" aria-label="AIKI 홈">
                        <span class="logo-mark" aria-hidden="true">
                            <span></span>
                            <span></span>
                            <span></span>
                        </span>
                        <span>AIKI</span>
                    </a>
                    <nav class="brief-links" aria-label="주요 섹션">
                        <a class="is-active" href="/ko/">홈</a>
                        <a href="/ko/news/">뉴스</a>
                        <a href="/ko/wiki/">위키</a>
                        <a href="/ko/projects/">쇼케이스</a>
                    </nav>
                    <a class="brief-search" href="/ko/wiki/" aria-label="검색">
                        <span>검색어 또는 주제 입력...</span>
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <circle cx="11" cy="11" r="7"></circle>
                            <path d="m16.5 16.5 4 4"></path>
                        </svg>
                    </a>
                    <button class="landing-theme-toggle" type="button" aria-label="테마 변경">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <circle cx="12" cy="12" r="4"></circle>
                            <path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
                        </svg>
                    </button>
                    <a class="brief-menu" href="/ko/news/" aria-label="뉴스 메뉴">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M4 7h16M4 12h16M4 17h16"></path>
                        </svg>
                    </a>
                    <a class="brief-lang" href="/en/">EN</a>
                </header>

                <section class="brief-hero">
                    <div>
                        <p class="eyebrow">Daily Briefing</p>
                        <h1 id="landing-title">오늘의 AI 브리핑</h1>
                        <p>뉴스, 위키, 프로젝트를 한 곳에서 연결해 AI의 오늘을 빠르게 읽어.</p>
                    </div>
                    <time datetime={latestNewsDay}>{latestDayLabel}</time>
                </section>

                <section class="brief-board" aria-label="오늘의 AI 브리핑">
                    <div class="news-zone">
                        <div class="section-head">
                            <h2>오늘의 AI 뉴스</h2>
                            <a href="/ko/news/">전체 보기</a>
                        </div>

                        <div class="news-mosaic">
                            {featureNews && (
                                <a class="lead-news-card" href={`/ko/news/${newsSlug(featureNews)}/`}>
                                    <span class="news-visual news-visual--hero">
                                        <img src={newsThumbSrc(featureNews)} alt={featureNews.data.title} loading="eager" decoding="async" />
                                    </span>
                                    <span class="news-copy">
                                        <span class="pill">{newsLabel(featureNews, 0)}</span>
                                        <strong>{featureNews.data.title}</strong>
                                        <span>{featureNews.data.summary}</span>
                                        <small>AIKI 뉴스팀 · {formatShortDate(featureNews.data.date)}</small>
                                    </span>
                                </a>
                            )}

                            <div class="side-news-list">
                                {sideNews.map((entry, index) => (
                                    <a class="side-news-card" href={`/ko/news/${newsSlug(entry)}/`}>
                                        <span class={`news-visual news-visual--side news-visual--${index + 1}`}>
                                            <img src={newsThumbSrc(entry)} alt={entry.data.title} loading="lazy" decoding="async" />
                                        </span>
                                        <span class="news-copy">
                                            <span class="pill">{newsLabel(entry, index + 1)}</span>
                                            <strong>{entry.data.title}</strong>
                                            <small>{formatShortDate(entry.data.date)}</small>
                                        </span>
                                        <span class="arrow" aria-hidden="true">→</span>
                                    </a>
                                ))}
                            </div>
                        </div>
                    </div>

                    <aside class="insight-zone" aria-label="트렌딩 위키와 프로젝트">
                        <section class="compact-panel terms-card" aria-labelledby="terms-title">
                            <div class="panel-head">
                                <h2 id="terms-title">많이 찾는 위키 용어</h2>
                                <a href="/ko/wiki/">전체 보기</a>
                            </div>
                            <div class="term-list">
                                {trendingTerms.map((entry, index) => (
                                    <a class="term-row" href={`/ko/wiki/${wikiSlug(entry)}/`}>
                                        <span>{String(index + 1).padStart(2, '0')}</span>
                                        <strong>{entry.data.title}</strong>
                                        <small>{entry.data.mentionCount >= 10 ? '▲' : '▼'} {entry.data.mentionCount}</small>
                                    </a>
                                ))}
                            </div>
                        </section>

                        <section class="compact-panel project-card" aria-labelledby="projects-title">
                            <div class="panel-head">
                                <h2 id="projects-title">인기 프로젝트</h2>
                                <a href="/ko/projects/">전체 보기</a>
                            </div>
                            <div class="project-list">
                                {trendingProjects.map((project, index) => (
                                    <a class="project-row" href={`/ko/projects/${project.data.slug}/`}>
                                        <span class={`project-icon project-icon--${index + 1}`}>{projectLogo(project)}</span>
                                        <span>
                                            <strong>{project.data.title}</strong>
                                            <small>{project.data.summary}</small>
                                        </span>
                                        <em>★ {projectMetric(project)}</em>
                                    </a>
                                ))}
                            </div>
                        </section>
                    </aside>
                </section>

                <section class="value-strip" aria-label="AIKI 사용 가치">
                    <div>
                        <h2>AI를 시작하는 가장 효과적인 방법</h2>
                        <p>트렌드를 읽고, 모르는 개념을 바로 배우고, 적용 가능한 도구와 튜토리얼까지 이어 가.</p>
                    </div>
                    <a href="/ko/news/">
                        <span aria-hidden="true">⌁</span>
                        <strong>뉴스로 흐름 잡기</strong>
                        <small>오늘 나온 변화와 방향을 먼저 읽어</small>
                    </a>
                    <a href="/ko/wiki/">
                        <span aria-hidden="true">□</span>
                        <strong>위키로 개념 익히기</strong>
                        <small>낯선 용어와 배경을 바로 확인해</small>
                    </a>
                    <a href="/ko/projects/">
                        <span aria-hidden="true">◇</span>
                        <strong>프로젝트로 실행하기</strong>
                        <small>오픈소스 도구와 실제 사례로 연결해</small>
                    </a>
                    <a href="/ko/projects/">
                        <span aria-hidden="true">♡</span>
                        <strong>튜토리얼로 적용하기</strong>
                        <small>맞춤형 가이드로 내 작업에 옮겨 봐</small>
                    </a>
                </section>
            </article>
        </section>

        <nav class="landing-bottom-dock" aria-label="AIKI 모바일 내비게이션">
            <a class="active" href="/ko/">홈</a>
            <a href="/ko/news/">뉴스</a>
            <a href="/ko/wiki/">위키</a>
            <a href="/ko/projects/">쇼케이스</a>
        </nav>
    </div>
</BaseLayout>

<script is:inline>
    document.querySelectorAll('.landing-theme-toggle').forEach((button) => {
        button.addEventListener('click', () => {
            const isDark = document.documentElement.classList.toggle('dark');
            const expires = new Date(Date.now() + 365 * 24 * 60 * 60 * 1000).toUTCString();
            document.cookie = `theme=${isDark ? 'dark' : 'light'};expires=${expires};path=/;SameSite=Lax`;
        });
    });
</script>

<style>
    :global(body:has(.aiki-landing) .site-nav),
    :global(body:has(.aiki-landing) .site-footer),
    :global(body:has(.aiki-landing) > .bottom-nav) {
        display: none !important;
    }

    :global(body:has(.aiki-landing)) {
        padding-bottom: 0;
    }

    .aiki-landing {
        --ink: #071426;
        --muted: #637086;
        --faint: #8994a7;
        --blue: #356dff;
        --blue-soft: #eaf1ff;
        --cyan: #48d6ca;
        --mint: #bff1e8;
        --violet: #9e8cff;
        --line: rgba(79, 96, 132, 0.16);
        --line-strong: rgba(79, 96, 132, 0.28);
        --surface: rgba(255, 255, 255, 0.86);
        width: min(1180px, calc(100vw - 48px));
        margin: 0 auto;
        color: var(--ink);
    }

    .aiki-landing,
    .aiki-landing *,
    .aiki-landing *::before,
    .aiki-landing *::after {
        box-sizing: border-box;
    }

    .aiki-landing a {
        color: inherit;
        text-decoration: none;
    }

    .concept-stage {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        align-items: start;
    }

    .brief-app {
        border: 1px solid rgba(195, 204, 222, 0.66);
        background:
            linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0.84)),
            radial-gradient(circle at 0 0, rgba(222, 237, 255, 0.7), transparent 38%),
            radial-gradient(circle at 100% 0, rgba(242, 231, 255, 0.64), transparent 36%);
        box-shadow: 0 24px 80px rgba(50, 68, 104, 0.13);
        backdrop-filter: blur(22px) saturate(150%);
        min-width: 0;
        overflow: hidden;
        border-radius: 24px;
        padding: 30px clamp(34px, 3.1vw, 44px) 34px;
    }

    .brief-nav {
        display: grid;
        grid-template-columns: auto minmax(240px, 1fr) minmax(260px, 330px) auto auto;
        gap: 18px;
        align-items: center;
        margin-bottom: clamp(28px, 3vw, 34px);
    }

    .brief-logo {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
        color: var(--ink);
        font-family: var(--font-heading);
        font-size: 1.45rem;
        font-weight: 900;
        line-height: 1;
    }

    .logo-mark {
        position: relative;
        display: inline-flex;
        width: 26px;
        height: 20px;
    }

    .logo-mark span {
        position: absolute;
        width: 13px;
        height: 13px;
        border-radius: 999px;
        mix-blend-mode: multiply;
    }

    .logo-mark span:nth-child(1) {
        left: 1px;
        top: 5px;
        background: var(--cyan);
    }

    .logo-mark span:nth-child(2) {
        left: 8px;
        top: 2px;
        background: var(--blue);
    }

    .logo-mark span:nth-child(3) {
        left: 12px;
        top: 8px;
        background: var(--violet);
    }

    .brief-links {
        display: flex;
        justify-content: center;
        gap: 28px;
        min-width: 0;
    }

    .brief-links a {
        position: relative;
        display: inline-flex;
        align-items: center;
        min-height: 36px;
        color: #0e1728;
        font-size: 0.91rem;
        font-weight: 680;
    }

    .brief-links a::after {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        bottom: -4px;
        height: 2px;
        border-radius: 999px;
        background: var(--blue);
        opacity: 0;
        transform: scaleX(0.4);
        transition: opacity 0.16s ease, transform 0.16s ease;
    }

    .brief-links a:hover::after,
    .brief-links a.is-active::after {
        opacity: 1;
        transform: scaleX(1);
    }

    .brief-links a.is-active {
        color: var(--blue);
        font-weight: 850;
    }

    .brief-search,
    .phone-search {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        min-width: 0;
        min-height: 42px;
        border: 1px solid var(--line);
        border-radius: 6px;
        background: rgba(255, 255, 255, 0.62);
        color: #9aa3b1;
        padding: 0 13px 0 16px;
        font-size: 0.9rem;
        font-weight: 560;
    }

    .brief-search span,
    .phone-search span {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .brief-search svg,
    .phone-search svg {
        width: 18px;
        height: 18px;
        flex: 0 0 auto;
        fill: none;
        stroke: #68758a;
        stroke-width: 2;
        stroke-linecap: round;
    }

    .landing-theme-toggle,
    .brief-lang,
    .brief-menu,
    .phone-menu {
        display: inline-grid;
        place-items: center;
        width: 44px;
        height: 44px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.68);
        color: var(--ink);
        cursor: pointer;
    }

    .landing-theme-toggle svg,
    .brief-menu svg,
    .phone-menu svg {
        width: 19px;
        height: 19px;
        fill: none;
        stroke: currentColor;
        stroke-width: 1.8;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .brief-lang {
        font-size: 0.78rem;
        font-weight: 820;
    }

    .brief-menu {
        display: none;
    }

    .brief-hero {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 28px;
        align-items: end;
        margin-bottom: 28px;
    }

    .eyebrow {
        margin: 0 0 14px;
        color: var(--blue);
        font-family: var(--font-heading);
        font-size: 0.74rem;
        font-weight: 900;
        letter-spacing: 0.13em;
        line-height: 1;
        text-transform: uppercase;
    }

    .brief-hero h1 {
        max-width: 720px;
        margin: 0;
        color: var(--ink);
        font-family: var(--font-display);
        font-size: clamp(4.4rem, 5.5vw, 5.9rem);
        font-weight: 900;
        letter-spacing: 0;
        line-height: 0.95;
        word-break: keep-all;
    }

    .brief-hero p:not(.eyebrow),
    .phone-hero p:not(.eyebrow) {
        max-width: 640px;
        margin: 18px 0 0;
        color: var(--muted);
        font-size: 1.08rem;
        font-weight: 610;
        line-height: 1.65;
        word-break: keep-all;
    }

    .brief-hero time {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        margin-bottom: 8px;
        color: var(--muted);
        font-size: 0.92rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .brief-hero time::before,
    .phone-hero time::before {
        content: '';
        width: 14px;
        height: 14px;
        background:
            linear-gradient(var(--muted), var(--muted)) 3px 6px / 8px 1.5px no-repeat,
            linear-gradient(var(--muted), var(--muted)) 3px 10px / 8px 1.5px no-repeat;
        border: 1.5px solid var(--muted);
        border-radius: 3px;
        opacity: 0.72;
    }

    .brief-board {
        display: grid;
        grid-template-columns: minmax(0, 1.66fr) minmax(292px, 0.88fr);
        gap: 34px;
        align-items: start;
    }

    .section-head,
    .panel-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 16px;
    }

    .section-head h2,
    .panel-head h2,
    .value-strip h2,
    .phone-hero h2 {
        margin: 0;
        color: var(--ink);
        font-family: var(--font-heading);
        font-weight: 900;
        letter-spacing: 0;
        line-height: 1.1;
        word-break: keep-all;
    }

    .section-head h2 {
        font-size: 1.32rem;
    }

    .panel-head h2 {
        font-size: 1rem;
    }

    .section-head a,
    .panel-head a {
        color: var(--blue);
        font-size: 0.78rem;
        font-weight: 800;
        white-space: nowrap;
    }

    .section-head a::after,
    .panel-head a::after {
        content: ' →';
    }

    .news-mosaic {
        display: grid;
        grid-template-columns: minmax(0, 1.55fr) minmax(260px, 0.98fr);
        gap: 18px;
    }

    .lead-news-card,
    .side-news-card,
    .compact-panel,
    .value-strip {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.64);
        box-shadow: 0 18px 42px rgba(51, 68, 104, 0.08);
    }

    .lead-news-card,
    .side-news-card {
        position: relative;
        overflow: hidden;
        display: grid;
        color: var(--ink);
        transition: border-color 0.16s ease, transform 0.16s ease, box-shadow 0.16s ease;
    }

    .lead-news-card:hover,
    .side-news-card:hover,
    .term-row:hover,
    .project-row:hover,
    .value-strip a:hover {
        border-color: rgba(53, 109, 255, 0.4);
        transform: translateY(-2px);
        box-shadow: 0 22px 52px rgba(53, 76, 118, 0.12);
    }

    .lead-news-card {
        min-height: 410px;
        border-radius: 14px;
    }

    .news-visual {
        position: relative;
        display: block;
        min-width: 0;
        overflow: hidden;
        background: #dfeaf7;
    }

    .news-visual--hero {
        min-height: 235px;
        background:
            radial-gradient(circle at 82% 30%, rgba(83, 130, 198, 0.22), transparent 34%),
            linear-gradient(108deg, #f7fbff 0%, #d7e8f7 53%, #edf5ff 100%);
    }

    .news-visual img {
        display: block;
        width: 100%;
        height: 100%;
        min-height: inherit;
        object-fit: cover;
    }

    .news-visual--hero::before {
        content: '';
        position: absolute;
        inset: auto 0 0;
        z-index: 3;
        height: 44%;
        pointer-events: none;
        background: linear-gradient(to bottom, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.92) 86%, rgba(255, 255, 255, 1));
    }

    .news-visual--phone::after {
        content: '';
        position: absolute;
        inset: 0;
        z-index: 2;
        background-image:
