---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Timeline from '../../components/Timeline.astro';
import ZoomTabs from '../../components/ZoomTabs.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';

const lang = 'ko';
const allNews = await getCollection('news', ({ data }) => data.lang === lang && !data.draft);
const sorted = allNews.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const items = sorted.map(entry => ({
    title: entry.data.title,
    summary: entry.data.summary,
    date: entry.data.date,
    category: entry.data.category,
    factCheckStatus: entry.data.factCheck?.status,
    factCheckSourceCount: entry.data.factCheck?.sources?.length,
    slug: entry.id.replace(/^ko\//, ''),
    score: entry.data.score ?? 0,
    sourceCount: entry.data.sourceCount,
}));

// --- Zoom-level grouping ---

// Helper: ISO week number
function getISOWeek(dateStr: string): string {
    const d = new Date(dateStr);
    const tmp = new Date(Date.UTC(d.getFullYear(), d.getMonth(), d.getDate()));
    tmp.setUTCDate(tmp.getUTCDate() + 4 - (tmp.getUTCDay() || 7));
    const yearStart = new Date(Date.UTC(tmp.getUTCFullYear(), 0, 1));
    const weekNo = Math.ceil((((tmp.getTime() - yearStart.getTime()) / 86400000) + 1) / 7);
    return `${tmp.getUTCFullYear()}-W${String(weekNo).padStart(2, '0')}`;
}

// Weekly: highest score per day
const dailyGroups = new Map<string, typeof items>();
for (const item of items) {
    const day = item.date.split('T')[0];
    if (!dailyGroups.has(day)) dailyGroups.set(day, []);
    dailyGroups.get(day)!.push(item);
}
const weeklySet = new Set<string>();
for (const [, group] of dailyGroups) {
    const best = group.reduce((a, b) => (a.score >= b.score ? a : b));
    weeklySet.add(best.slug);
}

// Monthly: top 3 per ISO week
const weeklyGroups = new Map<string, typeof items>();
for (const item of items) {
    const week = getISOWeek(item.date);
    if (!weeklyGroups.has(week)) weeklyGroups.set(week, []);
    weeklyGroups.get(week)!.push(item);
}
const monthlySet = new Set<string>();
for (const [, group] of weeklyGroups) {
    const top3 = [...group].sort((a, b) => b.score - a.score).slice(0, 3);
    for (const t of top3) monthlySet.add(t.slug);
}

// Yearly: top 1 per month
const monthGroups = new Map<string, typeof items>();
for (const item of items) {
    const month = item.date.substring(0, 7);
    if (!monthGroups.has(month)) monthGroups.set(month, []);
    monthGroups.get(month)!.push(item);
}
const yearlySet = new Set<string>();
for (const [, group] of monthGroups) {
    const best = group.reduce((a, b) => (a.score >= b.score ? a : b));
    yearlySet.add(best.slug);
}

// Assign zoom levels
const itemsWithZoom = items.map(item => {
    const levels = ['daily'];
    if (weeklySet.has(item.slug)) levels.push('weekly');
    if (monthlySet.has(item.slug)) levels.push('monthly');
    if (yearlySet.has(item.slug)) levels.push('yearly');
    return { ...item, zoomLevel: levels.join(',') };
});

// Relative time helper
function relativeTime(dateStr: string): string {
    const now = new Date();
    const d = new Date(dateStr);
    const diffMs = now.getTime() - d.getTime();
    const diffMin = Math.floor(diffMs / 60000);
    if (diffMin < 60) return `${diffMin}분 전`;
    const diffHr = Math.floor(diffMin / 60);
    if (diffHr < 24) return `${diffHr}시간 전`;
    const diffDay = Math.floor(diffHr / 24);
    return `${diffDay}일 전`;
}

// Editorial hierarchy: hero + secondary + rest
const heroItem = itemsWithZoom[0];
const secondaryItems = itemsWithZoom.slice(1, 3);
const restItems = itemsWithZoom.slice(3);

const categoryColors: Record<string, string> = {
    news: 'var(--color-news)',
    wiki: 'var(--color-wiki)',
    tutorial: 'var(--color-tutorial)',
};
const categoryLabels: Record<string, string> = {
    news: '뉴스', wiki: '위키', tutorial: '튜토리얼',
};
---

<BaseLayout>
    <div class="hero">
        <h1 class="hero-title">AIKI</h1>
        <p class="hero-subtitle">AI 뉴스, 용어, 모델 비교를 한 곳에서</p>
    </div>
    <ZoomTabs lang={lang} />

    {/* Hero article */}
    {heroItem && (
        <a href={`/${lang}/news/${heroItem.slug}/`} class="hero-article" data-zoom-level={heroItem.zoomLevel}>
            <div class="hero-meta">
                <span class="hero-badge" style={`background: ${categoryColors[heroItem.category] ?? 'var(--color-news)'}`}>
                    {categoryLabels[heroItem.category] ?? heroItem.category}
                </span>
                <span class="hero-time">{relativeTime(heroItem.date)}</span>
            </div>
            <h2 class="hero-article-title">{heroItem.title}</h2>
            <p class="hero-article-summary">{heroItem.summary}</p>
            {heroItem.factCheckStatus === 'passed' && (
                <span class="hero-fc">✅ 팩트체크 통과 · 출처 {heroItem.factCheckSourceCount}건</span>
            )}
        </a>
    )}

    {/* Secondary 2-column grid */}
    {secondaryItems.length > 0 && (
        <div class="secondary-grid">
            {secondaryItems.map(item => (
                <a href={`/${lang}/news/${item.slug}/`} class="secondary-card" data-zoom-level={item.zoomLevel}>
                    <span class="sec-badge" style={`background: ${categoryColors[item.category] ?? 'var(--color-news)'}`}>
                        {categoryLabels[item.category] ?? item.category}
                    </span>
                    <h3 class="sec-title">{item.title}</h3>
                    <p class="sec-summary">{item.summary}</p>
                </a>
            ))}
        </div>
    )}

    {/* Rest in timeline */}
    <Timeline items={restItems} lang={lang} />
    <NewsletterSignup lang={lang} />
</BaseLayout>

<script>
    function applyZoom(level: string) {
        document.querySelectorAll('.zoom-tab').forEach(t => t.classList.remove('active'));
        document.querySelector(`.zoom-tab[data-zoom="${level}"]`)?.classList.add('active');
        // Filter all zoomable elements: timeline items + hero + secondary cards
        document.querySelectorAll('[data-zoom-level]').forEach(item => {
            const levels = ((item as HTMLElement).dataset.zoomLevel || 'daily').split(',');
            (item as HTMLElement).style.display = levels.includes(level) ? '' : 'none';
        });
    }

    // Read initial state from URL
    const params = new URLSearchParams(window.location.search);
    const initialZoom = params.get('period') || 'daily';
    applyZoom(initialZoom);

    document.querySelectorAll('.zoom-tab').forEach(tab => {
        tab.addEventListener('click', () => {
            const level = (tab as HTMLElement).dataset.zoom!;
            const url = new URL(window.location.href);
            if (level === 'daily') {
                url.searchParams.delete('period');
            } else {
                url.searchParams.set('period', level);
            }
            window.history.replaceState({}, '', url.toString());
            applyZoom(level);
        });
    });

    // Scroll-triggered entrance animations (respects prefers-reduced-motion)
    const animTargets = '.timeline-item, .hero-article, .secondary-card';
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1 });
        document.querySelectorAll(animTargets).forEach(item => observer.observe(item));
    } else {
        document.querySelectorAll(animTargets).forEach(item => item.classList.add('visible'));
    }
</script>

<style>
    .hero { text-align: center; padding: 48px 0 40px; }
    .hero-title {
        font-size: var(--text-4xl);
        font-weight: 800;
        letter-spacing: -0.02em;
        background: linear-gradient(135deg, var(--color-news), var(--color-wiki));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 12px;
    }
    .hero-subtitle {
        font-size: var(--text-lg);
        color: var(--color-text-muted);
        line-height: 1.5;
    }
    /* Hero article */
    .hero-article {
        display: block;
        background: var(--color-surface-elevated);
        border: 1px solid rgba(79, 195, 247, 0.2);
        border-radius: 12px;
        padding: 28px 32px;
        margin-bottom: 20px;
        text-decoration: none;
        color: inherit;
        box-shadow: 0 4px 24px rgba(79, 195, 247, 0.08), 0 2px 8px rgba(0, 0, 0, 0.3);
        transition: transform 0.2s ease-out, box-shadow 0.2s ease-out;
        opacity: 0;
        transform: translateY(16px);
    }
    .hero-article.visible {
        opacity: 1;
        transform: translateY(0);
        transition: opacity 0.5s ease-out, transform 0.5s ease-out;
    }
    .hero-article:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 32px rgba(79, 195, 247, 0.12), 0 4px 16px rgba(0, 0, 0, 0.4);
    }
    .hero-meta {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 12px;
    }
    .hero-badge {
        display: inline-block;
        color: #000;
        padding: 3px 12px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }
    .hero-time {
        font-size: 12px;
        color: var(--color-text-muted);
    }
    .hero-article-title {
        font-size: 26px;
        font-weight: 700;
        line-height: 1.3;
        margin-bottom: 10px;
    }
    .hero-article-summary {
        font-size: 15px;
        color: var(--color-text-muted);
        line-height: 1.6;
        margin-bottom: 8px;
    }
    .hero-fc {
        font-size: 12px;
        color: var(--color-pass);
    }

    /* Secondary 2-column grid */
    .secondary-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 32px;
    }
    .secondary-card {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 10px;
        padding: 20px;
        text-decoration: none;
        color: inherit;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
        transition: transform 0.2s ease-out, box-shadow 0.2s ease-out, background 0.2s ease;
        opacity: 0;
        transform: translateY(12px);
    }
    .secondary-card.visible {
        opacity: 1;
        transform: translateY(0);
        transition: opacity 0.4s ease-out, transform 0.4s ease-out;
    }
    .secondary-card:hover {
        background: var(--color-surface-alt);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
    }
    .sec-badge {
        display: inline-block;
        color: #000;
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 8px;
    }
    .sec-title {
        font-size: 16px;
        font-weight: 700;
        line-height: 1.35;
        margin-bottom: 6px;
    }
    .sec-summary {
        font-size: 13px;
        color: var(--color-text-muted);
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    @media (max-width: 640px) {
        .hero { padding: 32px 0 24px; }
        .hero-title { font-size: var(--text-3xl); }
        .hero-subtitle { font-size: var(--text-base); }
        .hero-article { padding: 20px; }
        .hero-article-title { font-size: 22px; }
        .secondary-grid { grid-template-columns: 1fr; }
    }
</style>
