---
import fs from 'node:fs';
import path from 'node:path';
import { t } from '../i18n/utils';
import ScoreBadge from './ScoreBadge.astro';

interface Props {
    title: string;
    summary: string;
    date: string;
    category: string;
    factCheckStatus?: string;
    factCheckSourceCount?: number;
    score?: number;
    sourceCount?: number;
    slug: string;
    side: 'left' | 'right';
    lang: string;
    zoomLevel?: string;
    featured?: boolean;
}

const { title, summary, category, factCheckStatus, factCheckSourceCount, score, sourceCount, slug, side, lang, zoomLevel, featured } = Astro.props;

const categoryColors: Record<string, string> = {
    news: 'var(--color-news)',
    wiki: 'var(--color-wiki)',
    model: 'var(--color-model)',
    tutorial: 'var(--color-tutorial)',
    skill: 'var(--color-skill)',
};

const categoryLabels: Record<string, string> = {
    news: t(lang, 'filter.news'),
    wiki: t(lang, 'filter.wiki'),
    model: t(lang, 'filter.model'),
    tutorial: t(lang, 'filter.tutorial'),
    skill: t(lang, 'filter.skill'),
};

const color = categoryColors[category] ?? 'var(--color-news)';
const externalThumbPath = path.join(process.cwd(), 'public', 'og', 'news', `${slug}.jpg`);
const fallbackThumbPath = path.join(process.cwd(), 'public', 'og', 'news-fallback', `${slug}.png`);
const thumbSrc = fs.existsSync(externalThumbPath)
    ? `/og/news/${slug}.jpg`
    : fs.existsSync(fallbackThumbPath)
        ? `/og/news-fallback/${slug}.png`
        : '/og/site-default.png';
---

<div class={`timeline-item timeline-${side}${featured ? ' featured' : ''}`} data-zoom-level={zoomLevel || 'daily'}>
    <div class="connector" style={`background: ${color}`}></div>
    <div class="dot" style={`background: ${color}`}></div>
    <a href={`/${lang}/news/${slug}/`} class="card" style={`border-color: ${color}`}>
        <div class="card-media">
            <img src={thumbSrc} alt={title} loading="lazy" decoding="async" />
        </div>
        <div class="card-copy">
            <div class="card-header">
                <span class="badge" style={`background: ${color}`}>{categoryLabels[category]}</span>
                {score > 0 && <ScoreBadge score={score} sourceCount={sourceCount} />}
            </div>
            <h3 class="card-title">{title}</h3>
            <p class="card-summary">{summary}</p>
            {factCheckStatus === 'passed' && (
                <div class="card-fc">
                    <span class="fc-pass">OK {t(lang, 'factcheck.status.passed')}</span>
                    {factCheckSourceCount && <span class="fc-sources">· 출처 {factCheckSourceCount}건</span>}
                </div>
            )}
        </div>
    </a>
</div>

<style>
    .timeline-item {
        display: block;
        position: relative;
        min-width: 0;
        opacity: 1;
        transform: none;
        transition: opacity 0.4s ease-out, transform 0.4s ease-out;
    }
    .timeline-item.visible {
        opacity: 1;
        transform: translateY(0);
    }
    .dot {
        display: none;
    }
    .connector {
        display: none;
    }
    .card {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        gap: 14px;
        height: 100%;
        background: color-mix(in srgb, var(--color-surface-elevated) 76%, transparent);
        border-radius: var(--radius-lg);
        padding: 14px;
        text-decoration: none;
        color: inherit;
        margin-left: 0;
        border: 1px solid var(--color-border) !important;
        text-align: left;
        transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
        box-shadow: var(--shadow-card);
        backdrop-filter: blur(18px) saturate(135%);
    }
    .card:hover {
        background: color-mix(in srgb, var(--color-surface-elevated) 88%, transparent);
        box-shadow: var(--shadow-card-hover);
        transform: translateY(-3px);
    }
    .card-media {
        position: relative;
        overflow: hidden;
        aspect-ratio: 16 / 9;
        min-height: 150px;
        border-radius: 18px;
        background: var(--color-surface-alt);
        border: 1px solid rgba(255, 255, 255, 0.58);
    }
    .card-media img {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: cover;
    }
    .card-copy {
        min-width: 0;
    }
    .card-header {
        display: flex;
        justify-content: flex-start;
        align-items: center;
        margin-bottom: 10px;
        gap: 8px;
        flex-wrap: wrap;
    }
    .badge {
        color: var(--color-text);
        padding: 3px 9px;
        border: 1px solid var(--color-border);
        border-radius: 999px;
        font-size: 11px;
        font-weight: 800;
        background: rgba(255, 255, 255, 0.5) !important;
        text-transform: none;
        letter-spacing: 0;
    }
    .card-title {
        font-family: var(--font-display);
        font-size: 21px;
        font-weight: 800;
        margin-bottom: 8px;
        line-height: 1.34;
        letter-spacing: 0;
    }
    .card-summary {
        font-size: 13px;
        color: var(--color-text-muted);
        line-height: 1.58;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .card-fc {
        display: flex;
        gap: 6px;
        margin-top: 8px;
        font-size: 10px;
    }
    .fc-pass {
        color: var(--color-pass);
    }
    .fc-sources {
        color: var(--color-text-muted);
    }
    .featured .card {
        grid-template-columns: minmax(0, 1.08fr) minmax(260px, 0.92fr);
        align-items: stretch;
        padding: 16px;
        background:
            linear-gradient(130deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.46)),
            color-mix(in srgb, var(--color-aiki-blue) 8%, var(--color-surface-elevated) 92%);
    }
    .featured .card-title {
        font-size: 32px;
    }
    .featured .card-summary {
        -webkit-line-clamp: 5;
        font-size: 14px;
    }
    .featured .dot {
        transform: scale(1.25);
    }
    @media (max-width: 640px) {
        .card {
            grid-template-columns: minmax(0, 1fr);
            padding: 12px;
        }
        .card-media {
            min-height: 170px;
        }
        .featured .card {
            grid-template-columns: minmax(0, 1fr);
        }
        .card-title {
            font-size: 19px;
        }
        .card-summary {
            -webkit-line-clamp: 2;
        }
    }
</style>
