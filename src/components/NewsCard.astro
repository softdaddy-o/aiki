---
import { t } from '../i18n/utils';
import ScoreBadge from './ScoreBadge.astro';

interface Props {
    title: string;
    summary: string;
    date: string;
    category: string;
    factCheckStatus?: string;
    factCheckSourceCount?: number;
    score?: number;
    sourceCount?: number;
    slug: string;
    side: 'left' | 'right';
    lang: string;
    zoomLevel?: string;
    featured?: boolean;
}

const { title, summary, date, category, factCheckStatus, factCheckSourceCount, score, sourceCount, slug, side, lang, zoomLevel, featured } = Astro.props;

const categoryColors: Record<string, string> = {
    news: 'var(--color-news)',
    wiki: 'var(--color-wiki)',
    model: 'var(--color-model)',
    tutorial: 'var(--color-tutorial)',
    skill: 'var(--color-skill)',
};

const categoryLabels: Record<string, string> = {
    news: t(lang, 'filter.news'),
    wiki: t(lang, 'filter.wiki'),
    model: t(lang, 'filter.model'),
    tutorial: t(lang, 'filter.tutorial'),
    skill: t(lang, 'filter.skill'),
};

const color = categoryColors[category] ?? 'var(--color-news)';
const time = date.split('T')[1]?.substring(0, 5) ?? '';
---

<div class={`timeline-item timeline-${side}${featured ? ' featured' : ''}`} data-zoom-level={zoomLevel || 'daily'}>
    <div class="connector" style={`background: ${color}`}></div>
    <div class="dot" style={`background: ${color}`}></div>
    <a href={`/${lang}/news/${slug}/`} class="card" style={`border-color: ${color}`}>
        <div class="card-header">
            <span class="badge" style={`background: ${color}`}>{categoryLabels[category]}</span>
            {time && <span class="time">{time}</span>}
            {score && <ScoreBadge score={score} sourceCount={sourceCount} />}
        </div>
        <h3 class="card-title">{title}</h3>
        <p class="card-summary">{summary}</p>
        {factCheckStatus === 'passed' && (
            <div class="card-fc">
                <span class="fc-pass">✅ {t(lang, 'factcheck.status.passed')}</span>
                {factCheckSourceCount && <span class="fc-sources">· 출처 {factCheckSourceCount}건</span>}
            </div>
        )}
    </a>
</div>

<style>
    .timeline-item {
        display: flex;
        align-items: flex-start;
        position: relative;
        margin-bottom: 16px;
        opacity: 0;
        transform: translateY(12px);
        transition: opacity 0.4s ease-out, transform 0.4s ease-out;
    }
    .timeline-item.visible {
        opacity: 1;
        transform: translateY(0);
    }
    .timeline-right { flex-direction: row; }
    .timeline-left { flex-direction: row-reverse; }
    .timeline-right .card { margin-left: 12px; border-left: 3px solid; border-right: none; }
    .timeline-left .card { margin-right: 12px; border-right: 3px solid; border-left: none; text-align: right; }
    .timeline-left .card-header { flex-direction: row-reverse; }
    .timeline-left .card-fc { justify-content: flex-end; }
    .dot {
        width: 14px; height: 14px; border-radius: 50%;
        border: 3px solid var(--color-bg); flex-shrink: 0;
        margin-top: 16px; position: relative; z-index: 2;
        box-shadow: 0 0 10px currentColor;
        transition: transform 0.2s ease;
    }
    .timeline-item:hover .dot { transform: scale(1.4); }
    .connector {
        width: 28px; height: 2px; opacity: 0.6;
        flex-shrink: 0; margin-top: 22px;
    }
    .card {
        flex: 1; background: var(--color-surface); border-radius: 10px;
        padding: 16px 20px; text-decoration: none; color: inherit;
        transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
        border: 1px solid var(--color-border);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    }
    .card:hover {
        background: var(--color-surface-alt);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
    }
    .card-header {
        display: flex; justify-content: space-between;
        align-items: center; margin-bottom: 10px;
    }
    .badge {
        color: #000; padding: 3px 10px; border-radius: 4px;
        font-size: 11px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.03em;
    }
    .time { color: var(--color-text-muted); font-size: 11px; }
    .card-title { font-size: 18px; font-weight: 700; margin-bottom: 6px; line-height: 1.4; }
    .card-summary {
        font-size: 13px; color: var(--color-text-muted); line-height: 1.5;
        display: -webkit-box; -webkit-line-clamp: 3;
        -webkit-box-orient: vertical; overflow: hidden;
    }
    .card-fc { display: flex; gap: 6px; margin-top: 6px; font-size: 10px; }
    .fc-pass { color: var(--color-pass); }
    .fc-sources { color: var(--color-text-muted); }
    .featured .card {
        background: var(--color-surface-elevated);
        border-color: rgba(79, 195, 247, 0.3);
        box-shadow: 0 4px 16px rgba(79, 195, 247, 0.1), 0 2px 8px rgba(0, 0, 0, 0.3);
    }
    .featured .card-title { font-size: 22px; }
    .featured .card-summary {
        -webkit-line-clamp: 5;
        font-size: 14px;
    }
    .featured .dot {
        width: 20px; height: 20px;
        box-shadow: 0 0 16px currentColor;
    }
    @media (max-width: 640px) {
        .timeline-item {
            flex-direction: row !important;
            margin-bottom: 14px;
            padding-left: 4px;
        }
        .dot {
            width: 12px !important; height: 12px !important;
            margin-left: 6px;
            margin-top: 18px;
            border-width: 2px !important;
            box-shadow: 0 0 8px currentColor !important;
        }
        .connector {
            width: 16px;
            margin-top: 23px;
            opacity: 0.7;
        }
        .timeline-left .card, .timeline-right .card {
            margin-left: 8px; margin-right: 0;
            border-left: 3px solid; border-right: none;
            text-align: left;
            border-radius: 8px;
            padding: 14px 16px;
        }
        .timeline-left .card-header { flex-direction: row; }
        .timeline-left .card-fc { justify-content: flex-start; }
        .card-title { font-size: 16px; }
        .card-summary { font-size: 13px; -webkit-line-clamp: 2; }
        .featured .dot { width: 16px !important; height: 16px !important; }
    }
</style>
