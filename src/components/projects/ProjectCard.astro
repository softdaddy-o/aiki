---
import { t } from '../../i18n/utils';

interface Props {
    title: string;
    slug: string;
    summary: string;
    category: string;
    tags: string[];
    sourceUrl: string;
    metric: number;
    license: string;
    version: string;
    date?: string;
    popularity?: number;
    recency?: number;
    lang: string;
}

const { title, slug, summary, category, tags, sourceUrl, metric, license, version, date, popularity, recency, lang } = Astro.props;
const categoryLabel = t(lang, `projects.category.${category}`);
const metricTitle = sourceUrl.includes('huggingface.co/') ? 'Hugging Face Likes' : 'GitHub Stars';
const metricPrefix = sourceUrl.includes('huggingface.co/') ? 'HF' : null;

function formatStars(value: number): string {
    if (value >= 1000) {
        const compact = (value / 1000).toFixed(1);
        return (compact.endsWith('.0') ? compact.slice(0, -2) : compact) + 'k';
    }
    return String(value);
}
---

<a
    href={`/${lang}/projects/${slug}/`}
    class="project-card"
    data-project-card
    data-title={title.toLowerCase()}
    data-summary={summary.toLowerCase()}
    data-tags={tags.join(' ').toLowerCase()}
    data-category={category}
    data-popularity={popularity ?? metric ?? 0}
    data-recency={recency ?? 0}
    data-date={date ?? ''}
>
    <div class="card-header">
        <h3 class="card-title">{title}</h3>
        <span class="category-badge">{categoryLabel}</span>
    </div>
    <p class="card-summary">{summary}</p>
    <div class="card-meta">
        <div class="card-stats">
            <span class="stars-badge" title={metricTitle}>
                {metricPrefix ? (
                    <span class="metric-prefix" aria-hidden="true">{metricPrefix}</span>
                ) : (
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279L12 19.771l-7.416 3.642 1.48-8.279L0 9.306l8.332-1.151z"/></svg>
                )}
                {formatStars(metric)}
            </span>
            <span class="license-badge">{license}</span>
            <span class="version-badge">{version}</span>
        </div>
    </div>
</a>

<style>
    .project-card {
        display: flex;
        flex-direction: column;
        gap: 12px;
        min-height: 238px;
        padding: 20px;
        background: color-mix(in srgb, var(--color-surface-elevated) 75%, transparent);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        text-decoration: none;
        color: var(--color-text);
        box-shadow: var(--shadow-card);
        backdrop-filter: blur(18px) saturate(135%);
        transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    }

    .project-card:hover {
        background: color-mix(in srgb, var(--color-projects) 12%, var(--color-surface-elevated) 88%);
        transform: translateY(-3px);
        box-shadow: var(--shadow-card-hover);
    }

    .card-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 10px;
    }

    .card-title {
        font-size: var(--text-lg);
        font-weight: 900;
        line-height: 1.24;
        color: var(--color-text);
    }

    .category-badge {
        flex-shrink: 0;
        padding: 3px 8px;
        border: 1px solid var(--color-aiki-blue);
        border-radius: 999px;
        background: transparent;
        color: var(--color-text);
        font-size: var(--text-xs);
        font-weight: 900;
        white-space: nowrap;
    }

    .card-summary {
        display: -webkit-box;
        overflow: hidden;
        color: var(--color-text-muted);
        font-size: var(--text-sm);
        line-height: 1.58;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 3;
    }

    .card-meta {
        display: flex;
        align-items: flex-end;
        justify-content: flex-start;
        gap: 12px;
        margin-top: auto;
    }

    .license-badge,
    .version-badge {
        border-radius: 999px;
        font-size: 11px;
        line-height: 1.3;
    }

    .card-stats {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        justify-content: flex-start;
        gap: 8px;
    }

    .stars-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        color: var(--color-aiki-blue);
        font-size: var(--text-xs);
        font-weight: 700;
    }

    .metric-prefix {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 18px;
        height: 18px;
        padding: 0 4px;
        border-radius: 999px;
        background: color-mix(in srgb, var(--color-aiki-blue) 18%, transparent);
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.04em;
    }

    .license-badge {
        padding: 2px 6px;
        border: 1px solid color-mix(in srgb, var(--color-aiki-blue) 45%, transparent);
        color: var(--color-text-muted);
    }

    .version-badge {
        padding: 2px 6px;
        border: 1px solid color-mix(in srgb, var(--color-aiki-blue) 45%, transparent);
        color: var(--color-text-muted);
    }
</style>
