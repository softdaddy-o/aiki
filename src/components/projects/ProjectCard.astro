---
import { t } from '../../i18n/utils';

interface Props {
    title: string;
    slug: string;
    summary: string;
    category: string;
    tags: string[];
    stars: number;
    license: string;
    lang: string;
}

const { title, slug, summary, category, tags, stars, license, lang } = Astro.props;
const categoryLabel = t(lang, `projects.category.${category}`);

function formatStars(value: number): string {
    if (value >= 1000) {
        const compact = (value / 1000).toFixed(1);
        return (compact.endsWith('.0') ? compact.slice(0, -2) : compact) + 'k';
    }
    return String(value);
}
---

<a
    href={`/${lang}/projects/${slug}/`}
    class="project-card"
    data-project-card
    data-title={title.toLowerCase()}
    data-summary={summary.toLowerCase()}
    data-tags={tags.join(' ').toLowerCase()}
    data-category={category}
>
    <div class="card-header">
        <h3 class="card-title">{title}</h3>
        <span class="category-badge">{categoryLabel}</span>
    </div>
    <p class="card-summary">{summary}</p>
    <div class="card-meta">
        <div class="card-tags">
            {tags.slice(0, 4).map((tag) => <span class="tag-pill">{tag}</span>)}
        </div>
        <div class="card-stats">
            <span class="stars-badge" title="GitHub Stars">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279L12 19.771l-7.416 3.642 1.48-8.279L0 9.306l8.332-1.151z"/></svg>
                {formatStars(stars)}
            </span>
            <span class="license-badge">{license}</span>
        </div>
    </div>
</a>

<style>
    .project-card {
        display: flex;
        flex-direction: column;
        gap: 12px;
        min-height: 210px;
        padding: 20px;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-left: 3px solid var(--color-projects);
        border-radius: 8px;
        text-decoration: none;
        color: var(--color-text);
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    }

    .project-card:hover {
        transform: translateY(-2px);
        background: var(--color-surface-elevated);
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.12);
        border-color: var(--color-projects);
    }

    .card-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 10px;
    }

    .card-title {
        font-size: var(--text-lg);
        font-weight: 700;
        line-height: 1.3;
        color: var(--color-text);
    }

    .category-badge {
        flex-shrink: 0;
        padding: 3px 8px;
        border-radius: 6px;
        background: color-mix(in srgb, var(--color-projects) 14%, transparent);
        color: var(--color-projects);
        font-size: var(--text-xs);
        font-weight: 700;
        white-space: nowrap;
    }

    .card-summary {
        display: -webkit-box;
        overflow: hidden;
        color: var(--color-text-muted);
        font-size: var(--text-sm);
        line-height: 1.55;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 3;
    }

    .card-meta {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 12px;
        margin-top: auto;
    }

    .card-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 5px;
    }

    .tag-pill,
    .license-badge {
        border-radius: 5px;
        font-size: 11px;
        line-height: 1.3;
    }

    .tag-pill {
        padding: 3px 7px;
        background: var(--color-surface-alt);
        color: var(--color-text-muted);
    }

    .card-stats {
        display: flex;
        align-items: center;
        flex-shrink: 0;
        gap: 8px;
    }

    .stars-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        color: var(--color-model);
        font-size: var(--text-xs);
        font-weight: 700;
    }

    .license-badge {
        padding: 2px 6px;
        border: 1px solid var(--color-border);
        color: var(--color-text-muted);
    }
</style>
