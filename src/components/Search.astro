---
interface Props {
    placeholder?: string;
    ariaLabel?: string;
}

const {
    placeholder = '검색...',
    ariaLabel = '검색',
} = Astro.props as Props;
---
<div class="search-container" data-search-placeholder={placeholder} data-search-aria-label={ariaLabel}>
    <div id="search"></div>
</div>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script is:inline src="/pagefind/pagefind-ui.js"></script>
<script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
        const searchRoot = document.getElementById('search');
        const searchContainer = document.querySelector('.search-container');
        if (!searchRoot || !searchContainer || typeof PagefindUI !== 'function') {
            return;
        }

        new PagefindUI({
            element: '#search',
            showSubResults: false,
            showImages: false,
        });

        const syncSearchInput = () => {
            const input = searchRoot.querySelector('.pagefind-ui__search-input');
            if (!(input instanceof HTMLInputElement)) {
                return;
            }

            const nextPlaceholder = searchContainer.getAttribute('data-search-placeholder') || '검색...';
            const nextAriaLabel = searchContainer.getAttribute('data-search-aria-label') || nextPlaceholder;
            input.placeholder = nextPlaceholder;
            input.setAttribute('aria-label', nextAriaLabel);
        };

        const observer = new MutationObserver(syncSearchInput);
        observer.observe(searchRoot, { childList: true, subtree: true });
        syncSearchInput();
    });
</script>

<style>
    .search-container {
        position: relative;
        flex: 0 1 230px;
        min-width: 190px;
        margin: 0;
    }

    :global(.search-container .pagefind-ui) {
        --pagefind-ui-primary: var(--color-news);
        --pagefind-ui-text: var(--color-text);
        --pagefind-ui-background: var(--color-surface-elevated);
        --pagefind-ui-border: var(--color-border-strong);
        --pagefind-ui-tag: var(--color-surface-alt);
        --pagefind-ui-border-width: 1px;
        --pagefind-ui-border-radius: 999px;
        --pagefind-ui-font: 'Pretendard Variable', Pretendard, -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
    }

    :global(.search-container .pagefind-ui__form) {
        position: relative;
    }

    :global(.search-container .pagefind-ui__search-input) {
        height: 34px;
        padding: 0 14px;
        border-radius: 999px;
        background: color-mix(in srgb, var(--color-surface-elevated) 92%, transparent);
        color: var(--color-text);
        font-size: 13px;
        box-shadow: none;
    }

    :global(.search-container .pagefind-ui__search-input::placeholder) {
        color: var(--color-text-muted);
        opacity: 1;
    }

    :global(.search-container .pagefind-ui__search-input:focus) {
        border-color: var(--color-news);
        box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-news) 12%, transparent);
    }

    :global(.search-container .pagefind-ui__search-clear) {
        top: 7px;
        right: 12px;
    }

    :global(.search-container .pagefind-ui__drawer) {
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        width: min(520px, calc(100vw - 32px));
        padding: 12px;
        border: 1px solid var(--color-border);
        border-radius: 16px;
        background: color-mix(in srgb, var(--color-surface) 94%, transparent);
        box-shadow: 0 18px 42px rgba(0, 0, 0, 0.18);
        backdrop-filter: blur(16px);
        z-index: 120;
    }

    :global(.search-container .pagefind-ui__message) {
        margin: 0 0 8px;
        color: var(--color-text-muted);
        font-size: 12px;
    }

    :global(.search-container .pagefind-ui__result) {
        padding: 10px 0;
    }

    :global(.search-container .pagefind-ui__result-link) {
        color: var(--color-text);
        font-weight: 700;
    }

    :global(.search-container .pagefind-ui__result-excerpt) {
        color: var(--color-text-muted);
        font-size: 12px;
        line-height: 1.55;
    }

    @media (max-width: 900px) {
        .search-container {
            flex-basis: 200px;
            min-width: 170px;
        }
    }

    @media (max-width: 640px) {
        .search-container {
            order: 10;
            flex: 1 0 100%;
            min-width: 0;
            margin-top: 8px;
        }

        :global(.search-container .pagefind-ui__drawer) {
            width: 100%;
        }
    }
</style>
