---
interface Props {
    title: string;
    url: string;
    text?: string;
    show?: boolean;
    label?: string;
}

const { title, url, text, label = 'Share this page' } = Astro.props as Props;
const { show = true } = Astro.props as Props;

const safeTitle = title.trim();
const safeText = text?.trim() ?? '';
const shortText = safeText.length > 120 ? `${safeText.slice(0, 117)}...` : safeText;
const shareText = `${safeTitle}${shortText ? ` - ${shortText}` : ''}`;

const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(safeTitle);
const encodedText = encodeURIComponent(shareText);

const shareLinks = [
    {
        name: 'X',
        label: 'X',
        href: `https://x.com/intent/tweet?text=${encodedText}&url=${encodedUrl}`,
        icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
        brand: '#000',
        darkBrand: '#e7e9ea',
    },
    {
        name: 'Threads',
        label: 'Threads',
        href: `https://www.threads.net/intent/post?text=${encodedText}%20${encodedUrl}`,
        icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017c.03-3.579.879-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717C4.307 6.504 3.616 8.914 3.589 12c.027 3.086.718 5.496 2.057 7.164 1.43 1.783 3.631 2.698 6.54 2.717 2.623-.02 4.358-.631 5.8-2.045 1.647-1.613 1.618-3.593 1.09-4.798-.31-.71-.873-1.3-1.634-1.75-.192 1.352-.622 2.446-1.284 3.272-.886 1.102-2.14 1.704-3.73 1.79-1.202.065-2.361-.218-3.259-.801-1.063-.689-1.685-1.74-1.752-2.964-.065-1.19.408-2.285 1.33-3.082.88-.76 2.119-1.207 3.583-1.291a13.853 13.853 0 0 1 3.02.142c-.126-.742-.375-1.332-.75-1.757-.513-.586-1.308-.883-2.359-.89h-.029c-.844 0-1.992.232-2.721 1.32L7.734 7.847c.98-1.454 2.568-2.256 4.478-2.256h.044c3.194.02 5.097 1.975 5.287 5.388.108.046.216.094.321.142 1.49.7 2.58 1.761 3.154 3.07.797 1.82.871 4.79-1.548 7.158-1.85 1.81-4.094 2.628-7.277 2.65Zm1.003-11.69c-.242 0-.487.007-.739.021-1.836.103-2.98.946-2.916 2.143.067 1.256 1.452 1.839 2.784 1.767 1.224-.065 2.818-.543 3.086-3.71a10.5 10.5 0 0 0-2.215-.221z"/></svg>`,
        brand: '#000',
        darkBrand: '#e7e9ea',
    },
    {
        name: 'Facebook',
        label: 'Facebook',
        href: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`,
        icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
        brand: '#1877F2',
        darkBrand: '#4599F7',
    },
    {
        name: 'LinkedIn',
        label: 'LinkedIn',
        href: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`,
        icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
        brand: '#0A66C2',
        darkBrand: '#3E9AE0',
    },
    {
        name: 'Reddit',
        label: 'Reddit',
        href: `https://www.reddit.com/submit?url=${encodedUrl}&title=${encodedTitle}`,
        icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 6.627 5.373 12 12 12s12-5.373 12-12c0-6.627-5.373-12-12-12zm6.066 13.5c.037.21.058.424.058.642 0 3.282-3.823 5.942-8.539 5.942S1.047 17.424 1.047 14.142c0-.218.02-.432.058-.642a1.693 1.693 0 01-.63-1.317c0-.938.76-1.698 1.698-1.698.472 0 .898.193 1.206.504 1.187-.813 2.824-1.336 4.678-1.394l.883-4.154a.377.377 0 01.45-.292l2.934.622a1.198 1.198 0 012.195.659 1.198 1.198 0 01-2.394.042l-2.622-.556-.79 3.714c1.835.07 3.45.595 4.623 1.4.308-.31.734-.504 1.206-.504a1.698 1.698 0 011.068 3.016zM8.27 13.8c0 .66.535 1.198 1.198 1.198.66 0 1.198-.535 1.198-1.198 0-.66-.535-1.198-1.198-1.198-.663 0-1.198.535-1.198 1.198zm7.46 3.393c-.077.077-1.007.863-3.724.863s-3.647-.79-3.724-.863a.377.377 0 01.534-.534c.02.02.877.66 3.19.66 2.316 0 3.174-.644 3.19-.66a.377.377 0 01.534.534zm-.263-2.195c.66 0 1.198-.535 1.198-1.198 0-.66-.535-1.198-1.198-1.198-.663 0-1.198.535-1.198 1.198 0 .66.535 1.198 1.198 1.198z"/></svg>`,
        brand: '#FF4500',
        darkBrand: '#FF6333',
    },
    {
        name: 'Bluesky',
        label: 'Bluesky',
        href: `https://bsky.app/intent/compose?text=${encodedText}%20${encodedUrl}`,
        icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.785 2.643 3.593 3.516 6.204 3.27-3.703.574-6.441 2.27-3.965 6.771 2.904 4.86 6.137-.566 7.137-3.088.137-.345.233-.667.285-.905.052.238.148.56.285.905 1 2.522 4.233 7.948 7.137 3.088 2.476-4.5-.262-6.197-3.965-6.771 2.611.246 5.42-.627 6.204-3.27.246-.828.624-5.79.624-6.479 0-.688-.139-1.86-.902-2.203-.659-.299-1.664-.621-4.3 1.24C12.046 4.747 9.087 8.686 12 10.8z"/></svg>`,
        brand: '#0085FF',
        darkBrand: '#3DA1FF',
    },
];
---

{show && (
    <section class="social-share" aria-label={label} data-share-title={safeTitle} data-share-url={url}>
        <div class="social-share-links" role="list">
            {shareLinks.map((item) => (
                <a
                    role="listitem"
                    href={item.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Share on ${item.name}`}
                    class={`share-pill share-${item.name.toLowerCase()}`}
                    style={`--brand: ${item.brand}; --brand-dark: ${item.darkBrand};`}
                    data-umami-event="share"
                    data-umami-event-platform={item.name}
                    data-umami-event-url={url}
                >
                    <span class="share-icon" aria-hidden="true">
                        <Fragment set:html={item.icon} />
                    </span>
                    <span>{item.label}</span>
                </a>
            ))}
        </div>
    </section>
)}

<style>
    .social-share {
        display: grid;
        gap: 8px;
    }

    .social-share-links {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .share-pill {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        min-height: 42px;
        padding: 0 11px 0 9px;
        border-radius: 9999px;
        border: 1px solid var(--color-border-strong);
        background: color-mix(in srgb, var(--color-surface-elevated) 84%, transparent);
        color: var(--color-text);
        font-size: 12.5px;
        font-weight: 700;
        line-height: 1;
        text-decoration: none;
        cursor: pointer;
        transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease, box-shadow 0.18s ease, color 0.18s ease;
    }

    .share-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 18px;
        height: 18px;
        border-radius: 999px;
        background: color-mix(in srgb, var(--brand) 12%, transparent);
        color: var(--brand);
        flex-shrink: 0;
    }

    html.dark .share-icon {
        background: color-mix(in srgb, var(--brand-dark) 18%, transparent);
        color: var(--brand-dark);
    }

    .share-pill :global(svg) {
        width: 12px;
        height: 12px;
        flex-shrink: 0;
    }

    .share-pill span:last-child {
        transform: translateY(-0.5px);
    }

    .share-threads :global(svg) {
        width: 11px;
        height: 11px;
    }

    .share-pill:hover {
        border-color: color-mix(in srgb, var(--brand) 40%, var(--color-border-strong));
        background: color-mix(in srgb, var(--brand) 10%, var(--color-surface-elevated));
        color: var(--color-text);
        transform: translateY(-1px);
        box-shadow: 0 6px 18px color-mix(in srgb, var(--brand) 14%, transparent);
    }

    .share-pill:hover .share-icon {
        background: var(--brand);
        color: #fff;
    }

    html.dark .share-pill:hover {
        border-color: color-mix(in srgb, var(--brand-dark) 50%, var(--color-border-strong));
        background: color-mix(in srgb, var(--brand-dark) 12%, var(--color-surface-elevated));
        box-shadow: 0 6px 18px color-mix(in srgb, var(--brand-dark) 12%, transparent);
    }

    html.dark .share-pill:hover .share-icon {
        background: var(--brand-dark);
        color: #000;
    }

    .share-pill:focus-visible {
        outline: 2px solid color-mix(in srgb, var(--brand) 55%, var(--color-news));
        outline-offset: 2px;
    }

    @media (max-width: 640px) {
        .share-pill {
            min-height: 40px;
            padding: 0 10px 0 8px;
            font-size: 12px;
        }
    }
</style>
