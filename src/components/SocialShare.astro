---

{show && (
    <section class="social-share" aria-label="Share this page" data-share-title={safeTitle} data-share-url={url}>
        <div class="social-share-links" role="list">
            {shareLinks.map((item) => (
                <a role="listitem" href={item.href} target="_blank" rel="noopener noreferrer" aria-label={`${item.name}에 공유`} title={item.name}
                    data-umami-event="share"
                    data-umami-event-platform={item.name}
                    data-umami-event-url={url}>
                    <Fragment set:html={item.icon} />
                </a>
            ))}
        </div>
    </section>
)}

<style>
    .social-share {
        margin-top: 24px;
        padding-top: 20px;
        border-top: 1px solid var(--color-border);
    }
    .social-share-links {
        display: flex;
        gap: 4px;
    }
    .social-share-links a {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 8px;
        color: var(--color-text-muted);
        text-decoration: none;
        cursor: pointer;
        transition: color 0.15s ease, background 0.15s ease;
    }
    .social-share-links a:hover {
        color: var(--color-text);
        background: var(--color-surface-alt);
    }
    .social-share-links svg {
        width: 18px;
        height: 18px;
    }
</style>
