---
import { t } from '../i18n/utils';
interface Props { lang: string; }
const { lang } = Astro.props;
---

<div class="newsletter">
    <h4>{t(lang, 'newsletter.title')}</h4>
    <p class="newsletter-subtitle">{t(lang, 'newsletter.coming_soon')}</p>
    <form action="https://buttondown.com/api/emails/embed-subscribe/aiki" method="post" target="_blank">
        <input type="email" name="email" placeholder={t(lang, 'newsletter.placeholder')} required />
        <button type="submit">{t(lang, 'newsletter.submit')}</button>
    </form>
</div>

<style>
    .newsletter {
        background: var(--color-surface); border: 1px solid var(--color-border);
        border-radius: 12px; padding: 32px 24px; margin-top: 48px; text-align: center;
    }
    .newsletter h4 { font-size: 18px; font-weight: 700; margin-bottom: 8px; }
    .newsletter-subtitle { font-size: 14px; color: var(--color-text-muted); margin-bottom: 16px; }
    .newsletter form { display: flex; gap: 8px; justify-content: center; }
    .newsletter input {
        background: var(--color-surface-alt); border: 1px solid #444;
        border-radius: 4px; padding: 8px 12px; color: var(--color-text);
        font-size: 13px; flex: 1; max-width: 240px;
    }
    .newsletter input:focus { outline: none; border-color: var(--color-news); box-shadow: 0 0 0 2px rgba(79, 195, 247, 0.2); }
    .newsletter button {
        background: var(--color-news); color: #000; border: none;
        border-radius: 6px; padding: 10px 20px; font-size: 14px;
        font-weight: 700; cursor: pointer;
        transition: background 0.2s ease, transform 0.15s ease;
    }
    .newsletter button:hover { background: #29b6f6; transform: translateY(-1px); }
    .newsletter button:active { transform: translateY(0); }
</style>
