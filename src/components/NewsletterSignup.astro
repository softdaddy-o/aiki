---
import { t } from '../i18n/utils';

interface Props {
    lang: string;
}

const { lang } = Astro.props;
const earlyListCopy = lang === 'ko'
    ? '첫 뉴스레터 공개 전에 얼리리스트에 먼저 이름을 올려두세요.'
    : 'Join the early list before the first newsletter goes live.';
---

<div class="newsletter">
    <div class="newsletter-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 7.5A2.5 2.5 0 0 1 5.5 5h13A2.5 2.5 0 0 1 21 7.5v9A2.5 2.5 0 0 1 18.5 19h-13A2.5 2.5 0 0 1 3 16.5z" />
            <path d="m4.5 7 7.5 6 7.5-6" />
        </svg>
    </div>
    <h4>{t(lang, 'newsletter.title')}</h4>
    <p class="newsletter-value">{earlyListCopy}</p>
    <p class="newsletter-subtitle">{t(lang, 'newsletter.coming_soon')}</p>
    <form action="https://buttondown.com/api/emails/embed-subscribe/aiki" method="post" target="_blank">
        <input type="email" name="email" placeholder={t(lang, 'newsletter.placeholder')} required />
        <button type="submit">{t(lang, 'newsletter.submit')}</button>
    </form>
</div>

<style>
    .newsletter {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 12px;
        padding: 32px 24px;
        margin-top: 48px;
        text-align: center;
    }

    .newsletter-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        margin-bottom: 10px;
        border-radius: 999px;
        background: color-mix(in srgb, var(--color-news) 12%, transparent);
        color: var(--color-news);
    }

    .newsletter-icon svg {
        width: 22px;
        height: 22px;
    }

    .newsletter h4 {
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .newsletter-value {
        font-size: 14px;
        color: var(--color-text);
        margin-bottom: 4px;
        line-height: 1.6;
    }

    .newsletter-subtitle {
        font-size: 13px;
        color: var(--color-text-muted);
        margin-bottom: 16px;
    }

    .newsletter form {
        display: flex;
        gap: 8px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .newsletter input {
        background: var(--color-surface-alt);
        border: 1px solid #444;
        border-radius: 6px;
        padding: 10px 12px;
        color: var(--color-text);
        font-size: 13px;
        flex: 1;
        max-width: 240px;
    }

    .newsletter input:focus {
        outline: none;
        border-color: var(--color-news);
        box-shadow: 0 0 0 2px rgba(79, 195, 247, 0.2);
    }

    .newsletter button {
        background: var(--color-news);
        color: #000;
        border: none;
        border-radius: 6px;
        min-height: 42px;
        padding: 0 20px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.2s ease, transform 0.15s ease;
    }

    .newsletter button:hover {
        background: #29b6f6;
        transform: translateY(-1px);
    }

    .newsletter button:active {
        transform: translateY(0);
    }
</style>
