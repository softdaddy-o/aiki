---
interface Props {
    lang: string;
}

const { lang } = Astro.props;

const tabs = [
    { key: 'daily', label: '일간' },
    { key: 'weekly', label: '주간' },
    { key: 'monthly', label: '월간' },
    { key: 'yearly', label: '연간' },
];
---

<div class="zoom-tabs">
    {tabs.map(tab => (
        <button
            class={`zoom-tab ${tab.key === 'daily' ? 'active' : ''}`}
            data-zoom={tab.key}
        >
            {tab.label}
        </button>
    ))}
</div>

<style>
    .zoom-tabs {
        display: flex;
        justify-content: flex-start;
        gap: 8px;
        margin-bottom: 22px;
        overflow-x: auto;
        padding-bottom: 2px;
    }
    .zoom-tab {
        min-height: 38px;
        padding: 0 16px;
        border: 1px solid var(--color-border);
        border-radius: 20px;
        background: color-mix(in srgb, var(--color-surface-elevated) 68%, transparent);
        color: var(--color-text-muted);
        font-size: 13px;
        font-weight: 750;
        cursor: pointer;
        transition: background 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;
        white-space: nowrap;
    }
    .zoom-tab:hover {
        background: rgba(255, 255, 255, 0.68);
    }
    .zoom-tab.active {
        background: var(--color-text);
        border-color: var(--color-text);
        color: #fff;
        box-shadow: 0 12px 26px rgba(10, 20, 38, 0.12);
    }
</style>
