---
interface ModelProfile {
    memoryUsage: string;
    implementation: string;
    activeParameters: string;
    multimodalSupport: string;
    access: string;
    pricing: string;
    weightsOpen: string;
    vendor: string;
}

const { profile } = Astro.props as { profile: ModelProfile };

const rows = [
    {
        label: '컨텍스트·메모리',
        value: profile.memoryUsage,
        description: '컨텍스트는 이 모델이 한 번에 버티는 길이야. 서비스형은 입력·출력 한도, 직접 돌리는 모델은 VRAM과 KV 캐시 부담까지 같이 봐.',
    },
    {
        label: '잘하는 일',
        value: profile.implementation,
        description: '이 모델을 어디에 쓰라고 밀고 있는지 보는 칸이야. 코딩, 추론, 멀티모달, 에이전트 작업처럼 쓰임새를 먼저 잡아.',
    },
    {
        label: '크기와 구조',
        value: profile.activeParameters,
        description: '파라미터가 공개됐으면 규모를, 비공개면 계열명·버전·운영 옵션을 단서로 삼아.',
    },
    {
        label: '입출력 범위',
        value: profile.multimodalSupport,
        description: '텍스트만 받는지, 이미지·음성·영상까지 다루는지, 출력은 어디까지 열려 있는지 확인해.',
    },
    {
        label: '붙이는 경로',
        value: profile.access,
        description: 'API, 제품 화면, 클라우드, 다운로드 중 어디로 붙는지 보는 칸이야. 실제 도입 경로를 고를 때 가장 먼저 쓰여.',
    },
    {
        label: '비용 감각',
        value: profile.pricing,
        description: '성능보다 예산으로 걸러야 할 때 보는 칸이야. 토큰 단가, 캐시, 자체 서빙 비용을 분리해서 읽어.',
    },
    {
        label: '웨이트 공개',
        value: profile.weightsOpen,
        description: '가중치를 내려받아 직접 돌릴 수 있는지, API로만 써야 하는지 확인하는 칸이야.',
    },
    {
        label: '만든 곳',
        value: profile.vendor,
        description: '같은 계열명처럼 보여도 만든 곳이 다르면 가격표, 접근 경로, 운영 조건이 달라질 수 있어.',
    },
];
---

<section class="model-profile">
    <div class="model-profile-head">
        <h3>모델 프로필</h3>
        <p>스펙표에서 먼저 헷갈리는 운영 단서만 모았어. 컨텍스트는 한 번에 붙잡고 볼 수 있는 길이, 메모리는 실제로 굴릴 때 필요한 자리로 나눠 읽으면 돼.</p>
    </div>
    <div class="model-profile-grid">
        {rows.map((row) => (
            <section class="model-profile-card">
                <span class="model-profile-label">{row.label}</span>
                <p class="model-profile-value">{row.value}</p>
                <p class="model-profile-description">{row.description}</p>
            </section>
        ))}
    </div>
</section>

<style>
    .model-profile {
        margin: 24px 0 30px;
        padding: 18px;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-xl);
        background:
            linear-gradient(140deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.42)),
            color-mix(in srgb, var(--color-model) 8%, var(--color-surface-elevated) 92%);
        box-shadow: var(--shadow-card);
        backdrop-filter: blur(22px) saturate(145%);
    }
    .model-profile-head {
        padding: 4px 4px 18px;
        border-bottom: 1px solid var(--color-border);
        margin-bottom: 16px;
        display: grid;
        gap: 8px;
    }
    .model-profile h3 {
        margin: 0;
        color: var(--color-text);
        font-family: var(--font-display);
        font-size: var(--text-3xl);
        line-height: 1.14;
    }
    .model-profile-head p {
        margin: 0;
        max-width: 680px;
        font-size: 13px;
        line-height: 1.72;
        color: var(--color-text-muted);
    }
    .model-profile-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }
    .model-profile-card {
        min-width: 0;
        padding: 15px;
        border: 1px solid var(--color-border);
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.42);
        display: grid;
        gap: 8px;
    }
    .model-profile-card:nth-child(even) {
        padding-left: 15px;
        border-right: 1px solid var(--color-border);
    }
    .model-profile-card:first-child {
        grid-column: 1 / -1;
        background:
            linear-gradient(90deg, rgba(123, 216, 207, 0.16), rgba(185, 167, 255, 0.16)),
            rgba(255, 255, 255, 0.5);
    }
    .model-profile-card:first-child::after {
        content: '';
        display: block;
        height: 12px;
        margin-top: 4px;
        border-radius: 999px;
        background: linear-gradient(90deg, var(--color-aiki-cyan), var(--color-aiki-blue), var(--color-aiki-violet));
        box-shadow: 0 10px 26px color-mix(in srgb, var(--color-aiki-blue) 24%, transparent);
    }
    .model-profile-label {
        display: inline-block;
        font-size: 11px;
        font-weight: 850;
        letter-spacing: 0;
        color: var(--color-model);
    }
    .model-profile-value,
    .model-profile-description {
        margin: 0;
    }
    .model-profile-value {
        font-size: 13px;
        line-height: 1.62;
        color: var(--color-text);
        font-weight: 760;
    }
    .model-profile-description {
        font-size: 12px;
        line-height: 1.6;
        color: var(--color-text-muted);
    }
    @media (max-width: 640px) {
        .model-profile-grid {
            grid-template-columns: minmax(0, 1fr);
        }
        .model-profile-card,
        .model-profile-card:nth-child(even) {
            padding-left: 15px;
            border-right: 1px solid var(--color-border);
        }
    }
</style>
