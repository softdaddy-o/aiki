---
import NewsCard from './NewsCard.astro';

interface NewsItem {
    title: string;
    summary: string;
    date: string;
    category: string;
    factCheckStatus?: string;
    factCheckSourceCount?: number;
    score?: number;
    sourceCount?: number;
    slug: string;
    zoomLevel?: string;
}

interface DateGroup {
    date: string;
    label: string;
    items: NewsItem[];
}

interface Props {
    items: NewsItem[];
    lang: string;
    dateGroups?: DateGroup[];
}

const { items, lang, dateGroups } = Astro.props;
let globalIndex = 0;
---

<div class="timeline">
    <div class="timeline-line"></div>
    {dateGroups ? (
        dateGroups.map(group => (
            <>
                <div class="date-header" data-zoom-level={group.items[0]?.zoomLevel}>
                    <div class="date-marker"></div>
                    <span class="date-label">{group.label}</span>
                </div>
                {group.items.map(item => {
                    const i = globalIndex++;
                    return <NewsCard {...item} side={i % 2 === 0 ? 'right' : 'left'} lang={lang} featured={i === 0} />;
                })}
            </>
        ))
    ) : (
        items.map((item, i) => (
            <NewsCard {...item} side={i % 2 === 0 ? 'right' : 'left'} lang={lang} featured={i === 0} />
        ))
    )}
</div>

<style>
    .timeline { position: relative; padding: 32px 0; }
    .timeline-line {
        position: absolute; left: 50%; top: 0; bottom: 0;
        width: 3px; transform: translateX(-50%);
        background: linear-gradient(to bottom, var(--color-news), var(--color-wiki), var(--color-tutorial), var(--color-model), var(--color-news));
        opacity: 0.5;
        box-shadow: 0 0 8px rgba(79, 195, 247, 0.15);
    }
    .date-header {
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        z-index: 3;
        margin: 32px 0 20px;
        opacity: 0;
        transform: translateY(8px);
        transition: opacity 0.3s ease-out, transform 0.3s ease-out;
    }
    .date-header:first-child { margin-top: 0; }
    .date-header.visible {
        opacity: 1;
        transform: translateY(0);
    }
    .date-marker {
        width: 18px; height: 18px;
        border-radius: 50%;
        background: var(--color-news);
        border: 3px solid var(--color-bg);
        box-shadow: 0 0 16px rgba(79, 195, 247, 0.5);
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
    }
    .date-label {
        background: var(--color-surface);
        padding: 6px 20px;
        border: 1px solid rgba(79, 195, 247, 0.25);
        border-radius: 20px;
        font-size: 14px;
        font-weight: 600;
        color: var(--color-news);
        letter-spacing: 0.02em;
        font-family: var(--font-heading);
        box-shadow: 0 0 12px rgba(79, 195, 247, 0.1);
    }
    @media (max-width: 640px) {
        .timeline-line { display: none; }
        .timeline { padding: 16px 0; }
        .date-marker { display: none; }
        .date-header {
            justify-content: flex-start;
            margin: 20px 0 10px;
        }
        .date-label {
            font-size: 13px;
            padding: 6px 14px;
        }
    }
</style>
