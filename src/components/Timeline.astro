---
import NewsCard from './NewsCard.astro';

interface NewsItem {
    title: string;
    summary: string;
    date: string;
    category: string;
    factCheckStatus?: string;
    factCheckSourceCount?: number;
    score?: number;
    sourceCount?: number;
    slug: string;
    zoomLevel?: string;
}

interface DateGroup {
    date: string;
    label: string;
    items: NewsItem[];
}

interface Props {
    items: NewsItem[];
    lang: string;
    dateGroups?: DateGroup[];
}

const { items, lang, dateGroups } = Astro.props;
let globalIndex = 0;
---

<div class="timeline">
    <div class="timeline-line"></div>
    {dateGroups ? (
        dateGroups.map(group => (
            <>
                <div class="date-header" data-zoom-level={group.items[0]?.zoomLevel}>
                    <div class="date-marker"></div>
                    <span class="date-label">{group.label}</span>
                </div>
                {group.items.map(item => {
                    const i = globalIndex++;
                    return <NewsCard {...item} side={i % 2 === 0 ? 'right' : 'left'} lang={lang} featured={i === 0} />;
                })}
            </>
        ))
    ) : (
        items.map((item, i) => (
            <NewsCard {...item} side={i % 2 === 0 ? 'right' : 'left'} lang={lang} featured={i === 0} />
        ))
    )}
</div>

<style is:global>
    .timeline {
        position: relative;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
        padding: 8px 0 24px;
    }
    .timeline-line {
        display: none;
    }
    .date-header {
        grid-column: 1 / -1;
        display: flex;
        align-items: center;
        justify-content: flex-start;
        padding-left: 0;
        position: relative;
        z-index: 3;
        margin: 16px 0 0;
        opacity: 1;
        transform: none;
        transition: opacity 0.3s ease-out, transform 0.3s ease-out;
    }
    .date-header:first-child { margin-top: 0; }
    .date-header.visible {
        opacity: 1;
        transform: translateY(0);
    }
    .date-marker {
        display: none;
    }
    .date-label {
        background: color-mix(in srgb, var(--color-surface-elevated) 74%, transparent);
        padding: 7px 12px;
        border: 1px solid var(--color-border);
        border-radius: 999px;
        font-size: 13px;
        font-weight: 800;
        color: var(--color-text-muted);
        letter-spacing: 0;
        font-family: var(--font-heading);
        box-shadow: 0 10px 26px rgba(40, 58, 90, 0.06);
        backdrop-filter: blur(14px);
    }
    .timeline > .timeline-item.featured {
        grid-column: span 2;
    }
    @media (max-width: 760px) {
        .timeline {
            grid-template-columns: minmax(0, 1fr);
        }
        .timeline > .timeline-item.featured {
            grid-column: auto;
        }
    }
    @media (prefers-reduced-motion: reduce) {
        .date-header {
            opacity: 1;
            transform: none;
            transition: none;
        }
    }
</style>
