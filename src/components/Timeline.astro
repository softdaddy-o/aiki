---
import NewsCard from './NewsCard.astro';

interface NewsItem {
    title: string;
    summary: string;
    date: string;
    category: string;
    factCheckStatus?: string;
    factCheckSourceCount?: number;
    score?: number;
    sourceCount?: number;
    slug: string;
    zoomLevel?: string;
}

interface DateGroup {
    date: string;
    label: string;
    items: NewsItem[];
}

interface Props {
    items: NewsItem[];
    lang: string;
    dateGroups?: DateGroup[];
}

const { items, lang, dateGroups } = Astro.props;
let globalIndex = 0;
---

<div class="timeline">
    <div class="timeline-line"></div>
    {dateGroups ? (
        dateGroups.map(group => (
            <>
                <div class="date-header" data-zoom-level={group.items[0]?.zoomLevel}>
                    <div class="date-marker"></div>
                    <span class="date-label">{group.label}</span>
                </div>
                {group.items.map(item => {
                    const i = globalIndex++;
                    return <NewsCard {...item} side={i % 2 === 0 ? 'right' : 'left'} lang={lang} featured={i === 0} />;
                })}
            </>
        ))
    ) : (
        items.map((item, i) => (
            <NewsCard {...item} side={i % 2 === 0 ? 'right' : 'left'} lang={lang} featured={i === 0} />
        ))
    )}
</div>

<style is:global>
    /* Always single-column with left-aligned timeline */
    .timeline { position: relative; padding: 16px 0; }
    .timeline-line {
        position: absolute; left: 16px; top: 0; bottom: 0;
        width: 3px;
        background: var(--color-border-strong);
        opacity: 0.55;
    }
    .date-header {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        padding-left: 40px;
        position: relative;
        z-index: 3;
        margin: 24px 0 12px;
        opacity: 0;
        transform: translateY(8px);
        transition: opacity 0.3s ease-out, transform 0.3s ease-out;
    }
    .date-header:first-child { margin-top: 0; }
    .date-header.visible {
        opacity: 1;
        transform: translateY(0);
    }
    .date-marker {
        width: 16px; height: 16px;
        border-radius: 50%;
        background: var(--color-news);
        border: 3px solid var(--color-bg);
        position: absolute;
        left: 16px;
        transform: translateX(-50%);
    }
    .date-label {
        background: var(--color-surface);
        padding: 6px 14px;
        border: 1px solid rgba(79, 195, 247, 0.25);
        border-radius: 20px;
        font-size: 13px;
        font-weight: 700;
        color: var(--color-news);
        letter-spacing: 0.02em;
        font-family: var(--font-heading);
        box-shadow: 0 0 12px rgba(79, 195, 247, 0.1);
    }
    @media (prefers-reduced-motion: reduce) {
        .date-header {
            opacity: 1;
            transform: none;
            transition: none;
        }
    }
</style>
