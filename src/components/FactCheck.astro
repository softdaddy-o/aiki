---
interface Check {
    type: string;
    result: string;
    sources?: number;
    summary?: string;
    items?: string[];
    findings?: string[];
}

interface Source {
    url: string;
    title: string;
}

interface Props {
    status: string;
    date: string;
    checks: Check[];
    sources: Source[];
    lang: string;
}

type Locale = 'ko' | 'en';

const { status, date, checks, sources, lang } = Astro.props as Props;
const locale: Locale = lang === 'ko' ? 'ko' : 'en';

const copy = {
    ko: {
        title: '팩트 체크',
        generated: '검증 생성',
        generatedMethod: 'AI + 편집 검토',
        status: '상태',
        sourceCount: '검증 출처',
        sources: '출처',
        lastChecked: '마지막 검증',
        reportIssue: '오류 제보',
        expandAll: '전체 보기',
        collapseAll: '전체 접기',
        statuses: {
            passed: '통과',
            failed: '실패',
            pending: '검토 중',
        },
        results: {
            pass: '통과',
            skip: '보류',
            fail: '실패',
        },
        labels: {
            source_match: '원문 대조',
            web_cross_check: '교차 검증',
            number_verify: '수치 검증',
            adversarial: '비판 검토',
        },
        fallbackSummary: (check: Check) => {
            if (check.type === 'source_match') return '본문 설명이 원문 출처와 같은 대상을 가리키는지 먼저 맞춰봤어.';
            if (check.type === 'web_cross_check') return `관련 출처 ${check.sources ?? sources.length}건을 나란히 놓고 핵심 주장 충돌이 없는지 다시 봤어.`;
            if (check.type === 'number_verify') return '숫자, 버전, 고유명칭처럼 틀리기 쉬운 항목만 따로 떼어 확인했어.';
            if (check.type === 'adversarial') return '독자가 과하게 받아들일 수 있는 부분이 없는지 일부러 비판적으로 다시 읽었어.';
            return '';
        },
    },
    en: {
        title: 'Fact Check',
        generated: 'Verification',
        generatedMethod: 'AI + editorial review',
        status: 'Status',
        sourceCount: 'Sources',
        sources: 'Sources',
        lastChecked: 'Last checked',
        reportIssue: 'Report an issue',
        expandAll: 'Expand all',
        collapseAll: 'Collapse all',
        statuses: {
            passed: 'Passed',
            failed: 'Failed',
            pending: 'Pending',
        },
        results: {
            pass: 'PASS',
            skip: 'SKIP',
            fail: 'FAIL',
        },
        labels: {
            source_match: 'Source Match',
            web_cross_check: 'Cross Verification',
            number_verify: 'Number Verification',
            adversarial: 'Adversarial Review',
        },
        fallbackSummary: (check: Check) => {
            if (check.type === 'source_match') return 'The core description was compared against the primary source before publishing.';
            if (check.type === 'web_cross_check') return `The main claim was cross-checked against ${check.sources ?? sources.length} public sources.`;
            if (check.type === 'number_verify') return 'Numbers, versions, and named entities were verified separately.';
            if (check.type === 'adversarial') return 'The copy was reread with a skeptical lens to catch overclaiming.';
            return '';
        },
    },
}[locale];

function checkLabel(type: string) {
    return copy.labels[type as keyof typeof copy.labels] ?? type;
}

function resultLabel(result: string) {
    return copy.results[result as keyof typeof copy.results] ?? result.toUpperCase();
}

function statusLabel(value: string) {
    return copy.statuses[value as keyof typeof copy.statuses] ?? value;
}

function cleanText(text?: string) {
    return String(text || '').replace(/\s+/g, ' ').trim();
}

function uniqueStrings(values: string[]) {
    const seen = new Set<string>();
    const normalizedValues: string[] = [];

    for (const value of values) {
        const normalized = cleanText(value);
        if (!normalized) continue;
        if (seen.has(normalized)) continue;
        seen.add(normalized);
        normalizedValues.push(normalized);
    }

    return normalizedValues;
}

function fallbackItems(check: Check) {
    if (Array.isArray(check.items) && check.items.length > 0) return check.items;
    if (check.type === 'source_match') return sources.slice(0, 2).map((source) => source.title);
    if (check.type === 'web_cross_check') return sources.map((source) => source.title);
    return [];
}

const visibleChecks = checks
    .map((check) => {
        const preview = cleanText(check.summary || copy.fallbackSummary(check));
        const detailItems = uniqueStrings(fallbackItems(check)).filter((item) => item !== preview);
        const findingItems = uniqueStrings(Array.isArray(check.findings) ? check.findings : []).filter(
            (item) => item !== preview && !detailItems.includes(item),
        );

        return {
            ...check,
            label: checkLabel(check.type),
            preview,
            detailItems,
            findingItems,
        };
    })
    .filter((check) => check.preview || check.detailItems.length > 0 || check.findingItems.length > 0);
---

<section class="factcheck">
    <div class="fc-header">
        <div>
            <div class="fc-title">{copy.title}</div>
            <div class="fc-meta-inline">{statusLabel(status)} · {date} KST</div>
        </div>
        {visibleChecks.length > 0 && (
            <button type="button" class="fc-expand-all" data-fc-toggle-all aria-expanded="false">
                {copy.expandAll}
            </button>
        )}
    </div>

    <div class="fc-body">
        <div class="fc-meta">
            <span>{copy.generated}: {copy.generatedMethod} · {date}</span>
            <span>{copy.status}: {statusLabel(status)}</span>
        </div>

        {visibleChecks.length > 0 && (
            <div class="fc-summary-grid">
                {visibleChecks.map((check) => (
                    <details class="fc-summary-card" data-fc-item>
                        <summary class="fc-summary-toggle">
                            <div class="fc-summary-head">
                                <span class:list={[
                                    'fc-result-badge',
                                    check.result === 'pass' ? 'check-pass' : check.result === 'skip' ? 'check-skip' : 'check-fail',
                                ]}>
                                    {resultLabel(check.result)}
                                </span>
                                <span class="fc-summary-title">{check.label}</span>
                                {typeof check.sources === 'number' && (
                                    <span class="check-detail">{copy.sourceCount} {check.sources}</span>
                                )}
                            </div>
                            {check.preview && <div class="fc-summary-preview">{check.preview}</div>}
                        </summary>
                        <div class="fc-summary-body">
                            {check.detailItems.length > 0 && (
                                <ul class="fc-group-list">
                                    {check.detailItems.map((item) => (
                                        <li>{item}</li>
                                    ))}
                                </ul>
                            )}
                            {check.findingItems.length > 0 && (
                                <ul class="fc-group-list fc-findings">
                                    {check.findingItems.map((finding) => (
                                        <li>{finding}</li>
                                    ))}
                                </ul>
                            )}
                        </div>
                    </details>
                ))}
            </div>
        )}

        {sources.length > 0 && (
            <div class="fc-sources-list">
                {copy.sources}:{' '}
                {sources.map((source, index) => (
                    <>
                        {index > 0 && ', '}
                        <a href={source.url} target="_blank" rel="noopener noreferrer" data-link-kind="external">{source.title}</a>
                    </>
                ))}
            </div>
        )}

        <div class="fc-footer">
            {copy.lastChecked} {date} KST ·
            <a href="https://github.com/softdaddy-o/aiki/issues/new"> {copy.reportIssue}</a>
        </div>
    </div>
</section>

<style>
    .factcheck {
        margin-top: 40px;
        padding: 18px;
        background: color-mix(in srgb, var(--color-surface-elevated) 74%, transparent);
        border-radius: var(--radius-lg);
        border: 1px solid var(--color-border);
        box-shadow: var(--shadow-card);
        backdrop-filter: blur(18px);
        font-size: 13px;
    }
    .factcheck summary {
        list-style: none;
    }
    .factcheck summary::-webkit-details-marker {
        display: none;
    }
    .fc-header {
        margin-bottom: 14px;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
    }
    .fc-title {
        margin-bottom: 4px;
        font-size: 14px;
        font-weight: 800;
        color: var(--color-text);
    }
    .fc-meta-inline,
    .fc-meta,
    .check-detail,
    .fc-summary-preview,
    .fc-group-list,
    .fc-sources-list,
    .fc-footer {
        color: var(--color-text-muted);
    }
    .fc-meta-inline,
    .fc-meta,
    .check-detail,
    .fc-summary-preview,
    .fc-sources-list {
        font-size: 12px;
    }
    .fc-meta {
        display: flex;
        flex-direction: column;
        gap: 4px;
        margin-bottom: 12px;
    }
    .fc-summary-grid {
        display: grid;
        gap: 12px;
        margin-bottom: 12px;
    }
    .fc-summary-card {
        background: rgba(255, 255, 255, 0.42);
        border: 1px solid var(--color-border);
        border-radius: 16px;
    }
    .fc-summary-toggle {
        display: block;
        cursor: pointer;
        padding: 12px;
    }
    .fc-summary-head {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 6px;
    }
    .fc-result-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 48px;
        padding: 3px 8px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 800;
        line-height: 1.1;
    }
    .fc-summary-title {
        font-weight: 700;
    }
    .fc-summary-preview {
        line-height: 1.6;
    }
    .fc-summary-body {
        padding: 0 12px 12px;
    }
    .fc-expand-all {
        appearance: none;
        border: 1px solid color-mix(in srgb, var(--color-border) 80%, transparent);
        background: rgba(255, 255, 255, 0.48);
        color: var(--color-text);
        border-radius: 999px;
        padding: 6px 12px;
        font-size: 12px;
        line-height: 1.2;
        cursor: pointer;
    }
    .fc-expand-all:hover,
    .fc-expand-all:focus-visible {
        border-color: var(--color-aiki-blue);
        outline: none;
    }
    .check-pass {
        background: color-mix(in srgb, var(--color-pass) 18%, transparent);
        color: var(--color-pass);
    }
    .check-fail {
        background: color-mix(in srgb, var(--color-fail) 18%, transparent);
        color: var(--color-fail);
    }
    .check-skip {
        background: color-mix(in srgb, var(--color-text-muted) 14%, transparent);
        color: var(--color-text-muted);
    }
    .fc-group-list {
        margin: 0;
        padding-left: 18px;
        line-height: 1.6;
    }
    .fc-group-list li + li {
        margin-top: 5px;
    }
    .fc-findings {
        margin-top: 8px;
    }
    .fc-sources-list a,
    .fc-footer a {
        color: var(--color-aiki-blue);
    }
    .fc-sources-list a::after {
        content: '↗';
        display: inline-block;
        margin-left: 0.22em;
        font-size: 0.78em;
        line-height: 1;
        vertical-align: text-top;
    }
    .fc-footer {
        font-size: 11px;
        padding-top: 8px;
        border-top: 1px solid var(--color-border);
    }
    @media (max-width: 640px) {
        .factcheck {
            padding: 16px;
        }
        .fc-header {
            flex-direction: column;
        }
    }
</style>

<script is:inline>
    document.querySelectorAll('[data-fc-toggle-all]').forEach((button) => {
        const container = button.closest('.factcheck');
        if (!container) return;

        const items = Array.from(container.querySelectorAll('[data-fc-item]'));
        if (items.length === 0) return;

        const expandLabel = button.textContent?.trim() || 'Expand all';
        const collapseLabel = button.getAttribute('data-collapse-label')
            || (expandLabel === '전체 보기' ? '전체 접기' : 'Collapse all');

        button.setAttribute('data-collapse-label', collapseLabel);

        const syncLabel = () => {
            const allOpen = items.every((item) => item.open);
            button.textContent = allOpen ? collapseLabel : expandLabel;
            button.setAttribute('aria-expanded', allOpen ? 'true' : 'false');
        };

        button.addEventListener('click', () => {
            const shouldOpen = !items.every((item) => item.open);
            items.forEach((item) => {
                item.open = shouldOpen;
            });
            syncLabel();
        });

        items.forEach((item) => item.addEventListener('toggle', syncLabel));

        syncLabel();
    });
</script>
