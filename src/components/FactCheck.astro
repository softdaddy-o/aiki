---
interface Check {
    type: string;
    result: string;
    sources?: number;
    summary?: string;
    items?: string[];
    findings?: string[];
}

interface Source {
    url: string;
    title: string;
}

interface Props {
    status: string;
    date: string;
    checks: Check[];
    sources: Source[];
    lang: string;
}

const { status, date, checks, sources } = Astro.props as Props;
const statusIcon = status === 'passed' ? 'OK' : status === 'failed' ? 'FAIL' : 'PENDING';

function checkLabel(type: string) {
    if (type === 'source_match') return '원문 대조';
    if (type === 'web_cross_check') return '교차검증';
    if (type === 'number_verify') return '숫자·명칭 검증';
    if (type === 'adversarial') return '비판적 검증';
    return type;
}

function resultIcon(result: string) {
    if (result === 'pass') return 'OK';
    if (result === 'skip') return 'SKIP';
    return 'FAIL';
}

function fallbackSummary(check: Check) {
    if (check.type === 'source_match') return '대표 원문과 제목 축이 맞는지 먼저 대조했다.';
    if (check.type === 'web_cross_check') return `관련 출처 ${check.sources ?? sources.length}건을 교차검토했다.`;
    if (check.type === 'number_verify') return '숫자와 고유 명칭을 따로 묶어 다시 확인했다.';
    if (check.type === 'adversarial') return '헷갈리기 쉬운 해석 포인트를 비판적으로 점검했다.';
    return '';
}

function fallbackItems(check: Check) {
    if (check.items && check.items.length > 0) {
        return check.items;
    }

    if (check.type === 'source_match') {
        return sources.slice(0, 2).map((source) => `${source.title} (${source.url})`);
    }

    if (check.type === 'web_cross_check') {
        return sources.map((source, index) => `비교 출처 ${index + 1}: ${source.title}`);
    }

    return [];
}
---

<section class="factcheck">
    <h4 class="fc-title">팩트 체크</h4>
    <div class="fc-meta">
        <span>검증 생성: AI + 수집 스크립트 · {date}</span>
        <span>상태: {statusIcon}</span>
    </div>

    <div class="fc-checks">
        {checks.map((check) => (
            <div class="fc-check">
                <span class={check.result === 'pass' ? 'check-pass' : check.result === 'skip' ? 'check-skip' : 'check-fail'}>
                    {resultIcon(check.result)}
                </span>
                <span>{checkLabel(check.type)}</span>
                {typeof check.sources === 'number' && <span class="check-detail">검토 출처 {check.sources}건</span>}
            </div>
        ))}
    </div>

    <div class="fc-groups">
        {checks.map((check) => (
            ((check.summary && check.summary.trim()) || fallbackItems(check).length > 0 || (check.findings && check.findings.length > 0) || fallbackSummary(check)) && (
                <details class="fc-group">
                    <summary>
                        <span class={check.result === 'pass' ? 'check-pass' : check.result === 'skip' ? 'check-skip' : 'check-fail'}>
                            {resultIcon(check.result)}
                        </span>
                        <span>{checkLabel(check.type)}</span>
                    </summary>
                    {(check.summary || fallbackSummary(check)) && <p class="fc-group-summary">{check.summary || fallbackSummary(check)}</p>}
                    {fallbackItems(check).length > 0 && (
                        <ul class="fc-group-list">
                            {fallbackItems(check).map((item) => (
                                <li>{item}</li>
                            ))}
                        </ul>
                    )}
                    {check.findings && check.findings.length > 0 && (
                        <ul class="fc-group-list fc-findings">
                            {check.findings.map((finding) => (
                                <li>{finding}</li>
                            ))}
                        </ul>
                    )}
                </details>
            )
        ))}
    </div>

    {sources.length > 0 && (
        <div class="fc-sources-list">
            출처: {sources.map((source, index) => (
                <>{index > 0 && ', '}<a href={source.url} target="_blank" rel="noopener">{source.title}</a></>
            ))}
        </div>
    )}

    <div class="fc-footer">
        마지막 검증 {date} KST ·
        <a href="https://github.com/softdaddy-o/aiki/issues/new"> 오류 제보</a>
    </div>
</section>

<style>
