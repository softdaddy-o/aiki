---
interface Check {
    type: string;
    result: string;
    sources?: number;
    summary?: string;
    items?: string[];
    findings?: string[];
}

interface Source {
    url: string;
    title: string;
}

interface Props {
    status: string;
    date: string;
    checks: Check[];
    sources: Source[];
    lang: string;
}

const { status, date, checks, sources } = Astro.props as Props;
const statusIcon = status === 'passed' ? 'OK' : status === 'failed' ? 'FAIL' : 'PENDING';

function checkLabel(type: string) {
    if (type === 'source_match') return '원문 대조';
    if (type === 'web_cross_check') return '교차검증';
    if (type === 'number_verify') return '숫자·명칭 검증';
    if (type === 'adversarial') return '비판적 검증';
    return type;
}

function resultIcon(result: string) {
    if (result === 'pass') return 'OK';
    if (result === 'skip') return 'SKIP';
    return 'FAIL';
}

function fallbackSummary(check: Check) {
    if (check.type === 'source_match') return '이 글이 정말 같은 대상과 사건을 짚는지부터 먼저 확인해뒀어.';
    if (check.type === 'web_cross_check') return `관련 출처 ${check.sources ?? sources.length}건을 나란히 놓고 설명 축이 어긋나지 않는지 비교해뒀어.`;
    if (check.type === 'number_verify') return '헷갈리기 쉬운 숫자와 고유 명칭은 따로 검증해뒀어.';
    if (check.type === 'adversarial') return '오해하기 쉬운 지점은 어디서 잘못 읽히는지까지 따로 분리해뒀어.';
    return '';
}

function fallbackItems(check: Check) {
    if (check.items && check.items.length > 0) {
        return check.items;
    }

    if (check.type === 'source_match') {
        return sources.slice(0, 2).map((source) => `${source.title} (${source.url})`);
    }

    if (check.type === 'web_cross_check') {
        return sources.map((source, index) => `비교 출처 ${index + 1}: ${source.title}`);
    }

    return [];
}

function normalizeFactCheckText(text: string) {
    return String(text || '')
        .replace(/\s+/g, ' ')
        .replace(/한 번 더 다시 봤다/g, '한 번 더 확인해뒀어')
        .replace(/한 번 더 봤다/g, '따로 검증해뒀어')
        .replace(/다시 봤다/g, '비교해뒀어')
        .replace(/맞춰봤다/g, '확인해뒀어')
        .replace(/확인해봤다/g, '확인해뒀어')
        .replace(/걸렀다/g, '걸러뒀어')
        .replace(/봤다/g, '확인했어')
        .replace(/해준다/g, '도움이 된다')
        .replace(/판단하게 도움[이가] 된다/g, '판단하는 데 도움이 된다')
        .replace(/읽게 도움[이가] 된다/g, '읽는 데 도움이 된다')
        .replace(/구분하게 도움[이가] 된다/g, '구분하는 데 도움이 된다')
        .replace(/잡게 도움[이가] 된다/g, '큰 흐름을 잡는 데 도움이 된다')
        .replace(/나뉜다/g, '갈린다')
        .replace(/정리해뒀다/g, '따로 정리해뒀어')
        .trim();
}

function uniqueStrings(values: string[]) {
    const seen = new Set<string>();
    const result: string[] = [];

    for (const value of values) {
        const normalized = normalizeFactCheckText(value);
        if (!normalized) continue;
        const key = normalized.replace(/\s+/g, ' ').trim();
        if (seen.has(key)) continue;
        seen.add(key);
        result.push(normalized);
    }

    return result;
}

const visibleChecks = checks
    .map((check) => {
        const detailItems = uniqueStrings(fallbackItems(check));
        const findingItems = uniqueStrings(Array.isArray(check.findings) ? check.findings : []);
        const preview = normalizeFactCheckText(String(check.summary || fallbackSummary(check) || '').trim());

        return {
            ...check,
            label: checkLabel(check.type),
            preview,
            detailItems: detailItems.filter((item) => item !== preview),
            findingItems: findingItems.filter((item) => item !== preview && !detailItems.includes(item)),
        };
    })
    .filter((check) => check.preview || check.detailItems.length > 0 || check.findingItems.length > 0);
---

<section class="factcheck">
    <div class="fc-header">
        <div>
            <div class="fc-title">팩트 체크</div>
            <div class="fc-meta-inline">상태 {statusIcon} · {date} KST</div>
        </div>
        {visibleChecks.length > 0 && (
            <button type="button" class="fc-expand-all" data-fc-toggle-all aria-expanded="false">전체 보기</button>
        )}
    </div>

    <div class="fc-body">
        <div class="fc-meta">
            <span>검증 생성: AI + 수집 스크립트 · {date}</span>
            <span>상태: {statusIcon}</span>
        </div>

        {visibleChecks.length > 0 && (
            <div class="fc-summary-grid">
                {visibleChecks.map((check) => (
                    <details class="fc-summary-card" data-fc-item>
                        <summary class="fc-summary-toggle">
                            <div class="fc-summary-head">
                                <span class={check.result === 'pass' ? 'check-pass' : check.result === 'skip' ? 'check-skip' : 'check-fail'}>
                                    {resultIcon(check.result)}
                                </span>
                                <span class="fc-summary-title">{check.label}</span>
                                {typeof check.sources === 'number' && <span class="check-detail">검토 출처 {check.sources}건</span>}
                            </div>
                            {check.preview && <div class="fc-summary-preview">{check.preview}</div>}
                        </summary>
                        <div class="fc-summary-body">
                            {check.detailItems.length > 0 && (
                                <ul class="fc-group-list">
                                    {check.detailItems.map((item) => (
                                        <li>{item}</li>
                                    ))}
                                </ul>
                            )}
                            {check.findingItems.length > 0 && (
                                <ul class="fc-group-list fc-findings">
                                    {check.findingItems.map((finding) => (
                                        <li>{finding}</li>
                                    ))}
                                </ul>
                            )}
                        </div>
                    </details>
                ))}
            </div>
        )}

        {sources.length > 0 && (
            <div class="fc-sources-list">
                출처: {sources.map((source, index) => (
                    <>{index > 0 && ', '}<a href={source.url} target="_blank" rel="noopener">{source.title}</a></>
                ))}
            </div>
        )}

        <div class="fc-footer">
            마지막 검증 {date} KST ·
            <a href="https://github.com/softdaddy-o/aiki/issues/new"> 오류 제보</a>
        </div>
    </div>
</section>

<style>
    .factcheck {
        margin-top: 40px;
        padding: 20px 24px;
        background: var(--color-surface);
        border-radius: 10px;
        border: 1px solid var(--color-border);
        font-size: 13px;
    }
    .factcheck summary {
        list-style: none;
    }
    .factcheck summary::-webkit-details-marker {
        display: none;
    }
    .fc-header {
        margin-bottom: 14px;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
    }
    .fc-title {
        font-size: 14px;
        margin-bottom: 4px;
    }
    .fc-meta-inline {
        color: var(--color-text-muted);
        font-size: 12px;
    }
    .fc-meta {
        display: flex;
        flex-direction: column;
        gap: 4px;
        color: var(--color-text-muted);
        margin-bottom: 12px;
        font-size: 12px;
    }
    .check-pass {
        color: var(--color-pass);
        font-weight: 700;
    }
    .check-fail {
        color: var(--color-fail);
        font-weight: 700;
    }
    .check-skip {
        color: var(--color-text-muted);
    }
    .check-detail {
        color: var(--color-text-muted);
        font-size: 12px;
    }
    .fc-summary-grid {
        display: grid;
        gap: 12px;
        margin-bottom: 12px;
    }
    .fc-summary-card {
        background: var(--color-surface-alt);
        border: 1px solid color-mix(in srgb, var(--color-border) 80%, transparent);
        border-radius: 8px;
    }
    .fc-summary-toggle {
        display: block;
        cursor: pointer;
        padding: 12px;
    }
    .fc-summary-card summary {
        list-style: none;
    }
    .fc-summary-card summary::-webkit-details-marker {
        display: none;
    }
    .fc-summary-head {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 6px;
    }
    .fc-summary-title {
        font-weight: 700;
    }
    .fc-summary-preview {
        color: var(--color-text-muted);
        font-size: 12px;
        line-height: 1.6;
    }
    .fc-summary-body {
        padding: 0 12px 12px;
    }
    .fc-expand-all {
        appearance: none;
        border: 1px solid color-mix(in srgb, var(--color-border) 80%, transparent);
        background: var(--color-surface-alt);
        color: var(--color-news);
        border-radius: 999px;
        padding: 6px 12px;
        font-size: 12px;
        line-height: 1.2;
        cursor: pointer;
    }
    .fc-expand-all:hover {
        border-color: var(--color-news);
    }
    .fc-group-list {
        margin: 0;
        padding-left: 18px;
        font-size: 12px;
        color: var(--color-text-muted);
    }
    .fc-group-list li {
        margin-bottom: 5px;
    }
    .fc-findings {
        margin-top: 8px;
    }
    .fc-sources-list {
        font-size: 12px;
        color: var(--color-text-muted);
        margin-bottom: 8px;
    }
    .fc-sources-list a {
        color: var(--color-news);
    }
    .fc-footer {
        font-size: 11px;
        color: var(--color-text-muted);
        padding-top: 8px;
        border-top: 1px solid #333;
    }
    .fc-footer a {
        color: var(--color-news);
    }
</style>

<script is:inline>
    document.querySelectorAll('[data-fc-toggle-all]').forEach((button) => {
        const container = button.closest('.factcheck');
        if (!container) return;
        const items = Array.from(container.querySelectorAll('[data-fc-item]'));
        if (items.length === 0) return;

        const syncLabel = () => {
            const allOpen = items.every((item) => item.open);
            button.textContent = allOpen ? '전체 닫기' : '전체 보기';
            button.setAttribute('aria-expanded', allOpen ? 'true' : 'false');
        };

        button.addEventListener('click', () => {
            const shouldOpen = !items.every((item) => item.open);
            items.forEach((item) => {
                item.open = shouldOpen;
            });
            syncLabel();
        });

        items.forEach((item) => {
            item.addEventListener('toggle', syncLabel);
        });

        syncLabel();
    });
</script>
