        margin-top: 40px;
        padding: 20px 24px;
        background: var(--color-surface);
        border-radius: 10px;
        border: 1px solid var(--color-border);
        font-size: 13px;
    }
    .fc-title {
        font-size: 14px;
        margin-bottom: 12px;
    }
    .fc-meta {
        display: flex;
        flex-direction: column;
        gap: 4px;
        color: var(--color-text-muted);
        margin-bottom: 12px;
        font-size: 12px;
    }
    .fc-checks {
        display: flex;
        flex-direction: column;
        gap: 4px;
        margin-bottom: 12px;
    }
    .fc-check {
        display: flex;
        gap: 8px;
        align-items: center;
        flex-wrap: wrap;
    }
    .check-pass {
        color: var(--color-pass);
        font-weight: bold;
    }
    .check-fail {
        color: var(--color-fail);
        font-weight: bold;
    }
    .check-skip {
        color: var(--color-text-muted);
    }
    .check-detail {
        color: var(--color-text-muted);
        font-size: 12px;
    }
    .fc-groups {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 12px;
    }
    .fc-group {
        background: var(--color-surface-alt);
        border-radius: 8px;
        padding: 10px 12px;
    }
    .fc-group summary {
        display: flex;
        gap: 8px;
        align-items: center;
        cursor: pointer;
        font-weight: 600;
        list-style: none;
    }
    .fc-group summary::-webkit-details-marker {
        display: none;
    }
    .fc-group-summary {
        margin: 10px 0 8px;
        color: var(--color-text-muted);
        font-size: 12px;
        line-height: 1.6;
    }
    .fc-group-list {
        padding-left: 18px;
        font-size: 12px;
        color: var(--color-text-muted);
    }
    .fc-group-list li {
        margin-bottom: 5px;
    }
    .fc-findings {
        margin-top: 8px;
    }
    .fc-sources-list {
        font-size: 12px;
        color: var(--color-text-muted);
        margin-bottom: 8px;
    }
    .fc-sources-list a {
        color: var(--color-news);
    }
    .fc-footer {
        font-size: 11px;
        color: var(--color-text-muted);
        padding-top: 8px;
        border-top: 1px solid #333;
    }
    .fc-footer a {
        color: var(--color-news);
    }
</style>
