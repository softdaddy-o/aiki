---
interface Check {
    type: string;
    result: string;
    sources?: number;
    summary?: string;
    items?: string[];
    findings?: string[];
}

interface Source {
    url: string;
    title: string;
}

interface Props {
    status: string;
    date: string;
    checks: Check[];
    sources: Source[];
    lang: string;
}

const { status, date, checks, sources } = Astro.props as Props;
const statusIcon = status === 'passed' ? 'OK' : status === 'failed' ? 'FAIL' : 'PENDING';

function checkLabel(type: string) {
    if (type === 'source_match') return '원문 대조';
    if (type === 'web_cross_check') return '교차검증';
    if (type === 'number_verify') return '숫자·명칭 검증';
    if (type === 'adversarial') return '비판적 검증';
    return type;
}

function resultIcon(result: string) {
    if (result === 'pass') return 'OK';
    if (result === 'skip') return 'SKIP';
    return 'FAIL';
}

function fallbackSummary(check: Check) {
    if (check.type === 'source_match') return '원문 제목이랑 글 제목이 같은 축인지 먼저 맞춰봤다.';
    if (check.type === 'web_cross_check') return `관련 출처 ${check.sources ?? sources.length}건을 나란히 놓고 다시 봤다.`;
    if (check.type === 'number_verify') return '숫자와 고유 명칭은 따로 빼서 한 번 더 봤다.';
    if (check.type === 'adversarial') return '헷갈릴 수 있는 해석 포인트는 한 번 더 의심해봤다.';
    return '';
}

function fallbackItems(check: Check) {
    if (check.items && check.items.length > 0) {
        return check.items;
    }

    if (check.type === 'source_match') {
        return sources.slice(0, 2).map((source) => `${source.title} (${source.url})`);
    }

    if (check.type === 'web_cross_check') {
        return sources.map((source, index) => `비교 출처 ${index + 1}: ${source.title}`);
    }

    return [];
}
---

<details class="factcheck">
    <summary class="fc-toggle">
        <div>
            <div class="fc-title">팩트 체크</div>
            <div class="fc-meta-inline">상태 {statusIcon} · {date} KST</div>
        </div>
        <span class="fc-toggle-copy">열어서 보기</span>
    </summary>

    <div class="fc-body">
        <div class="fc-meta">
            <span>검증 생성: AI + 수집 스크립트 · {date}</span>
            <span>상태: {statusIcon}</span>
        </div>

        <div class="fc-groups">
            {checks.map((check) => (
                ((check.summary && check.summary.trim()) || fallbackItems(check).length > 0 || (check.findings && check.findings.length > 0) || fallbackSummary(check)) && (
                    <div class="fc-group">
                        <div class="fc-group-header">
                            <span class={check.result === 'pass' ? 'check-pass' : check.result === 'skip' ? 'check-skip' : 'check-fail'}>
                                {resultIcon(check.result)}
                            </span>
                            <span>{checkLabel(check.type)}</span>
                            {typeof check.sources === 'number' && <span class="check-detail">검토 출처 {check.sources}건</span>}
                        </div>
                        {(check.summary || fallbackSummary(check)) && <p class="fc-group-summary">{check.summary || fallbackSummary(check)}</p>}
                        {fallbackItems(check).length > 0 && (
                            <ul class="fc-group-list">
                                {fallbackItems(check).map((item) => (
                                    <li>{item}</li>
                                ))}
                            </ul>
                        )}
                        {check.findings && check.findings.length > 0 && (
                            <ul class="fc-group-list fc-findings">
                                {check.findings.map((finding) => (
                                    <li>{finding}</li>
                                ))}
                            </ul>
                        )}
                    </div>
                )
            ))}
        </div>

        {sources.length > 0 && (
            <div class="fc-sources-list">
                출처: {sources.map((source, index) => (
                    <>{index > 0 && ', '}<a href={source.url} target="_blank" rel="noopener">{source.title}</a></>
                ))}
            </div>
        )}

        <div class="fc-footer">
            마지막 검증 {date} KST ·
            <a href="https://github.com/softdaddy-o/aiki/issues/new"> 오류 제보</a>
        </div>
    </div>
</details>

<style>
    .factcheck {
        margin-top: 40px;
        padding: 20px 24px;
        background: var(--color-surface);
        border-radius: 10px;
        border: 1px solid var(--color-border);
        font-size: 13px;
    }
    .factcheck summary {
        list-style: none;
    }
    .factcheck summary::-webkit-details-marker {
        display: none;
    }
    .fc-toggle {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        cursor: pointer;
    }
    .fc-title {
        font-size: 14px;
        margin-bottom: 4px;
    }
    .fc-meta-inline {
        color: var(--color-text-muted);
        font-size: 12px;
    }
    .fc-toggle-copy {
        color: var(--color-text-muted);
        font-size: 12px;
        white-space: nowrap;
    }
    .factcheck[open] .fc-toggle-copy {
        color: var(--color-news);
    }
    .fc-body {
        margin-top: 14px;
    }
    .fc-meta {
        display: flex;
        flex-direction: column;
        gap: 4px;
        color: var(--color-text-muted);
        margin-bottom: 12px;
        font-size: 12px;
    }
    .check-pass {
        color: var(--color-pass);
        font-weight: bold;
    }
    .check-fail {
        color: var(--color-fail);
        font-weight: bold;
    }
    .check-skip {
        color: var(--color-text-muted);
    }
    .check-detail {
        color: var(--color-text-muted);
        font-size: 12px;
    }
    .fc-groups {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 12px;
    }
    .fc-group {
        background: var(--color-surface-alt);
        border-radius: 8px;
        padding: 10px 12px;
    }
    .fc-group-header {
        display: flex;
        gap: 8px;
        align-items: center;
        flex-wrap: wrap;
        font-weight: 600;
    }
    .fc-group-summary {
        margin: 10px 0 8px;
        color: var(--color-text-muted);
        font-size: 12px;
        line-height: 1.6;
    }
    .fc-group-list {
        padding-left: 18px;
        font-size: 12px;
        color: var(--color-text-muted);
    }
    .fc-group-list li {
        margin-bottom: 5px;
    }
    .fc-findings {
        margin-top: 8px;
    }
    .fc-sources-list {
        font-size: 12px;
        color: var(--color-text-muted);
        margin-bottom: 8px;
    }
    .fc-sources-list a {
        color: var(--color-news);
    }
    .fc-footer {
        font-size: 11px;
        color: var(--color-text-muted);
        padding-top: 8px;
        border-top: 1px solid #333;
    }
    .fc-footer a {
        color: var(--color-news);
    }
</style>
