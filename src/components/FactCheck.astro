---
interface Check {
    type: string;
    result: string;
    sources?: number;
    summary?: string;
    items?: string[];
    findings?: string[];
}

interface Source {
    url: string;
    title: string;
}

interface Props {
    status: string;
    date: string;
    checks: Check[];
    sources: Source[];
    lang: string;
}

const { status, date, checks, sources } = Astro.props as Props;
const statusIcon = status === 'passed' ? 'OK' : status === 'failed' ? 'FAIL' : 'PENDING';

function checkLabel(type: string) {
    if (type === 'source_match') return '원문 대조';
    if (type === 'web_cross_check') return '교차검증';
    if (type === 'number_verify') return '숫자·명칭 검증';
    if (type === 'adversarial') return '비판적 검증';
    return type;
}

function resultIcon(result: string) {
    if (result === 'pass') return 'OK';
    if (result === 'skip') return 'SKIP';
    return 'FAIL';
}

function fallbackSummary(check: Check) {
    if (check.type === 'source_match') return '이 글이 실제로 같은 대상과 사건을 가리키는지부터 먼저 맞춰봤다.';
    if (check.type === 'web_cross_check') return `원문 하나만 믿지 않으려고 관련 출처 ${check.sources ?? sources.length}건을 옆에 두고 다시 봤다.`;
    if (check.type === 'number_verify') return '헷갈리기 쉬운 숫자와 고유 명칭은 따로 떼어 한 번 더 봤다.';
    if (check.type === 'adversarial') return '독자가 너무 크게 믿거나 잘못 읽기 쉬운 지점은 따로 의심해보고 걸렀다.';
    return '';
}

function fallbackItems(check: Check) {
    if (check.items && check.items.length > 0) {
        return check.items;
    }

    if (check.type === 'source_match') {
        return sources.slice(0, 2).map((source) => `${source.title} (${source.url})`);
    }

    if (check.type === 'web_cross_check') {
        return sources.map((source, index) => `비교 출처 ${index + 1}: ${source.title}`);
    }

    return [];
}

const visibleChecks = checks
    .map((check) => ({
        ...check,
        label: checkLabel(check.type),
        preview: String(check.summary || fallbackSummary(check) || '').trim(),
        detailItems: fallbackItems(check),
        findingItems: Array.isArray(check.findings) ? check.findings : [],
    }))
    .filter((check) => check.preview || check.detailItems.length > 0 || check.findingItems.length > 0);
---

<section class="factcheck">
    <div class="fc-header">
        <div>
            <div class="fc-title">팩트 체크</div>
            <div class="fc-meta-inline">상태 {statusIcon} · {date} KST</div>
        </div>
    </div>

    <div class="fc-body">
        <div class="fc-meta">
            <span>검증 생성: AI + 수집 스크립트 · {date}</span>
            <span>상태: {statusIcon}</span>
        </div>

        {visibleChecks.length > 0 && (
            <div class="fc-summary-grid">
                {visibleChecks.map((check) => (
                    <section class="fc-summary-card">
                        <div class="fc-summary-head">
                            <span class={check.result === 'pass' ? 'check-pass' : check.result === 'skip' ? 'check-skip' : 'check-fail'}>
                                {resultIcon(check.result)}
                            </span>
                            <span class="fc-summary-title">{check.label}</span>
                            {typeof check.sources === 'number' && <span class="check-detail">검토 출처 {check.sources}건</span>}
                        </div>
                        {check.preview && <div class="fc-summary-preview">{check.preview}</div>}
                    </section>
                ))}
            </div>
        )}

        <details class="fc-details">
            <summary class="fc-details-toggle">
                <span>팩트 체크 전체 보기</span>
                <span class="fc-details-toggle-copy">원문 대조, 교차검증, 숫자·명칭 검증, 비판적 검증</span>
            </summary>

            <div class="fc-groups">
                {visibleChecks.map((check) => (
                    <section class="fc-group">
                        <div class="sr-only">{check.label} 상세 검증</div>
                        <div class="fc-group-body">
                            {check.detailItems.length > 0 && (
                                <ul class="fc-group-list">
                                    {check.detailItems.map((item) => (
                                        <li>{item}</li>
                                    ))}
                                </ul>
                            )}
                            {check.findingItems.length > 0 && (
                                <ul class="fc-group-list fc-findings">
                                    {check.findingItems.map((finding) => (
                                        <li>{finding}</li>
                                    ))}
                                </ul>
                            )}
                        </div>
                    </section>
                ))}
            </div>
        </details>

        {sources.length > 0 && (
            <div class="fc-sources-list">
                출처: {sources.map((source, index) => (
                    <>{index > 0 && ', '}<a href={source.url} target="_blank" rel="noopener">{source.title}</a></>
                ))}
            </div>
        )}

        <div class="fc-footer">
            마지막 검증 {date} KST ·
            <a href="https://github.com/softdaddy-o/aiki/issues/new"> 오류 제보</a>
        </div>
    </div>
</section>

<style>
    .factcheck {
        margin-top: 40px;
        padding: 20px 24px;
        background: var(--color-surface);
        border-radius: 10px;
        border: 1px solid var(--color-border);
        font-size: 13px;
    }
    .factcheck summary {
        list-style: none;
    }
    .factcheck summary::-webkit-details-marker {
        display: none;
    }
    .fc-header { margin-bottom: 14px; }
    .fc-title {
        font-size: 14px;
        margin-bottom: 4px;
    }
    .fc-meta-inline {
        color: var(--color-text-muted);
        font-size: 12px;
    }
    .fc-meta {
        display: flex;
        flex-direction: column;
        gap: 4px;
        color: var(--color-text-muted);
        margin-bottom: 12px;
        font-size: 12px;
    }
    .check-pass {
        color: var(--color-pass);
        font-weight: bold;
    }
    .check-fail {
        color: var(--color-fail);
        font-weight: bold;
    }
    .check-skip {
        color: var(--color-text-muted);
    }
    .check-detail {
        color: var(--color-text-muted);
        font-size: 12px;
    }
    .fc-summary-grid {
        display: grid;
        gap: 12px;
        margin-bottom: 12px;
    }
    .fc-summary-card {
        padding: 12px;
        background: var(--color-surface-alt);
        border: 1px solid color-mix(in srgb, var(--color-border) 80%, transparent);
        border-radius: 8px;
    }
    .fc-summary-head {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 6px;
    }
    .fc-summary-title {
        font-weight: 700;
    }
    .fc-summary-preview {
        color: var(--color-text-muted);
        font-size: 12px;
        line-height: 1.6;
    }
    .fc-details {
        background: var(--color-surface-alt);
        border-radius: 8px;
        border: 1px solid color-mix(in srgb, var(--color-border) 80%, transparent);
        margin-bottom: 12px;
    }
    .fc-details-toggle {
        display: flex;
        justify-content: space-between;
        gap: 8px;
        align-items: center;
        padding: 11px 12px;
        cursor: pointer;
    }
    .fc-details-toggle-copy {
        color: var(--color-text-muted);
        font-size: 12px;
        white-space: nowrap;
    }
    .fc-details[open] .fc-details-toggle-copy {
        color: var(--color-news);
    }
    .fc-groups {
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding: 0 12px 12px;
    }
    .fc-group {
        background: color-mix(in srgb, var(--color-surface) 75%, transparent);
        border-radius: 8px;
        border: 1px solid color-mix(in srgb, var(--color-border) 70%, transparent);
    }
    .fc-group-body {
        padding: 12px;
    }
    .fc-group-list {
        margin: 0;
        padding-left: 18px;
        font-size: 12px;
        color: var(--color-text-muted);
    }
    .fc-group-list li {
        margin-bottom: 5px;
    }
    .fc-findings {
        margin-top: 8px;
    }
    .fc-sources-list {
        font-size: 12px;
        color: var(--color-text-muted);
        margin-bottom: 8px;
    }
    .fc-sources-list a {
        color: var(--color-news);
    }
    .fc-footer {
        font-size: 11px;
        color: var(--color-text-muted);
        padding-top: 8px;
        border-top: 1px solid #333;
    }
    .fc-footer a {
        color: var(--color-news);
    }
    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }
</style>
