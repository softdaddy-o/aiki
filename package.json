{
  "name": "d-srcp-aiki",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node scripts/aiki-pre-publish-check.cjs && node scripts/aiki-pre-publish-check.cjs --all",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "validate:content": "node scripts/aiki-prune-news.cjs && node scripts/aiki-generate-wiki.cjs && node scripts/aiki-sync-news-factcheck.cjs && node scripts/aiki-pre-publish-check.cjs && node scripts/aiki-pre-publish-check.cjs --all",
    "generate:wiki": "node scripts/aiki-generate-wiki.cjs",
    "prune:news": "node scripts/aiki-prune-news.cjs",
    "sync:news-factcheck": "node scripts/aiki-sync-news-factcheck.cjs",
    "backfill:range": "node scripts/aiki-backfill-range.cjs",
    "backfill:reader-value": "node scripts/aiki-backfill-reader-value.cjs"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.2",
    "astro": "^6.1.3",
    "astro-pagefind": "^1.8.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
